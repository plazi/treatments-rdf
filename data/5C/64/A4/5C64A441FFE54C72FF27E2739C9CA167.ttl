    dc:creator "Motta, Ana P.; Castroviejo-Fisher, Santiago; Venegas, Pablo J.; Orrico, Victor G. D.; Padial, José M." ;
    dc:title "Dendropsophus frosti Motta, Castroviejo-Fisher, Venegas, Orrico & Padial, 2012, sp. nov." ;
