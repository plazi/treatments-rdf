    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10094702>
    dc:description "FIGURE 111. Lasioglossum foveolatum (Robertson). Female (A) lateral habitus; (B) dorsal habitus; (C) face; (D) lateral view of head; (E) mesoscutum, tegula. Scale bars, A–C = 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10094702/files/figure.png" ;
