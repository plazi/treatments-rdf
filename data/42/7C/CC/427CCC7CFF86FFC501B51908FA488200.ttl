    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10094483>
    dc:description "FIGURE 2. Forewings of female Lasioglossum subgenus Dialictus. (A) Typical forewing with three submarginal cells. Pterostigma (pt), basal vein (b), arrows indicate weakened veins. (B) Forewing with two submarginal cells. Arrows indicate weakened veins." ;
    fabio:hasRepresentation "https://zenodo.org/record/10094483/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10094493>
    dc:description "FIGURE 7. Tegula of (A) L. imbrex (tegulare species group), (B) L. oceanicum." ;
    fabio:hasRepresentation "https://zenodo.org/record/10094493/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10094495>
    dc:description "FIGURE 8. Mesoscutal punctation on lateral portion of disc (A) L. obscurum, (B) L. incompletum." ;
    fabio:hasRepresentation "https://zenodo.org/record/10094495/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10094497>
    dc:description "FIGURE 9. Propodeum of (A) L. hudsoniellum, (B) L. testaceum." ;
