    dc:title "Liolaemus cyaneinotatus Martinez, Avila, Perez, Perez, Sites & Morando, 2011, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Liolaemus_cyaneinotatus_Martinez_2011> ;
