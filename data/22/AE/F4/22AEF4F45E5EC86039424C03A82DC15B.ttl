    dc:description "Plate 50. Kleemannia plumigera, female, dorsal idiosoma." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/158663" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/zookeys.704.13304.plate51>
    dc:description "Plate 51. Kleemannia plumigera, female (from Germany), dorsal idiosoma." ;
