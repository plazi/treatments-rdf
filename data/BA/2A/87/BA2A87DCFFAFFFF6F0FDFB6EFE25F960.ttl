    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10130875>
    dc:description "Fig. 39. Phlaeopterus species, maxillae, dorsal and ventral views. A–B) P. houkae, C–D) P. obsoletus, E–F) P. elongatus." ;
    fabio:hasRepresentation "https://zenodo.org/record/10130875/files/figure.png" ;
