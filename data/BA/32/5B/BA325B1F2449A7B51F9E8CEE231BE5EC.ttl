    dc:date "2022" ;
    dc:title "Two new species of Navicula (Bacillariophyta) from Southeast Asia" ;
    fabio:hasPart <http://dx.doi.org/10.3897/phytokeys.190.78164.figure1>, <http://dx.doi.org/10.3897/phytokeys.190.78164.figure2> ;
