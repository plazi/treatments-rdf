treatment:011CD740F91BFFD6BD808090957AFEB8
    cito:cites <http://dx.doi.org/10.5281/zenodo.238588>, <http://dx.doi.org/10.5281/zenodo.238589>, <http://dx.doi.org/10.5281/zenodo.238593>, <http://dx.doi.org/10.5281/zenodo.238590>, <http://dx.doi.org/10.5281/zenodo.238591>, <http://dx.doi.org/10.5281/zenodo.238592>, <http://dx.doi.org/10.5281/zenodo.238594> ;
    dc:creator "Petković, Matija; Delić, Teo; Lučić, Luka; Fišer, Cene" ;
    dc:title "Niphargidae Petković, Delić, Lučić & Fišer, 2015, sp. n." ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.4027.1.5> ;
    trt:treatsTaxonName <http://taxon-name.plazi.org/id/Animalia/Niphargidae> ;
    a trt:Treatment .

<http://dx.doi.org/10.11646/zootaxa.4027.1.5>
    bibo:endPage "129" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "117" ;
    bibo:volume "4027" ;
    dc:creator "Petković, Matija; Delić, Teo; Lučić, Luka; Fišer, Cene" ;
    dc:date "2015" ;
    dc:title "Description of a new species of Niphargus (Crustacea: Amphipoda: Niphargidae): the first record of a lake ecomorph in the Carpathian Mountains" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.238588>, <http://dx.doi.org/10.5281/zenodo.238589>, <http://dx.doi.org/10.5281/zenodo.238593>, <http://dx.doi.org/10.5281/zenodo.238590>, <http://dx.doi.org/10.5281/zenodo.238591>, <http://dx.doi.org/10.5281/zenodo.238592>, <http://dx.doi.org/10.5281/zenodo.238594> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.238588>
    dc:description "FIGURE 1. Distribution map of cave lake ecomorphs belonging to two major clades on Balkan Peninsula. Symbols indicate clade affiliation; closed circles for “ Northern orcinus group ”, triangles for “ Southern orcinus group ” and red circles for newly described species. Note a long distance between N. mirocensis sp. n. and species from the same phylogenetic lineage (400 km) and N. mirocensis sp. n. and closest representative of cave lake ecomorphs (280 km). Data were obtained from SubBio database (http: // subbio. net / db /)." ;
    fabio:hasRepresentation "https://zenodo.org/record/238588/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.238589>
    dc:description "FIGURE 2. Niphargus mirocensis, sp. n., female 17.95 mm (holotype), Rakin ponor. Head and pleosoma I – III are digitally positioned on a drawing, compared with a real holotype. Holotype`s left ppV (damaged) is reconstructed based on the right ppV from the same specimen." ;
    fabio:hasRepresentation "https://zenodo.org/record/238589/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.238593>
    dc:description "FIGURE 6. Niphargus mirocensis, sp. n., female 17.95 mm (holotype), Rakin ponor: aI – II = antennas I – II; md – R = right mandibula; md – L = left mandibula; mxp = maxilliped; mx 1 – 2 = maxilla I and II." ;
    fabio:hasRepresentation "https://zenodo.org/record/238593/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.238590>
    dc:description "FIGURE 3. Niphargus mirocensis, sp. n., female 17.95 mm (holotype), Rakin ponor: gI – II = gnathopods I – II." ;
    fabio:hasRepresentation "https://zenodo.org/record/238590/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.238591>
    dc:description "FIGURE 4. Niphargus mirocensis, sp. n., female 17.95 mm (holotype), Rakin ponor: ppIII – VII = pereopods III – VII." ;
    fabio:hasRepresentation "https://zenodo.org/record/238591/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.238592>
    dc:description "FIGURE 5. Niphargus mirocensis, sp. n., female 17.95 mm (holotype), Rakin ponor: plpII = plepopod II; T = telson; upI – upIII = uropods i – III." ;
    fabio:hasRepresentation "https://zenodo.org/record/238592/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.238594>
    dc:description "FIGURE 7. Phylogenetic relationships as inferred from Bayesian analysis. Color of nodes indicates range of posterior probabilities (Black circles = 1, gray circles = 0.95 – 0.99, white circles = 0. 90 –. 94). Clade with focal N. mirocensis sp. n. is indicated." ;
    fabio:hasRepresentation "https://zenodo.org/record/238594/files/figure.png" ;
    a fabio:Figure .

