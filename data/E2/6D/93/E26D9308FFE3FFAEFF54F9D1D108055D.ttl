    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10681215>
    dc:description "FIGURE 25. Bebaiotes penniy sp. nov. holotype male: A. Male habitus, lateral view; B. Female, habitus, lateral view; C. Male head, anterior view; D. Male head and thorax, dorsal view; E. Male abdominal process, lateral view. Scale bars: A, B = 1 mm; C = 0.7 mm; D = 0.5 mm; E = 0.3 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10681215/files/figure.png" ;
