    dc:creator "Huber, Bernhard A.; Carvalho, Leonardo S." ;
    dc:title "Psilochorus Simon 1893" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Psilochorus_Simon_1893> ;
    trt:deprecates <http://taxon-concept.plazi.org/id/Animalia/Arnapa_Huber_2019> ;
