    dc:title "A new species of Hibiscadelphus Rock (Malvaceae, Hibisceae) from Maui, Hawaiian Islands" ;
    fabio:hasPart <https://binary.pensoft.net/fig/10700>, <https://binary.pensoft.net/fig/10701>, <https://binary.pensoft.net/fig/10702> ;
