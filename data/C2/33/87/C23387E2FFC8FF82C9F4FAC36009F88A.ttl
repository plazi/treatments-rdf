    dc:date "2023" ;
    dc:title "Three new species of the Synapturanus rabus complex (Microhylidae: Otophryninae) in Colombia with a review of the genus Synapturanus" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7777054>, <http://dx.doi.org/10.5281/zenodo.7777058>, <http://dx.doi.org/10.5281/zenodo.7777074>, <http://dx.doi.org/10.5281/zenodo.7777076>, <http://dx.doi.org/10.5281/zenodo.7777080> ;
