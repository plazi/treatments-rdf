    dc:title "Rediscovery of Prosthechea sessiliflora (Orchidaceae, Laeliinae) in the Brazilian Cerrado domain provides valuable taxonomic data and allows nomenclatural adjustments" ;
    bibo:endPage "100" ;
    bibo:issue "1" ;
    bibo:journal "Phytotaxa" ;
    bibo:pubDate "2023-10-12" ;
    bibo:startPage "94" ;
