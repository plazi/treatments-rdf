    dc:title "Ostracods from the Kunming area of SW China, with description of two new species and male records of Cypridopsis vidua (O. F. Müller, 1776)" ;
    bibo:endPage "215" ;
    bibo:issue "2" ;
    bibo:journal "Zootaxa" ;
