    dc:title "New deep-sea Atlantic and Antarctic species of Abyssorchomene De Broyer, 1984 (Amphipoda, Lysianassoidea, Uristidae) with a redescription of A. abyssorum (Stebbing, 1888)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6686631>, <http://dx.doi.org/10.5281/zenodo.6686635>, <http://dx.doi.org/10.5281/zenodo.6686639>, <http://dx.doi.org/10.5281/zenodo.6686641>, <http://dx.doi.org/10.5281/zenodo.6686633>, <http://dx.doi.org/10.5281/zenodo.6686645>, <http://dx.doi.org/10.5281/zenodo.6686637>, <http://dx.doi.org/10.5281/zenodo.6686643>, <http://dx.doi.org/10.5281/zenodo.6686663>, <http://dx.doi.org/10.5281/zenodo.6686687>, <http://dx.doi.org/10.5281/zenodo.6686707> ;
