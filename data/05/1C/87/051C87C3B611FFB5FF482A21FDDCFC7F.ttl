    dc:title "Echiniscus clavispinosus Fontoura, Pilato & Lisi, 2011, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Echiniscus_clavispinosus_Fontoura_2011> ;
