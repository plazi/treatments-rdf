    dc:title "Laboulbenia quarantenae Haelewaters & Kesel 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Fungi/Laboulbenia_quarantenae_Haelewaters_2020> ;
