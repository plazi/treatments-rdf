    dc:title "A new freshwater species Achnanthidium kangdingnese (Bacillariophyta, Achnanthidiaceae) from Sichuan Province, China" ;
    fabio:hasPart <http://dx.doi.org/10.3897/phytokeys.204.89690.figure1>, <http://dx.doi.org/10.3897/phytokeys.204.89690.figure2>, <http://dx.doi.org/10.3897/phytokeys.204.89690.figure3>, <http://dx.doi.org/10.3897/phytokeys.204.89690.figure4>, <http://dx.doi.org/10.3897/phytokeys.204.89690.figure5> ;
