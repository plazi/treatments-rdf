    dc:title "A New Species Of Predaceous Diving Beetle, Heterosternuta Phoebeae (Coleoptera: Dytiscidae), From The Ozark Mountains Of Arkansas" ;
    bibo:endPage "121" ;
    bibo:issue "2" ;
