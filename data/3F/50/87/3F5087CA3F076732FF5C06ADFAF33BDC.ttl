    dc:creator "Lana, Paulo Da Cunha", "Magalhães, Wagner F.", "Oliveira, Verônica Maria De" ;
    dc:date "2021" ;
    dc:title "Ten new species of Phyllodoce Lamarck, 1818 (Phyllodocidae, Annelida) from Brazil" ;
    bibo:endPage "61" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
