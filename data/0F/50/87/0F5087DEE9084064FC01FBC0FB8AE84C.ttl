    dc:creator "Carrion-Bonilla, Carlos Alberto", "Cook, Joseph Anthony" ;
    dc:date "2020" ;
    dc:title "A new bat species of the genus Myotis with comments on the phylogenetic placement of M. keaysi and M. pilosatibialis" ;
    bibo:endPage "532" ;
    bibo:issue "3" ;
    bibo:journal "Therya" ;
