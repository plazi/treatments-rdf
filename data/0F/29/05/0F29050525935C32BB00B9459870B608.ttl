    dc:title "Myrsidea quadrifasciata (Phthiraptera: Amblycera) - a unique host generalist among highly host-specific chewing lice" ;
    fabio:hasPart <http://dx.doi.org/10.3897/asp.79.e63975.figures1-3>, <http://dx.doi.org/10.3897/asp.79.e63975.figures4-18>, <http://dx.doi.org/10.3897/asp.79.e63975.figures19-20> ;
