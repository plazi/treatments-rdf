    dc:creator "Kerr, Alexander M." ;
    dc:title "Holothuria (Semperothuria) roseomaculata Kerr, 2013, n. sp." ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Holothuria> ;
