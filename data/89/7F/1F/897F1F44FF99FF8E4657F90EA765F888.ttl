    dc:title "Revision of the genus Amputoearinus (Hymenoptera: Braconidae: Agathidinae) with fourteen new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.174175>, <http://dx.doi.org/10.5281/zenodo.174176>, <http://dx.doi.org/10.5281/zenodo.174178>, <http://dx.doi.org/10.5281/zenodo.174177> ;
