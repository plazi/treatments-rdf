    dc:creator "Li, Jiaxiang; Xu, Yongfu; Zhao, Lijuan" ;
    dc:date "2019" ;
    dc:title "Swertia hongquanii, a new species of Gentianaceae from Mt. Wuling, southern China" ;
    fabio:hasPart <http://dx.doi.org/10.3897/phytokeys.132.37009.figure1>, <http://dx.doi.org/10.3897/phytokeys.132.37009.figure2>, <http://dx.doi.org/10.3897/phytokeys.132.37009.figure3> ;
