    dc:title "Western Hemisphere Lasiochilinae (Hemiptera: Heteroptera: Anthocoridae) with comments on some extralimital species and some considerations on suprageneric relationships" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4947861>, <http://dx.doi.org/10.5281/zenodo.4947905>, <http://dx.doi.org/10.5281/zenodo.4947913>, <http://dx.doi.org/10.5281/zenodo.4947895>, <http://dx.doi.org/10.5281/zenodo.4947921>, <http://dx.doi.org/10.5281/zenodo.4947917>, <http://dx.doi.org/10.5281/zenodo.4947875>, <http://dx.doi.org/10.5281/zenodo.4947883>, <http://dx.doi.org/10.5281/zenodo.4947881>, <http://dx.doi.org/10.5281/zenodo.4947891>, <http://dx.doi.org/10.5281/zenodo.4947879>, <http://dx.doi.org/10.5281/zenodo.4947925>, <http://dx.doi.org/10.5281/zenodo.4947911>, <http://dx.doi.org/10.5281/zenodo.4947889>, <http://dx.doi.org/10.5281/zenodo.4947927>, <http://dx.doi.org/10.5281/zenodo.4947901> ;
