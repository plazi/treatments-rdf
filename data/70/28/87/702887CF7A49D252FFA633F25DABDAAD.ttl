    dc:creator "Toporkova, Yana Y.; Askarova, Elena K.; Gorina, Svetlana S.; Mukhtarova, Lucia S.; Grechkin, Alexander N." ;
    dc:title "Selaginella moellendorffii subsp. oxylipin Hieron. 1901" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Plantae/Selaginella_moellendorffii_oxylipin_Hieron._1901> ;
