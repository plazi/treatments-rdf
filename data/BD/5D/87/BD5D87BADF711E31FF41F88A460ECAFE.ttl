    dc:creator "Frank Glaw; Jörn Köhler; Ted M. Townsend; Miguel Vences" ;
    dc:date "2012" ;
    dc:title "Rivaling the World’s Smallest Reptiles: Discovery of Miniaturized and Microendemic New Species of Leaf Chameleons (Brookesia) from Northern Madagascar" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.894057>, <http://dx.doi.org/10.5281/zenodo.894053>, <http://dx.doi.org/10.5281/zenodo.894051> ;
