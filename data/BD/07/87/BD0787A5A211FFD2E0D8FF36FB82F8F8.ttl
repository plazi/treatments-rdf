    dc:title "Description of a new species of the genus Chrysolina (Coleoptera: Chrysomelidae) from Honshu, and notes on records of Chrysolina aeruginosa in Japan" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7617058>, <http://dx.doi.org/10.5281/zenodo.7617060>, <http://dx.doi.org/10.5281/zenodo.7617068>, <http://dx.doi.org/10.5281/zenodo.7617072>, <http://dx.doi.org/10.5281/zenodo.7617076>, <http://dx.doi.org/10.5281/zenodo.7617074>, <http://dx.doi.org/10.5281/zenodo.7617078>, <http://dx.doi.org/10.5281/zenodo.7617080>, <http://dx.doi.org/10.5281/zenodo.7617082>, <http://dx.doi.org/10.5281/zenodo.7617086> ;
