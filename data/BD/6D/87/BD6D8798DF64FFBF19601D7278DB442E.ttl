    dc:title "Lynx canadensis (Carnivora: Felidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4573616>, <http://dx.doi.org/10.5281/zenodo.4573618>, <http://dx.doi.org/10.5281/zenodo.4573620> ;
