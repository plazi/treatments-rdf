    dc:title "Pristimantis munozi Rojas-Runjaic, Delgado & Guayasamin, 2014, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Pristimantis_munozi_Rojas-Runjaic_2014> ;
