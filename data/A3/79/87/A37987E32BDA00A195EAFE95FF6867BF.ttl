    dc:creator "Polhemus, Dan A." ;
    dc:date "2024" ;
    dc:title "Thirty-four new species of Rhagovelia (Heteroptera: Veliidae) from the East Papua Composite Terrane, far eastern New Guinea" ;
    bibo:endPage "214" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2024-01-17" ;
    bibo:startPage "1" ;
