    dc:title "A survey of Pholcus spiders (Araneae, Pholcidae) from the Qinling Mountains of central China, with descriptions of seven new species" ;
    bibo:endPage "221" ;
    bibo:issue "1" ;
    bibo:journal "Zoosystematics and Evolution" ;
