    dc:title "Leptodactylus sertanejo Giaretta & Costa, 2007, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Leptodactylus_sertanejo_Giaretta_2007> ;
