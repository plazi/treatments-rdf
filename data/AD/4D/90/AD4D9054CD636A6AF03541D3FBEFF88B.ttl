    dc:title "Cameroceras turrisoides Kröger 2013, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/AD4D9054CD636A6AF03541D3FBEFF88B.mc.958C2B1FCD6C6A6EF28A447CFEF0FC2E> ;
