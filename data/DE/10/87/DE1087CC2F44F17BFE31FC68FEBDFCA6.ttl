    dc:title "Lisubatrus dongzhiweii gen. et sp. nov. from the Gaoligong Mountains, China (Coleoptera: Staphylinidae: Pselaphinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5363003>, <http://dx.doi.org/10.5281/zenodo.5363005>, <http://dx.doi.org/10.5281/zenodo.5363007>, <http://dx.doi.org/10.5281/zenodo.5363009> ;
