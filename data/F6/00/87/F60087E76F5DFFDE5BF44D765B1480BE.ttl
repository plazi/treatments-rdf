    dc:title "Three new Cryptochetum Rondani, 1875 (Diptera: Cryptochetidae) from Yunnan Province, China and an identification key to Chinese species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3668836>, <http://dx.doi.org/10.5281/zenodo.3668828>, <http://dx.doi.org/10.5281/zenodo.3668824>, <http://dx.doi.org/10.5281/zenodo.3668832>, <http://dx.doi.org/10.5281/zenodo.3668838> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.3668836>
    dc:description "Figs 22–29. Wings of eight species of Cryptochetum. 22. C. curvatum Yang & Yang, 1996. 23. C. deltatum Yang & Yang, 1996. 24. C. tianmuense Yang & Yang, 2001. 25. C. acutulum Yang & Yang, 1996. 26. C. zalatilabium Xi & Yang, 2015. 27. C. kunmingense Yang & Yang, 1996. 28. C. fanjingshanum Yang & Yang, 1988. 29. C. maolanum Yang & Yang, 1996. Scale bar = 0.1 mm" ;
    fabio:hasRepresentation "https://zenodo.org/record/3668836/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3668828>
    dc:description "Figs 8–10. Cryptochetum glochidiatusum sp. nov., holotype, ♂ (CR122). 8. Head, lateral view. 9. Head, dorsal view. 10. Wing, dorsal view. Scale bar = 0.1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/3668828/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3668824>
    dc:description "Figs 1–3. Cryptochetum euthyiproboscise sp. nov., holotype, ♂ (CR101). 1. Head, lateral view. 2. Head, dorsal view. 3. Wing, dorsal view. Scale bar = 0.1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/3668824/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3668832>
    dc:description "Figs 15–17. Cryptochetum longilingum sp. nov., holotype (CR154), ♂. 15. Head, lateral view. 16. Head, dorsal view. 17. Wing, dorsal view. Scale bar = 0.1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/3668832/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3668838>
    dc:description "Figs 30–36. Wings of seven species of Cryptochetum. 30. C. shaanxiense Xi & Yang, 2015. 31. C. yunnanum Xi & Yang, 2015. 32. C. nonagintaseptem Yang & Yang, 1998. 33. C. medianum Yang & Yang, 1998. 34. C. sinicum Yang & Yang, 1996. 35. C. acuticornutum Yang & Yang, 1998. 36. C. beijingense Yang & Yang, 1996. Scale bars = 0.1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/3668838/files/figure.png" ;
    a fabio:Figure .

