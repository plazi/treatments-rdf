    dc:title "Seven new species of the genus Lathrobium Gravenhorst (Coleoptera: Staphylinidae: Paederinae) from Central Honshu, Japan, with new distributional records" ;
    bibo:endPage "529" ;
    bibo:issue "5" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2024-01-24" ;
    bibo:startPage "501" ;
