    dc:creator "Demurtas, Olivia Costantina", "Diretto, Gianfranco", "Ferrante, Paola", "Giuliano, Giovanni", "Kanellis, Angelos K.", "Mini, Paola", "Papaefthimiou, Dimitra" ;
    dc:date "2019" ;
    dc:title "Heterologous production of labdane-type diterpenes in the green alga Chlamydomonas reinhardtii" ;
    bibo:endPage "8" ;
    bibo:journal "Phytochemistry" ;
    bibo:pubDate "2019-11-30" ;
    bibo:startPage "1" ;
    bibo:volume "167" ;
