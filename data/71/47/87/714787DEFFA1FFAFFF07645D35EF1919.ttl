    dc:creator "Figueroa, José Manuel Tierno De; López-Rodríguez, Manuel Jesús" ;
    dc:date "2010" ;
    dc:title "Protonemura gevi sp. n., a cavernicolous new species of stonefly (Insecta: Plecoptera)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.275761>, <http://dx.doi.org/10.5281/zenodo.275762>, <http://dx.doi.org/10.5281/zenodo.275763>, <http://dx.doi.org/10.5281/zenodo.275764> ;
