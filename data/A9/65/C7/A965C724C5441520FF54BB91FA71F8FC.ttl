    dc:title "Zaitzevhydrus Fery & Ribera 2018, n. gen." ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Hydroporus_formaster_formaster>, <http://taxon-name.plazi.org/id/Animalia/Zaitzevhydrus_formaster> ;
