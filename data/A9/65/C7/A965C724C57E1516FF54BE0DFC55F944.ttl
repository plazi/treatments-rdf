    dc:creator "Fery, Hans; Ribera, Ignacio" ;
    dc:title "Mystonectes Fery & Ribera 2018, n. gen." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Mystonectes_Fery_2018> ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.4474.1.1> ;
