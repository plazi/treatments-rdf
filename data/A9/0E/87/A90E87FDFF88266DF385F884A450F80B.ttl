    dc:creator "Cobb, Janessa C.", "Herrera, Joan C.", "Janies, Daniel", "Lawrence, John M.", "Lopez, Karen" ;
    dc:date "2019" ;
    dc:title "A new species of Astropecten (Echinodermata: Asteroidea: Paxillosida: Astropectinidae) and a comparison of the Astropecten species from the Gulf of Mexico and the East Florida Shelf" ;
    bibo:endPage "325" ;
    bibo:issue "3" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2019-05-30" ;
