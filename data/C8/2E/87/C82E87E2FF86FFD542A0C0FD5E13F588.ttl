    dc:title "Kokkocynips panamensis Medianero & Nieves-Aldrey 2021, n. sp." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/C82E87E2FF86FFD542A0C0FD5E13F588.mc.F0EF3CA9FF86FFDB4377C7775898F0C2>, <http://tb.plazi.org/GgServer/dwcaRecords/C82E87E2FF86FFD542A0C0FD5E13F588.mc.F0EF3CA9FF86FFDB41BEC78C5E8DF156> ;
