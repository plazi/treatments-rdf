    dc:date "2008" ;
    dc:title "Description of eleven new Triplectides species (Trichoptera: Leptoceridae) from New Caledonia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.182906>, <http://dx.doi.org/10.5281/zenodo.182915> ;
