    cito:cites <http://dx.doi.org/10.5281/zenodo.217552>, <http://dx.doi.org/10.5281/zenodo.217553>, <http://dx.doi.org/10.5281/zenodo.217554> ;
    dc:creator "Uyeno, Daisuke" ;
    dc:title "Cardiodectes bellwoodi Uyeno, 2013, n. sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cardiodectes_bellwoodi_Uyeno_2013> ;
