    dc:creator "Johanson, Kjell Arne; Malm, Tobias" ;
    dc:title "Helicopsyche (Feropsyche) cipoensis Johanson & Malm, 2006, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Helicopsyche_cipoensis_Johanson_2006> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.172404> ;
