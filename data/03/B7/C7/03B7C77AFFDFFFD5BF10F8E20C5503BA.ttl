    dc:title "Revision of Scopaeus Erichson, 1839 (Coleoptera, Staphylinidae, Paederinae) of Indonesia, with description of 19 new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.10724250>, <http://dx.doi.org/10.5281/zenodo.10724262>, <http://dx.doi.org/10.5281/zenodo.10724292> ;
