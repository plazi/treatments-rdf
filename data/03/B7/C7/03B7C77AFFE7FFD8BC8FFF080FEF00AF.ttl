    dc:title "Scopaeus borneensis Cameron 1941" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03B7C77AFFE7FFD8BC8FFF080FEF00AF.mc.3B767C31FFE7FFD3BC8FFD840F3706DB> ;
