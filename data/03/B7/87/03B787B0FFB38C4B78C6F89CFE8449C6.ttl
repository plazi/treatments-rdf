    dc:title "Notes on Nearctic genera Catalinus Casey and Parascydmus Casey (Coleoptera: Staphylinidae: Scydmaeninae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2673389>, <http://dx.doi.org/10.5281/zenodo.2673391>, <http://dx.doi.org/10.5281/zenodo.2673393> ;
