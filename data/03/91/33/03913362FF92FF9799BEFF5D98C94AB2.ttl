    bibo:volume "3581" ;
    dc:creator "Magalhães, Wagner F.; Bailey-Brock, Julie H." ;
    dc:date "2012" ;
    dc:title "Capitellidae Grube, 1862 (Annelida: Polychaeta) from the Hawaiian Islands with description of two new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.215330>, <http://dx.doi.org/10.5281/zenodo.215331>, <http://dx.doi.org/10.5281/zenodo.215332> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.215330>
    dc:description "FIGURE 20. Mediomastus californiensis: A, MGSP of anterior end in dorso-lateral view; B, MGSP of posterior end with pygidium. Notodasus dasybranchoides sp. nov.: C, anterior end in frontal view showing prostomium, palpode and peristomium; D, transitional segments between thorax and abdomen; E, posterior abdominal segments in ventral view showing retractile branchiae; F, MGSP of incomplete specimen." ;
    fabio:hasRepresentation "https://zenodo.org/record/215330/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.215331>
    dc:description "FIGURE 21. Notodasus dasybranchoides sp. nov.: A, anterior end in lateral view; B, transition between thoracic and abdominal segments in dorsal view; C, anterior abdominal segments in lateral view; D, posterior abdominal segments in ventral view showing tufts of branchiae; E, posterior end with pygidium." ;
    fabio:hasRepresentation "https://zenodo.org/record/215331/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.215332>
    dc:description "FIGURE 22. SEM of Notodasus dasybranchoides sp. nov: A, posterior end in ventral view showing protruding branchiae; B, tufts of branchiae; C, posterior abdominal segments in lateral view showing lateral organs and branchial pores; D, abdominal hooded hooks." ;
    fabio:hasRepresentation "https://zenodo.org/record/215332/files/figure.png" ;
    a fabio:Figure .

