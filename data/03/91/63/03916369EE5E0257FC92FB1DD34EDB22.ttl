    dc:description "FIGURE 2. Arethaea solterae sp. nov. (holotype male INHS-P2190-1). A, Habitus, right lateral view. B, Close-up view of head and pronotum." ;
    fabio:hasRepresentation "https://zenodo.org/record/8073014/files/figure.png" ;
