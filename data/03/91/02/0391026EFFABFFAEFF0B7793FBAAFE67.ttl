    a trt:Treatment .

<http://dx.doi.org/10.21248/contrib.entomol.66.2.201-255>
    bibo:endPage "255" ;
    bibo:issue "2" ;
    bibo:journal "Beiträge Zur Entomologie = Contributions to Entomology" ;
    bibo:pubDate "2016-12-20" ;
    bibo:startPage "201" ;
    bibo:volume "66" ;
    dc:creator "Assing, Volker" ;
    dc:date "2016" ;
    dc:title "Revision of the Anaulacaspis species of the Palaearctic region (Coleoptera: Staphylinidae: Aleocharinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5884779>, <http://dx.doi.org/10.5281/zenodo.5212610>, <http://dx.doi.org/10.5281/zenodo.5884775>, <http://dx.doi.org/10.5281/zenodo.5884777>, <http://dx.doi.org/10.5281/zenodo.5212608> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.5884779>
    dc:description "Figs 211–232: Anaulacaspsis formosa (211), A. elegans (212–220), A. beesoni (221–228; 224–225: lectotype), and A. inexpectata (229–232; 231–232: holotype): habitus (211; photo by Marc Tronquet); male tergite VIII (212, 221); male sternite VIII (213, 222); median lobe of aedeagus in lateral and in ventral view (214–217, 224–227, 229–232); female tergite VIII (218); posterior margin of female tergite VIII (219); female sternite VIII (220, 228); postero-lateral portion of sternite VIII (223). Scale bars: 211: 1.0 mm; 212–218, 220–222, 224–232: 0.1 mm; 219, 223: 0.05 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/5884779/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.5212610>
    dc:description "Figs 1–12: Anaulacaspsis nigra. Maxilla (1); labium (2); labrum (3); male tergite VIII (4–9); male sternite VIII (10–12). Scale bars: 1–2, 4–12: 0.1 mm; 3: 0.05 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/5212610/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.5884775>
    dc:description "Figs 164–186: Anaulacaspsis iberica (164–166), A. nigrina (167–172), A. beijingensis (173–177), A. taiwanica (178–183), and A. gilva (184–186): male tergite VIII (164, 167, 173, 178, 184); male sternite VIII (165, 168, 174, 179, 185); female sternite VIII (166, 172, 177, 183); median lobe of aedeagus in lateral and in ventral view (169–171, 175–176, 180–181); female tergite VIII (182); spermatheca (186). Scale bars: 0.1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/5884775/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.5884777>
    dc:description "Figs 187–210: Anaulacaspsis gilva (187–190), A. pectinata (191–195), and A. formosa (196–210; 199–200: Tunisia; 201–203: Morocco; 204–205: holotype of A. macra; 206: Murcia; 207–208: Andalucía): median lobe of aedeagus in lateral and in ventral view (187–188, 194–195, 199–208); female tergite VIII (189); female sternite VIII (190, 209); male tergite VIII (191, 196); posterior margin of male tergite VIII (192, 197); male sternite VIII (193, 198); spermatheca (210). Scale bars: 187–191, 193–196, 198–210: 0.1 mm; 192, 197: 0.05 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/5884777/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.5212608>
    dc:description "Map 1: Distribution of Anaulacaspis in the Palaearctic region, based on revised records (all records pooled)." ;
    fabio:hasRepresentation "https://zenodo.org/record/5212608/files/figure.png" ;
    a fabio:Figure .

