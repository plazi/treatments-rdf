    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.280648>
    dc:description "FIGURE 5. Ctenosciara depressa sp. n. (A paratype, B, C holotype). A. Antennal flagellomere 4, lateral view. B. Part of hypopygium, ventral view. C. Gonostylus, ventral view. Scale 0.1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/280648/files/figure.png" ;
