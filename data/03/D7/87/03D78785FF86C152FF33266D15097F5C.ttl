    dc:title "Isotomidae (Collembola) of Buryat Republic. Folsomia culter sp. nov and taxonomic value of terminalian chaetotaxy in the genus" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.190205>, <http://dx.doi.org/10.5281/zenodo.190202>, <http://dx.doi.org/10.5281/zenodo.190203>, <http://dx.doi.org/10.5281/zenodo.190204> ;
