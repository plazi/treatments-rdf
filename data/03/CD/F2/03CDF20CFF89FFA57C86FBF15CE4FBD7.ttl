    dc:creator "Mahony, Stephen; Teeling, Emma C.; Biju, S. D." ;
    dc:title "Megophrys ancrae Mahony, Teeling & Biju, 2013, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Megophrys_ancrae_Mahony_2013> ;
