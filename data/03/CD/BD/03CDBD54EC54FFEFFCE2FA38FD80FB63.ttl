    dc:title "Hallodapus jingfui Yasunaga & Tamada & Hinami & Miyazaki & Duwal & Nagashima 2019, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03CDBD54EC54FFEFFCE2FA38FD80FB63.mc.3B0C061FEC54FFF7FC44F9F3FB3DF9C0> ;
