    dc:creator "Guinot, Danièle" ;
    dc:title "Paradorippinae Guinot 2023, n. subfam." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Paradorippinae_Guinot_2023> ;
