    dc:title "An endemic predaceous water beetle from the Murchison River in Western Australia — Antiporus kalbarriensis sp. n. (Coleoptera: Dytiscidae, Hydroporinae, Hydroporini)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.193248>, <http://dx.doi.org/10.5281/zenodo.193249>, <http://dx.doi.org/10.5281/zenodo.193250>, <http://dx.doi.org/10.5281/zenodo.193251> ;
