    dc:title "Beebeomyia tuxtlaensis Hernandez-Ortiz and Aguirre 2015, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03F887FCFFBEFF887D39FAFAFEA7FD92.mc.3B393CB7FFBEFF807CA5FA52FD9BF9FE>, <http://tb.plazi.org/GgServer/dwcaRecords/03F887FCFFBEFF887D39FAFAFEA7FD92.mc.3B393CB7FFBEFF807CA5F9AAFC76F976>, <http://tb.plazi.org/GgServer/dwcaRecords/03F887FCFFBEFF887D39FAFAFEA7FD92.mc.3B393CB7FFBEFF877F99F96AFB62F9D7>, <http://tb.plazi.org/GgServer/dwcaRecords/03F887FCFFBEFF887D39FAFAFEA7FD92.mc.3B393CB7FFB9FF877CE1F9ACFEB5F994>, <http://tb.plazi.org/GgServer/dwcaRecords/03F887FCFFBEFF887D39FAFAFEA7FD92.mc.3B393CB7FFB9FF877D52F98FFC5BF974> ;
