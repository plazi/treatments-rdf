    fabio:hasRepresentation "https://zenodo.org/record/4402954/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4402952>
    dc:description "FIGURE 2. Condylostylus friedmani sp. nov., male. A. Habitus. B. Head. C. Antenna. D. Fore femur and tibia. E. Wing. F. Hypopygium, right lateral view." ;
