    dc:creator "Gestinari, Lísia Mônica De Souza; Pereira, Sonia Maria Barreto; Yoneshigue-Valentin, Yocie" ;
    dc:date "2010" ;
    dc:title "Distribution of Cladophora Species (Cladophorales, Chlorophyta) along the Brazilian Coast" ;
