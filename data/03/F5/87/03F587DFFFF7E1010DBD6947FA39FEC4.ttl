    dc:title "Revision of the plant bug genus Diognetus, with descriptions of thirteen new species from the Oriental and Eastern Palearctic Regions (Hemiptera: Heteroptera: Miridae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7887423>, <http://dx.doi.org/10.5281/zenodo.7887425>, <http://dx.doi.org/10.5281/zenodo.7887439>, <http://dx.doi.org/10.5281/zenodo.7887441>, <http://dx.doi.org/10.5281/zenodo.7887445>, <http://dx.doi.org/10.5281/zenodo.7887451>, <http://dx.doi.org/10.5281/zenodo.7887497>, <http://dx.doi.org/10.5281/zenodo.7887503>, <http://dx.doi.org/10.5281/zenodo.7887453> ;
