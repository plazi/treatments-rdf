<http://dx.doi.org/10.14411/fp.2016.038>
    bibo:endPage "28" ;
    bibo:issue "38" ;
    bibo:journal "Folia Parasitologica" ;
    bibo:pubDate "2016-11-10" ;
    bibo:series "038" ;
