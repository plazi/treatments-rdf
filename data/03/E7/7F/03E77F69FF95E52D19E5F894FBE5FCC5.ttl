    dc:creator "Rivero-Blanco, Carlos; Schargel, Walter E." ;
    dc:title "Gonatodes rozei Rivero-Blanco & Schargel, 2012, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Gonatodes_rozei_Rivero-Blanco_2012> ;
