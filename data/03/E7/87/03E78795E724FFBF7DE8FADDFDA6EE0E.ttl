    dc:title "Liolaemus morandae Breitman, Parra, Pérez & Sites, 2011, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Liolaemus_morandae_Breitman_2011> ;
