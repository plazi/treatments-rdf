    dc:creator "Breitman, Maria Florencia; Parra, Micaela; Pérez, Cristian Hernán Fulvio; Sites, Jack Walter" ;
    dc:title "Liolaemus avilae Breitman, Parra, Pérez & Sites, 2011, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Liolaemus_avilae_Breitman_2011> ;
