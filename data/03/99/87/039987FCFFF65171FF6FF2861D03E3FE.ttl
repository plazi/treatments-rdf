    dc:title "Leptolalax firthi Rowley, Hoang, Dau, Le & Cao, 2012, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Leptolalax_firthi_Rowley_2012> ;
