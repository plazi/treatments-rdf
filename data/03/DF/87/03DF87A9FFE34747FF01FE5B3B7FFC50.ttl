    dc:title "Afronympha, a new genus of Entedoninae (Hymenoptera: Eulophidae) from the rainforests of Africa" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6280817>, <http://dx.doi.org/10.5281/zenodo.6280821>, <http://dx.doi.org/10.5281/zenodo.6280823> ;
