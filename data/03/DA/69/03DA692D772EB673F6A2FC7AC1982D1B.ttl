    dc:title "Contributions to some Corydiinae genera (Blattodea: Corydioidea: Corydiidae) from China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5174800>, <http://dx.doi.org/10.5281/zenodo.5174804> ;
