    dc:title "Rediscovery of the Endangered frog Phrynopus montium (Shreve, 1938) (Amphibia, Anura, Craugastoridae) in the cloud forest of central Peru" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1035701>, <http://dx.doi.org/10.5281/zenodo.1035703>, <http://dx.doi.org/10.5281/zenodo.1035705> ;
