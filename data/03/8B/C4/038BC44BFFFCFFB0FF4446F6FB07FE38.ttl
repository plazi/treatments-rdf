    dc:creator "Teynié, Alexandre; David, Patrick; Lottier, Anne; Le, Minh Duc; Vidal, Nicolas; Nguyen, Truong Quang" ;
    dc:title "Parafimbrios lao Teynié, David, Lottier, Le, Vidal & Nguyen, 2015, spec. nov." ;
