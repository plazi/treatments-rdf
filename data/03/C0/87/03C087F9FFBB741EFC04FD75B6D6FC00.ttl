    dc:creator "Bolick, Holly", "Carrera-Parra, Luis F.", "Harris, Leslie", "Paulay, Gustav", "Piotrowski, Christina N.", "Salazar-Vallejo, Sergio I." ;
    dc:date "2024" ;
    dc:title "Redescription of Iphione ovata Kinberg, 1856 and confirmation of its Indian Ocean-Eastern Pacific distribution (Annelida, Aphroditiformia, Iphionidae)" ;
    bibo:endPage "22" ;
    bibo:issue "1" ;
    bibo:journal "Zoosystema" ;
