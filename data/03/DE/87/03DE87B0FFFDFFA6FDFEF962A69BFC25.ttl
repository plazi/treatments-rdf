    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10559536>
    dc:description "Fig. 5. Hemisphaerius bresseeli sp. nov., dissected holotype, ♂ (RBINS). A. Habitus, dorsal view. B. Habitus, ventral view. C. Habitus, lateral view. D. Habitus, perpendicular view of frons. E. Right hind wing." ;
    fabio:hasRepresentation "https://zenodo.org/record/10559536/files/figure.png" ;
