    dc:creator "François Génier; Patrick Arnaud" ;
    dc:title "Dendropaemon (Dendropaemon) flechtmanni Genier & Arnaud, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Dendropaemon_flechtmanni_Genier_2016> ;
