    dc:title "The genus Diplommatina Benson, 1849 (Gastropoda: Caenogastropoda: Diplommatinidae) in Nepal, with the description of seven new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3832500>, <http://dx.doi.org/10.5281/zenodo.3832502>, <http://dx.doi.org/10.5281/zenodo.3832498>, <http://dx.doi.org/10.5281/zenodo.3832490>, <http://dx.doi.org/10.5281/zenodo.3832492>, <http://dx.doi.org/10.5281/zenodo.3832488>, <http://dx.doi.org/10.5281/zenodo.3832494> ;
