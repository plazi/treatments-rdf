    dc:title "Doryphoribius picoensis Fontoura, Pilato & Lisi, 2008, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Doryphoribius_picoensis_Fontoura_2008> ;
