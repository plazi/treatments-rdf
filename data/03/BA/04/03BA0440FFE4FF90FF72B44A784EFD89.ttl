    dc:date "2023" ;
    dc:title "Enterographa ducouretiana sp. nov. (lichenized Ascomycota, Roccellaceae), a new foliicolous species from New Caledonia" ;
    bibo:endPage "252" ;
    bibo:issue "3" ;
    bibo:journal "Phytotaxa" ;
