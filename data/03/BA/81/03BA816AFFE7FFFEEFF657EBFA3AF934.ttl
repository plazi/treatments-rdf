    dc:title "Identification of Haplothrips species from Malesia (Thysanoptera, Phlaeothripinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3253560>, <http://dx.doi.org/10.5281/zenodo.3253562> ;
