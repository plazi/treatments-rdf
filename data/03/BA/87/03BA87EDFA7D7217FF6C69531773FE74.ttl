    dc:title "A new species of direct-developing frog of the genus Eleutherodactylus (Anura: Eleutherodactylidae) from the Pacific lowlands of Guerrero, Mexico" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3707418>, <http://dx.doi.org/10.5281/zenodo.3707420>, <http://dx.doi.org/10.5281/zenodo.3707422> ;
