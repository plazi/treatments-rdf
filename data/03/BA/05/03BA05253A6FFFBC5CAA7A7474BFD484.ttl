    cito:cites <http://dx.doi.org/10.5281/zenodo.2610616> ;
    dc:creator "Rosso, A.; Beuck, L.; Vertino, A.; Sanfilippo, R.; Freiwald, A." ;
    dc:title "Cribrilaria saginata Rosso & Beuck & Vertino & Sanfilippo & Freiwald 2018, n. comb." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cribrilaria_saginata_Winston_2005> ;
