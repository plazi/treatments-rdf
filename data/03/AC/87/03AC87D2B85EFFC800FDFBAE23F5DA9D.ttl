    bibo:startPage "1" ;
    bibo:volume "30" ;
    dc:creator "Levkov, Zlatko; Williams, David M." ;
    dc:date "2011" ;
    dc:title "Fifteen new diatom (Bacillariophyta) species from Lake Ohrid, Macedonia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4894398>, <http://dx.doi.org/10.5281/zenodo.4894400> ;
