    dc:creator "Chapple, David G.; Bell, Trent P.; Chapple, Stephanie N. J.; Miller, Kimberly A.; Daugherty, Charles H.; Patterson, Geoff B." ;
    dc:title "Oligosoma tekakahu Chapple, Bell, Chapple, Miller, Daugherty & Patterson, 2011, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Oligosoma_tekakahu_Chapple_2011> ;
