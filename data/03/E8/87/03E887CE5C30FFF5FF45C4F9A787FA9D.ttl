    dc:creator "Schwéger, Szabina; Melika, George; Tang, Chang-Ti; Bihari, Péter; Bozsó, Miklós; Stone, Graham N.; Nicholls, James A.; Pénzes, Zsolt" ;
    dc:title "Synergus symbioticus Schweger & Melika, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Synergus_symbioticus_Schweger_2015> ;
