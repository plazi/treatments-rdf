    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.10728353>
    dc:description "Figure 1. Ameronothrus retweet sp. n. adults.(a) Male,dorsal view,legs omitted. (b) Male, ventral view, distal leg segments and gnathosoma omitted.(c) Female,dorsal view, legs omitted. (d) Female, ventral view, distal leg segments and gnathosoma omitted." ;
    fabio:hasRepresentation "https://zenodo.org/record/10728353/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10728356>
    dc:description "Figure 2. Photographs of male (upper row) and female (lower row) Ameronothrus retweet sp. n. specimens in dorsal (left side) and ventral view (right side)." ;
    fabio:hasRepresentation "https://zenodo.org/record/10728356/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10728359>
    dc:description "Figure 3. Ameronothrus retweet sp. n. mouthparts. (a) Right pedipalp, paraxial view. (b) Right rutellum ventral view. (c) Right chelicera, paraxial view." ;
    fabio:hasRepresentation "https://zenodo.org/record/10728359/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10728362>
    dc:description "Figure 4. Ameronothrus retweet sp. n. adult male left legs, antiaxial view. (a) Leg I. (b) Leg II. (c) Leg III. (d) Leg IV." ;
    fabio:hasRepresentation "https://zenodo.org/record/10728362/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10728364>
    dc:description "Figure 5. Ameronothrus retweet sp. n. reproductive organs. (a) Male, extruded spermatopositor in lateroposterior view. (b) Female, ovipositor, ventral view." ;
    fabio:hasRepresentation "https://zenodo.org/record/10728364/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10728366>
    dc:description "Figure 6. Bayesian inference tree of marine associated ameronothroid mites and selected terrestrial taxa based on 18S rRNA gene sequences. Bootstrap values (>50) and posterior probabilities (>0.9) are shown near nodes. Sequences generated in this study are marked by *, all others were taken from GenBank and are listed in Table 3. Abbreviations: PRT – Portugal, DEU – Germany." ;
    fabio:hasRepresentation "https://zenodo.org/record/10728366/files/figure.png" ;
    a fabio:Figure .

