    dc:date "2024" ;
    dc:title "Review of Microleon Butler, 1885 (Lepidoptera: Limacodidae) from Taiwan with description of a new species based on morphology and DNA barcoding" ;
    bibo:endPage "384" ;
    bibo:issue "3" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2024-01-22" ;
