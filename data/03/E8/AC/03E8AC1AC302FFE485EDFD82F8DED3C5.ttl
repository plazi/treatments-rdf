    dc:creator "Winterbottom, Richard" ;
    dc:date "2018" ;
    dc:title "A new species of Trimma (Pisces; Gobiidae) from the South-West Islands of Palau, western Pacific Ocean" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1143865>, <http://dx.doi.org/10.5281/zenodo.1143867>, <http://dx.doi.org/10.5281/zenodo.1143869>, <http://dx.doi.org/10.5281/zenodo.1143871>, <http://dx.doi.org/10.5281/zenodo.1143873>, <http://dx.doi.org/10.5281/zenodo.1143881>, <http://dx.doi.org/10.5281/zenodo.1143877>, <http://dx.doi.org/10.5281/zenodo.1143875>, <http://dx.doi.org/10.5281/zenodo.1143879> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.1143865>
    dc:description "FIGURE 1. Trimma hamartium, 18.4 mm SL female paratype, ROM 102747, Helen Reef, SW Islands, Palau.Left lateral (A) and dorsal(B) views of head papillae, specimen stained with cyanine blue. Papillaein a given row connected by dashed yellow lines.Photos by R.Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143865/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143867>
    dc:description "FIGURE 2. Trimma hamartium, 21.3 mm SL male, ROM 101394, Merir I., SW Islands, Palau. Left lateral view of freshly collected specimen. Photo by R.Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143867/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143869>
    dc:description "FIGURE3. Trimmahamartium, 19.2 mm SL male (holotype), ROM 83314, Helen Reef, SW Islands, Palau, leftlateral view of head and anterior body to show pigmentation. Photo by R.Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143869/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143871>
    dc:description "FIGURE 4. Comparison of pigmentation on top of the snout. A: T. hamartium, 19.2 mm SL male (holotype), ROM 83314, Helen Reef, SW Islands, Palau. B: T. preclarum, 20.8 mm SL female, ROM 83049, Merir I., SW Islands, Palau. Photos by R. Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143871/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143873>
    dc:description "FIGURE 5. Putative distributions of T. hamartium (black stars, orange boundary and fill) and T. preclarum (white stars in black circle, blue boundary and fill). Black diamonds represent localities where both species were collected. Image by R. Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143873/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143881>
    dc:description "FIGURE 9. Trimma preclarum, 18.3 mm SL male, ROM 95775, Cendrawasih Bay, Indonesia. Left lateral (A) and dorsal (B) views of head papillae, specimen stained with cyanine blue. Papillae rows connected by thin yellow lines. Photos by R. Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143881/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143877>
    dc:description "FIGURE 7. Left lateral views of freshly collected specimens of T. hamartium. A: ROM 46013 19.2 mm SL female, Great Astrolabe Reef, Fiji; B; ROM 101364, 23.0 mm SL male, Niue; C: ROM 101382, 20.3 mm SL male, Pulau Pegun, Indonesia. Photos:A by R. Winterbottom, B & C by M.V.Erdmann." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143877/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143875>
    dc:description "FIGURE 6. Neighbour Joining network derived from a BOL analysis of the CO1 gene of the Trimma preclarum haplogroups. Image by R. Winterbottom." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143875/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1143879>
    dc:description "FIGURE 8. Left lateral views of live and freshly collected specimens of Trimma preclarum. A: 19.2 mm SL male, ROM 80020, Kayangel Atoll, Palau; B: 19.2 mm SL male, ROM 83023, Pulo Anna, SW Islands, Palau; C: ROM 95775, Cendrawasih Bay, Indonesia. A & B: left lateral views of freshly collected specimens, photos by R. Winterbottom. C: left lateral view (rotated) of live specimen, photo by M.V.Erdmann." ;
    fabio:hasRepresentation "https://zenodo.org/record/1143879/files/figure.png" ;
    a fabio:Figure .

