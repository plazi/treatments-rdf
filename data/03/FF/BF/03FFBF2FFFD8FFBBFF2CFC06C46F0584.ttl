    dc:title "New species and new records of Mesoceration Janssens, 1967 from South Africa (Coleoptera, Hydraenidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.243045>, <http://dx.doi.org/10.5281/zenodo.243046>, <http://dx.doi.org/10.5281/zenodo.243048> ;
