    dc:creator "Dorchin, Netta; Freidberg, Amnon" ;
    dc:title "Houardiella gracilis Dorchin and Freidberg, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Houardiella_gracilis_Freidberg_2008> ;
