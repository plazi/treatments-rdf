    dc:creator "Pollock, Darren" ;
    dc:title "Eustrophus tomentosus Say. The Canadian 1826" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Eustrophus_tomentosus_Canadian_1826> ;
