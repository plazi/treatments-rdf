    dc:title "Cephennium infractum Assing & Meybohm 2021, spec. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03FA8790C8485748B334F9F13BB11721.mc.3B3B3CDBC8485740B453F96B3DFD1461> ;
