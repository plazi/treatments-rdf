    cito:cites <http://dx.doi.org/10.5281/zenodo.223135>, <http://dx.doi.org/10.5281/zenodo.223136> ;
    dc:creator "Maruyama, Munetoshi; Kamezawa, Hiromu" ;
    dc:title "Adinopsis nippon Maruyama & Kamezawa, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Adinopsis_nippon_Maruyama_2013> ;
