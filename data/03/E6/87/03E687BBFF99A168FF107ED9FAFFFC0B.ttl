    cito:cites <http://dx.doi.org/10.5281/zenodo.193200>, <http://dx.doi.org/10.5281/zenodo.193199>, <http://dx.doi.org/10.5281/zenodo.193201> ;
    dc:creator "Shi, Lei; Zhao, Hui" ;
    dc:title "Cyrtodactylus zhaoermii Shi & Zhao, 2010, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cyrtodactylus_zhaoermii_Shi_2010> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.193197> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.193197>
    bibo:endPage "60" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "51" ;
    bibo:volume "2336" ;
    dc:creator "Shi, Lei; Zhao, Hui" ;
    dc:date "2010" ;
    dc:title "A new species of Cyrtodactylus (Reptilia: Squamata: Geckkonidae) from Xizang Autonomous Region, China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.193200>, <http://dx.doi.org/10.5281/zenodo.193199>, <http://dx.doi.org/10.5281/zenodo.193201> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.193200>
    dc:description "FIGURE 3. Illustration of holotype features. (A) Ventral view of head showing contact of postmentals. (B) Palmar surface of right pes showing differential size between proximal and distal subdigital lamellae. (C) Tail base showing distinct segments and large, backwardly directed tubercles in whorls." ;
    fabio:hasRepresentation "https://zenodo.org/record/193200/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.193199>
    dc:description "FIGURE 2. Pre-cloacal region of the holotype showing the 4 precloacal pores and series slightly enlarged femoral scales lacking pores." ;
    fabio:hasRepresentation "https://zenodo.org/record/193199/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.193201>
    dc:description "FIGURE 4. Map of middle and lower reaches of Yarlung Tsangpo River in Xizang Autonomous Region showing the type locality of Cyrtopodactylus zhaoermii and collection localities of other three Cyrtopodactylus species recorded in Xizang Autonomous Region." ;
    fabio:hasRepresentation "https://zenodo.org/record/193201/files/figure.png" ;
    a fabio:Figure .

