    dc:creator "Shear, William A.; Leonard, William P." ;
    dc:date "2003" ;
    dc:title "Microlympiidae, a new milliped family from North America, and Microlympia echina, new genus and species (Diplopoda: Chordeumatida: Brannerioidea)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.168732>, <http://dx.doi.org/10.5281/zenodo.156686>, <http://dx.doi.org/10.5281/zenodo.156687> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.168732>
    dc:description "FIGURES 1 ­ 2. Microlympia echina, n. sp., male. 1, photomicrograph, lateral view of anterior end. 2, line drawing based on Fig. 1, to emphasize features such as reduced telopodites of legpair 11. Scale line = 0. 35 mm (350 µ)." ;
    fabio:hasRepresentation "https://zenodo.org/record/168732/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.156686>
    dc:description "FIGURES 3 ­ 11. Right legs of Microlympia echina, n. sp., posterior views. 3, leg 1. 4, leg 2. 5, leg 3. 6, leg 4. 7, leg 5. 8, leg 6. 9, leg 7. 10, leg 10. 11, leg 11. All scale lines = 0.1 mm (100 þµ)" ;
    fabio:hasRepresentation "https://zenodo.org/record/156686/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.156687>
    dc:description "FIGURES 12 ­ 16. Microlympia echina, n. sp. 12, gonopods, anterior view. 13, gonopods, posterior view. 14, male ninth legpair, anterior view. 15, male tenth coxosternum, anterior view. 16, cyphopods, ventral view. All scale lines = 0.1 mm (100 µ)." ;
    fabio:hasRepresentation "https://zenodo.org/record/156687/files/figure.png" ;
    a fabio:Figure .

