    dc:date "2011" ;
    dc:title "A new species of Leptolalax (Anura: Megophryidae) from southern Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.277017>, <http://dx.doi.org/10.5281/zenodo.277019>, <http://dx.doi.org/10.5281/zenodo.277021>, <http://dx.doi.org/10.5281/zenodo.277020> ;
