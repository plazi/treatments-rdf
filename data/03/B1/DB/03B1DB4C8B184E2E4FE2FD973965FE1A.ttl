    dc:title "Landouria schepmani Nurinsiyah & Neiber & Hausdorf 2019, comb. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03B1DB4C8B184E2E4FE2FD973965FE1A.mc.3B7060078B184E2C4EDFFBA73EFDFB60>, <http://tb.plazi.org/GgServer/dwcaRecords/03B1DB4C8B184E2E4FE2FD973965FE1A.mc.3B7060078B184E2C4E88FAFA3F98FAFB> ;
