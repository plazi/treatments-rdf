    dc:title "A new species of Kana Distant representing the first record of Evacanthinae (Hemiptera: Cicadellidae) from Madagascar" ;
    bibo:endPage "134" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
