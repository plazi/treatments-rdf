    dc:creator "Lehnert, Helmut; Stone, Robert; Heimler, Wolfgang" ;
    dc:title "Plakina tanaga Lehnert, Stone & Heimler, 2005, n.sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Plakina_tanaga_Lehnert_2005> ;
