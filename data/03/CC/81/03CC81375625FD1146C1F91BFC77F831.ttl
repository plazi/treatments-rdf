    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8200306>
    dc:description "FIG. 4. — Comparison of the titillators of the two geographically close species: A, Roeseliana epirotica n. sp. ♂; B, Roeseliana ambitiosa (Uvarov, 1924) ♂." ;
