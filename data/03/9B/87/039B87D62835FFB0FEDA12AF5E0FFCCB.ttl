    dc:creator "Bruce, A. J.; Davie, P. J. F." ;
    dc:date "2006" ;
    dc:title "A new anchialine shrimp of the genus Procaris from Christmas Island: the first occurrence of the Procarididae in the Indian Ocean (Crustacea: Decapoda: Caridea)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.172829>, <http://dx.doi.org/10.5281/zenodo.172830>, <http://dx.doi.org/10.5281/zenodo.172831> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.172829>
    dc:description "FIGURE 1 Procaris noelensis sp. nov., holotype, Christmas Island. Scale bar in millimeters." ;
    fabio:hasRepresentation "https://zenodo.org/record/172829/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.172830>
    dc:description "FIGURE 2 Procaris noelensis sp. nov., holotype, Christmas Island. Anterior carapace and appendages, lateral. B, same, dorsal. C, eye, upper, dorsal; lower, lateral. D, antennule. E, antenna." ;
    fabio:hasRepresentation "https://zenodo.org/record/172830/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.172831>
    dc:description "FIGURE 3 Procaris noelensis sp. nov., holotype, Christmas Island. A, scaphocerite. B, same, distlateral angle. C, third maxilliped, ischium, distal edge to left. D, same, cutting edge. E, third pereiopod (?), propod and dactyl. F, uropods. G, same, posterolateral exopod." ;
    fabio:hasRepresentation "https://zenodo.org/record/172831/files/figure.png" ;
    a fabio:Figure .

