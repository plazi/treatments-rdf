    dc:creator "Aria, Cédric; Perrichot, Vincent; Nel, André" ;
    dc:date "2011" ;
    dc:title "Fossil Ponerinae (Hymenoptera: Formicidae) in Early Eocene amber of France" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.206041>, <http://dx.doi.org/10.5281/zenodo.206043> ;
