    dc:title "Ceuthomantis smaragdinus Heinicke, Duellman, Trueb, Means, D & Hedges, 2009, new species" ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Ceuthomantis_smaragdinus>, <http://taxon-name.plazi.org/id/Animalia/Ceuthomantis>, <http://taxon-name.plazi.org/id/Animalia/Pristimantis_aracamuni>, <http://taxon-name.plazi.org/id/Animalia/Pristimantis_cavernibardus>, <http://taxon-name.plazi.org/id/Animalia/Pristimantis>, <http://taxon-name.plazi.org/id/Animalia/Pristimantis_memorans>, <http://taxon-name.plazi.org/id/Animalia/Ceuthomantis_cavernibardus>, <http://taxon-name.plazi.org/id/Animalia/Ischnocnema_guentheri>, <http://taxon-name.plazi.org/id/Animalia/Brachycephalidae>, <http://taxon-name.plazi.org/id/Animalia/Haddadus_binotatus>, <http://taxon-name.plazi.org/id/Animalia/Craugastoridae>, <http://taxon-name.plazi.org/id/Animalia/Eleutherodactylus_gossei>, <http://taxon-name.plazi.org/id/Animalia/Eleutherodactylidae>, <http://taxon-name.plazi.org/id/Animalia/Pristimantis_pulvinatus>, <http://taxon-name.plazi.org/id/Animalia/Strabomantidae> ;
