    cito:cites <http://taxon-concept.plazi.org/id/Animalia/Paracercopis_seminigra_Melichar_1902>, <http://dx.doi.org/10.5281/zenodo.8058776>, <http://dx.doi.org/10.5281/zenodo.8058787>, <http://dx.doi.org/10.5281/zenodo.8058783>, <http://dx.doi.org/10.5281/zenodo.8058778> ;
    dc:creator "Liang, Ai-Ping; Zhang, Pei-Yi; Zhu, Xiao-Qing; Wang, Ye-Qing; Xiao, Neng-Wen" ;
    dc:title "Paracercopis Schmidt 1925" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Paracercopis_Schmidt_1925> ;
    trt:deprecates <http://taxon-concept.plazi.org/id/Animalia/Paracercopoides_Liang_1994>, <http://taxon-concept.plazi.org/id/Animalia/Eoscarta_Breddin_1902> ;
