    dc:description "FIGURE 5. Nivcentia pinicolus (female); A) habitus, dorsal view; B) same, lateral view; C) head, frontal view; D) head and thorax, dorsal view; E) labels." ;
    fabio:hasRepresentation "https://zenodo.org/record/10603235/files/figure.png" ;
