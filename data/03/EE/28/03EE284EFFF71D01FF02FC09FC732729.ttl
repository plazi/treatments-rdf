    dc:creator "Fjellberg, Arne" ;
    dc:title "Paraxenylla norvegica Fjellberg, 2010, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Paraxenylla_norvegica_Fjellberg_2010> ;
