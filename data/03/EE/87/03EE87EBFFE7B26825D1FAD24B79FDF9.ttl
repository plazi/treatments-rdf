    dc:creator "Londt, Jason G. H." ;
    dc:title "Afromelittodes mimos Londt 2003, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Afromelittodes_mimos_Londt_2003> ;
