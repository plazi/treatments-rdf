    dc:title "A new species-group with new species of the genus Lasioseius (Acari: Mesostigmata: Blattisociidae) associated with Neotropical hispine beetles in furled leaves ofHeliconia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4487539>, <http://dx.doi.org/10.5281/zenodo.4487541>, <http://dx.doi.org/10.5281/zenodo.4487561>, <http://dx.doi.org/10.5281/zenodo.4487563>, <http://dx.doi.org/10.5281/zenodo.4487565>, <http://dx.doi.org/10.5281/zenodo.4487567> ;
