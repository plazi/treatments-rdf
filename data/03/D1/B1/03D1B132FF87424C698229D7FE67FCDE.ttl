    dc:title "Microsaurus Dejean 1833" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03D1B132FF87424C698229D7FE67FCDE.mc.3B100A79FF88424C6A732A3EFE7FFD00> ;
