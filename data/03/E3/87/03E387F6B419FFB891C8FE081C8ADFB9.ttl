    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.195343>
    dc:description "FIGURES 62 – 69. Hatschekia churaumi n. sp., female, holotype NSMT – Cr 20907. 62, habitus dorsal; 63, posterior part of trunk, dorsal; 64, antennule, ventral, rp = rostrum process; 65, antenna, ventral; 66, antenna with parabasal papilla; 67, mandible; 68, maxillule; 69, maxilla. Scale bars: 62, 65 – 66, 100 μm; 63 – 64, 68 – 69, 20 μm; 67, 10 μm." ;
    fabio:hasRepresentation "https://zenodo.org/record/195343/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.195344>
    dc:description "FIGURES 70 – 75. Hatschekia churaumi n. sp., female, holotype NSMT – Cr 20907. 70, leg 1, anterior view; 71, leg 2, anterior view; 72, intercoxal sclerite of leg 1, anterior view; 73, intercoxal sclerite of leg 2, anterior view; 74, leg 3; 75, leg 4. Scale bars: 70 – 73, 20 μm; 74 – 75, 10 μm." ;
    fabio:hasRepresentation "https://zenodo.org/record/195344/files/figure.png" ;
    a fabio:Figure .

