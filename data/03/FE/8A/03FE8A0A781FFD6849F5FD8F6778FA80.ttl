    dc:creator "Orci, Kirill Márk; Szövényi, Gergely; Nagy, Barnabás" ;
    dc:title "Isophya sicula Orci, Szovenyi & Nagy, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Isophya_sicula_Orci_2010> ;
