    dc:creator "Lee, Sangmi; Brown, Richard L." ;
    dc:date "2008" ;
    dc:title "Revision of Holarctic Teleiodini (Lepidoptera: Gelechiidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.182960>, <http://dx.doi.org/10.5281/zenodo.182950>, <http://dx.doi.org/10.5281/zenodo.182954> ;
