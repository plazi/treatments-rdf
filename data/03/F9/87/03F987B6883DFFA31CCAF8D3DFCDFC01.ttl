    dc:title "Taxonomy of the subgenus Pseudocypus Mulsant & Rey (Coleoptera: Staphylinidae: Staphylinini) and eight new species from China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1037683>, <http://dx.doi.org/10.5281/zenodo.1037691>, <http://dx.doi.org/10.5281/zenodo.1037685> ;
