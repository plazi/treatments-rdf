    dc:title "Six new species of Aleuromarginatus Corbett, 1935 and Paramarginatus sarawakensis Dubey gen. and sp. nov. (Hemiptera: Aleyrodidae) from Southeast Asia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6000791>, <http://dx.doi.org/10.5281/zenodo.6000801>, <http://dx.doi.org/10.5281/zenodo.6000819>, <http://dx.doi.org/10.5281/zenodo.6000805>, <http://dx.doi.org/10.5281/zenodo.6000823>, <http://dx.doi.org/10.5281/zenodo.6000777>, <http://dx.doi.org/10.5281/zenodo.6000779>, <http://dx.doi.org/10.5281/zenodo.6000785>, <http://dx.doi.org/10.5281/zenodo.6000817> ;
