    dc:title "Capnia Pictet 1841, sensu lato" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03F99336FF07FFFD1BE45BD4D188FAA5.mc.3B38287DFF07FFE01BB458A5D059FBFE> ;
