    dc:date "2015" ;
    dc:title "A new species of Camellocossus Yakovlev, 2011 (Lepidoptera: Cossidae) from Southern Oman" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.243782>, <http://dx.doi.org/10.5281/zenodo.243783> ;
