    dc:creator "Neubert, Eike", "Subai, Peter" ;
    dc:date "2014" ;
    dc:title "Revision of the genus Lindholmiola HESSE, 1931 (Gastropoda: Pulmonata: Helicodontidae)" ;
    bibo:endPage "94" ;
    bibo:journal "Contributions to Natural History" ;
    bibo:pubDate "2014-04-03" ;
    bibo:startPage "1" ;
    bibo:volume "23" ;
