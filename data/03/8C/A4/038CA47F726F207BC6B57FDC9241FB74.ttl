    dc:title "Taxonomic revision of Orcevia Thorell, 1890, with description of fifteen new species (Araneae, Salticidae, Euophryini)" ;
    bibo:endPage "79" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
