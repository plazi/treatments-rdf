    cito:cites <http://dx.doi.org/10.5281/zenodo.172956>, <http://dx.doi.org/10.5281/zenodo.172957>, <http://dx.doi.org/10.5281/zenodo.172958> ;
    dc:creator "Kraus, Fred; Allison, Allen" ;
    dc:title "Cyrtodactylus murua Kraus & Allison, 2006, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cyrtodactylus_murua_Kraus_2006> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.172955> ;
