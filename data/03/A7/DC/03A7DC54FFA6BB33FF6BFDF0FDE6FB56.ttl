    dc:creator "Macgowan, Iain" ;
    dc:date "2017" ;
    dc:title "A new genus and species within the tribe Earomyiini (Diptera, Lonchaeidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.231765>, <http://dx.doi.org/10.5281/zenodo.231766>, <http://dx.doi.org/10.5281/zenodo.231769>, <http://dx.doi.org/10.5281/zenodo.231767> ;
