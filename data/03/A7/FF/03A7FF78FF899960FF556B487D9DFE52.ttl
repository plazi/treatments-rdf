    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.571031>
    dc:description "FIGURE 4. Habitat of Tropidophorus sebi sp. nov. at Putai, Upper Sungei Baleh, Sarawak, Malaysia (Borneo)." ;
    fabio:hasRepresentation "https://zenodo.org/record/571031/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.571032>
    dc:description "FIGURE 5. Concatenated ML phylogram of the mitochondrial 12 s and 16 s genes for Tropidophorus and close relatives with ML bootstraps (left number) and BI posterior probabilities (right number) shown at the nodes. Nodes with ML bootstrap ± 70 and BI posterior probability ± 0.95 are denoted with a black dot. The new species is indicated in bold." ;
    fabio:hasRepresentation "https://zenodo.org/record/571032/files/figure.png" ;
    a fabio:Figure .

