    dc:date "2021" ;
    dc:title "Untargeted metabolite profiling of petal blight in field-grown Rhododendron agastum using GC-TOF-MS and UHPLC-QTOF-MS / MS" ;
    bibo:endPage "12" ;
    bibo:journal "Phytochemistry" ;
