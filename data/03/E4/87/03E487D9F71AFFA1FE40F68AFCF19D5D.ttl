    cito:cites <http://dx.doi.org/10.5281/zenodo.10498718>, <http://dx.doi.org/10.5281/zenodo.10498722>, <http://dx.doi.org/10.5281/zenodo.10498724>, <http://dx.doi.org/10.5281/zenodo.10498720> ;
    dc:creator "Santos-Silva, Antonio; Nascimento, Francisco Eriberto de L.; Botero, Juan Pablo" ;
    dc:title "Oemini Lacordaire 1868" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Oemini_Lacordaire_1868> ;
    trt:publishedIn <http://dx.doi.org/10.1080/00222933.2023.2272347> ;
    a trt:Treatment .

<http://dx.doi.org/10.1080/00222933.2023.2272347>
    bibo:endPage "1948" ;
    bibo:issue "41 - 44" ;
    bibo:journal "Journal of Natural History" ;
    bibo:pubDate "2023-11-30" ;
    bibo:startPage "1917" ;
    bibo:volume "57" ;
    dc:creator "Santos-Silva, Antonio; Nascimento, Francisco Eriberto de L.; Botero, Juan Pablo" ;
    dc:date "2023" ;
    dc:title "Taxonomy of Oemini (Coleoptera: Cerambycidae: Cerambycinae), with key to American genera, notes and new taxa" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.10498718>, <http://dx.doi.org/10.5281/zenodo.10498722>, <http://dx.doi.org/10.5281/zenodo.10498724>, <http://dx.doi.org/10.5281/zenodo.10498720> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.10498718>
    dc:description "Figures 1–4. (1–2) Vandykea tuberculata Linsley, 1932, female from Butts Canyon, California, USA: (1) dorsal habitus; (2) head, lateral view. (3–4) Eudistenia costipennis Fall, 1907, male from San Antonio, California, USA: (3) head, lateral view; (4) dorsal habitus." ;
    fabio:hasRepresentation "https://zenodo.org/record/10498718/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10498722>
    dc:description "Figures 9–15. (9–10) Sepaicutea fisheri Lane, 1972, female: (9) dorsal habitus; (10) ventral habitus. (11–15) Liberedaxia deslauriersi Alten, Alten and Ramey, 2009, holotype male (by Eugenio H. Nearns): (11) dorsal habitus; (12) ventral habitus; (13) lateral habitus; (14) head, frontal view; (15) thorax, ventral habitus." ;
    fabio:hasRepresentation "https://zenodo.org/record/10498722/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10498724>
    dc:description "Figures 16–23. Biraoeme unicolour (Martins, 1981). (16–21) Male: (16) dorsal habitus; (17) ventral habitus; (18) lateral habitus; (19) head, frontal view; (20) upper eye lobes; (21) prosternal and mesoventral processes. (22–23) Female: (22) upper eye lobes; 23) dorsal habitus." ;
    fabio:hasRepresentation "https://zenodo.org/record/10498724/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10498720>
    dc:description "Figures 5–8. (5–6) Aponoeme castanea Martins and Galileo, 1997, holotype male: (5) dorsal habitus; (6) upper eye lobes. (7–8) Aponoeme amazonica Martins, 1985, holotype male: (7) upper eye lobes; (8) dorsal habitus." ;
    fabio:hasRepresentation "https://zenodo.org/record/10498720/files/figure.png" ;
    a fabio:Figure .

