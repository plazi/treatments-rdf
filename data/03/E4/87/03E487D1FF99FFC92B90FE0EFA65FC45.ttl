    dc:title "The Campsicnemus popeye species group (Diptera: Dolichopodidae) from French Polynesia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.223044>, <http://dx.doi.org/10.5281/zenodo.223045>, <http://dx.doi.org/10.5281/zenodo.223046> ;
