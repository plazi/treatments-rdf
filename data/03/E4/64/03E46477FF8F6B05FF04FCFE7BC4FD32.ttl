    dc:date "2023" ;
    dc:title "Redescription of Leptoconops (Leptoconops) brasiliensis (Lutz) and Leptoconops (Megaconops) floridensis Wirth (Diptera: Ceratopogonidae) with its first Brazilian record" ;
    bibo:endPage "183" ;
    bibo:issue "2" ;
