    dc:creator "Riaux-Gobin, Catherine; Garcia, Marinês; Witkowski, Andrzej; Saenz-Agudelo, Pablo; Coste, Michel; Daniszewska-Kowalczyk, Genowefa" ;
    dc:title "Amphicocconeis antiqua Riaux-Gobin & Garcia & Witkowski & Saenz-Agudelo & Coste & Daniszewska-Kowalczyk 2021, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03E42F1FFF9DFF9D43EDFBC8EA0DF9F9.mc.3B259454FF80FF9C43D8F850EEB0F847> ;
