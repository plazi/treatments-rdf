    dc:creator "Zonstein, Sergei L.; Marusik, Yuri M.; Koponen, Seppo" ;
    dc:title "Zaitunia afghana Roewer 1962, comb. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Zaitunia_afghana_Roewer_1962> ;
