    dc:creator "Megna, Yoandri S.; Epler, John H." ;
    dc:title "Copelatus : GUEORGUIEV 1968" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Copelatus_GUEORGUIEV_1968> ;
