    dc:title "Description of a new leafhopper species of the genus Sophonia Walker (Hemiptera: Cicadellidae: Evacanthinae) from China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.10603564>, <http://dx.doi.org/10.5281/zenodo.10603568>, <http://dx.doi.org/10.5281/zenodo.10603570> ;
