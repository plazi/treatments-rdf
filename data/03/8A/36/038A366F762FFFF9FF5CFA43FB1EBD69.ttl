    dc:creator "Kohlmann, Bert; Arriaga-Jiménez, Alfonsina; Rös, Matthias" ;
    dc:date "2018" ;
    dc:title "An unusual new species of Canthidium (Coleoptera: Scarabaeidae: Scarabaeinae) from Oaxaca, Mexico" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1169535>, <http://dx.doi.org/10.5281/zenodo.1169537>, <http://dx.doi.org/10.5281/zenodo.1169539> ;
