    dc:title "A key to species of Hercinothrips, with one new species, and a neotype designation for H. trilineatus (Priesner)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6952458>, <http://dx.doi.org/10.5281/zenodo.6952448>, <http://dx.doi.org/10.5281/zenodo.6952450> ;
