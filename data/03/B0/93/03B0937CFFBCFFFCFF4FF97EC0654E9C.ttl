    dc:creator "Mccranie, James R.; Vieites, David R.; Wake, David B." ;
    dc:title "Oedipina quadra Mccranie, Vieites & Wake, 2008, sp. nov." ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Oedipina_cyclocauda> ;
