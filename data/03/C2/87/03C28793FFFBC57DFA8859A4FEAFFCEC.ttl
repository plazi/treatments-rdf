    dc:date "2023" ;
    dc:title "Redescription and neotype designation of Suphis fluviatilis Guignot, 1948 (Coleoptera: Dytiscoidea: Noteridae) and notes on other species of the genus" ;
    bibo:endPage "147" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
