    dc:title "New Carlia fusca complex lizards (Reptilia: Squamata: Scincidae) from New Guinea, Papua­Indonesia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.172811>, <http://dx.doi.org/10.5281/zenodo.172815>, <http://dx.doi.org/10.5281/zenodo.172812> ;
