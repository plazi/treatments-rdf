    dc:creator "Berchi, Gavril Marius" ;
    dc:title "Notonecta (Notonecta) maculata Fabricius 1794" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Notonecta_maculata_Fabricius_1794> ;
