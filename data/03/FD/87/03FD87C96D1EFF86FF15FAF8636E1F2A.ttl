    dc:creator "Berchi, Gavril Marius" ;
    dc:title "Notonecta (Notonecta) viridis Delcourt 1909" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Notonecta_viridis_Delcourt_1909> ;
