    dc:title "Revision of Brazilian species of Aleochara Gravenhorst of the subgenus Xenochara Mulsant & Rey (Coleoptera: Staphylinidae: Aleocharinae)" ;
    bibo:endPage "534" ;
    bibo:issue "4" ;
