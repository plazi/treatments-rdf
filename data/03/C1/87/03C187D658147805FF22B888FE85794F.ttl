    dc:title "A new species of the genus Calotes (Squamata: Agamidae) from high elevations of the Knuckles Massif of Sri Lanka" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.285824>, <http://dx.doi.org/10.5281/zenodo.285818>, <http://dx.doi.org/10.5281/zenodo.285820>, <http://dx.doi.org/10.5281/zenodo.285821> ;
