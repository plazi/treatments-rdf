    dc:date "2009" ;
    dc:title "Three new genera of the mite family Eviphididae (Acari: Mesostigmata)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.185875>, <http://dx.doi.org/10.5281/zenodo.185879>, <http://dx.doi.org/10.5281/zenodo.185876> ;
