    dc:title "Pamphagidae (Orthoptera: Caelifera) of North Africa: key to genera and the annotated check-list of species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.249383>, <http://dx.doi.org/10.5281/zenodo.249384>, <http://dx.doi.org/10.5281/zenodo.249385> ;
