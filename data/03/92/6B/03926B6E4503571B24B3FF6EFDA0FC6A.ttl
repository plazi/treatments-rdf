    cito:cites <http://dx.doi.org/10.5281/zenodo.5281168>, <http://dx.doi.org/10.5281/zenodo.5281178>, <http://dx.doi.org/10.5281/zenodo.5777404> ;
    dc:creator "Puthz, Volker" ;
    dc:title "Dianous caeruleolimbatus Puthz 2016, nov.sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Dianous_caeruleolimbatus_Puthz_2016> ;
