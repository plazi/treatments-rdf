    dc:creator "Puthz, Volker" ;
    dc:title "Dianous falsificatus Puthz 2016, nov.sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Dianous_falsificatus_Puthz_2016> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.5281158> ;
