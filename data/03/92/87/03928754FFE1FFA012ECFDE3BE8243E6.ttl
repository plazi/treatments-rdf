    cito:cites <http://dx.doi.org/10.5281/zenodo.206650>, <http://dx.doi.org/10.5281/zenodo.206651>, <http://dx.doi.org/10.5281/zenodo.206652>, <http://dx.doi.org/10.5281/zenodo.206654> ;
    dc:creator "Framenau, Volker W." ;
    dc:title "Novaranea courti Framenau, 2011, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Novaranea_courti_Framenau_2011> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.206649> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.206649>
    bibo:endPage "55" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "47" ;
    bibo:volume "2793" ;
    dc:creator "Framenau, Volker W." ;
    dc:date "2011" ;
    dc:title "Description of a new orb-weaving spider species representing the first record of Novaranea in Australia (Araneae: Araneidae: Araneinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.206650>, <http://dx.doi.org/10.5281/zenodo.206651>, <http://dx.doi.org/10.5281/zenodo.206652>, <http://dx.doi.org/10.5281/zenodo.206654> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.206650>
    dc:description "FIGURE 1. Holotype male of Novaranea courti n. sp. from Fergies Paddock, Tasmania (QM S 83467) (in ca. 70 % EtOH). A, dorsal view; B, ventral view; C, left pedipalp, ventral view, D, left pedipalp, dorsal view; E, left pedipalp, basal view to illustrate shape of median apophysis. Scale bars: A – B, 1.0 mm, C – E, 0.5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/206650/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.206651>
    dc:description "FIGURE 2. Females of Novaranea courti n. sp. A, paratype female from the Otway Ranges, Victoria (NMV K 9859) (in ca. 70 % EtOH), dorsal view; B, ventral view. C, female from Cradle Mountain, Tasmania (ZMUC) (in ca. 100 % EtOH), dorsal view; D, ventral view. E, female from Nelson Falls, Tasmania (ZMUC) (in ca. 100 % EtOH), dorsal view. Scale bars: A – E, 2.0 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/206651/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.206652>
    dc:description "FIGURE 3. Females of Novaranea courti n. sp. A, epigynum of female from Cradle Mountain, Tasmania (ZMUC), ventral view. B – D, epigynum of paratype female from the Otway Ranges, Victoria (NMV K- 9859); B, lateral view; C, posterior view; D, dorsal view. Scale bars: A – E, 2.0 mm, F – G, 25 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/206652/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.206654>
    dc:description "FIGURE 4. Distribution records of Novaranea courti n. sp. in Australia." ;
    fabio:hasRepresentation "https://zenodo.org/record/206654/files/figure.png" ;
    a fabio:Figure .

