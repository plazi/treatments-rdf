    cito:cites <http://dx.doi.org/10.5281/zenodo.375725>, <http://dx.doi.org/10.5281/zenodo.375729> ;
    dc:creator "Sonali Garg; Robin Suyesh; Sandeep Sukesan; Sd Biju" ;
    dc:title "Nyctibatrachus pulivijayani Garg, Suyesh, Sukesan & Biju, 2017, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Nyctibatrachus_pulivijayani_Garg_2017> ;
