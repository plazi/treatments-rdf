    dc:title "Five new ocellus-bearing species of the cusk-eel genus Neobythites (Ophidiidae, Ophidiiformes) from the West Pacific, with establishment of three new species groups" ;
    bibo:endPage "205" ;
    bibo:issue "2" ;
