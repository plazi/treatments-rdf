    cito:cites <http://dx.doi.org/10.5281/zenodo.252219>, <http://dx.doi.org/10.5281/zenodo.252228>, <http://dx.doi.org/10.5281/zenodo.252231>, <http://dx.doi.org/10.5281/zenodo.252226>, <http://dx.doi.org/10.5281/zenodo.252236> ;
    dc:creator "Makarkin, Vladimir N.; Archibald, S. Bruce" ;
    dc:title "Raphidiidae Latreille 1810, gen. nov." ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Raphidiidae_Latreille_1810> ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.3784.4.4> ;
    a trt:Treatment .

<http://dx.doi.org/10.11646/zootaxa.3784.4.4>
    bibo:endPage "444" ;
    bibo:issue "4" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "401" ;
    bibo:volume "3784" ;
    dc:creator "Makarkin, Vladimir N.; Archibald, S. Bruce" ;
    dc:date "2014" ;
    dc:title "A revision of the late Eocene snakeflies (Raphidioptera) of the Florissant Formation, Colorado, with special reference to the wing venation of the Raphidiomorpha" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.252219>, <http://dx.doi.org/10.5281/zenodo.252228>, <http://dx.doi.org/10.5281/zenodo.252231>, <http://dx.doi.org/10.5281/zenodo.252226>, <http://dx.doi.org/10.5281/zenodo.252236> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.252219>
    dc:description "FIGURE 1. Wing venation of the Jurassic Mesoraphidiidae. A, Mesoraphidia inaequalis Martynov, 1925 (Late Jurassic of Karatau, Kazakhstan), forewing. B, same, hind wing. Re-drawn with slight simplification from Martynov 1925 b. Fused veins are shown by red lines. Identity of the vein stub labeled “? ” in basal-most part of forewing is unknown. Both wings are shown with apex to right. No scale provided or pterostigma shown in original figure." ;
    fabio:hasRepresentation "https://zenodo.org/record/252219/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.252228>
    dc:description "FIGURE 10. Archiraphidia tumulata (Scudder, 1890). Holotype MCZ 244. A, counterpart. B, part (converted to right). Scale bar = 4 mm (both to scale)." ;
    fabio:hasRepresentation "https://zenodo.org/record/252228/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.252231>
    dc:description "FIGURE 13. Archiraphidia tranquilla (Scudder, 1890). Wing venation of the holotype MCZ 246. A, right forewing. B, right hind wing. C, left forewing. D, left hind wing. Scale bar = 4 mm (all to scale)." ;
    fabio:hasRepresentation "https://zenodo.org/record/252231/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.252226>
    dc:description "FIGURE 8. Megaraphidia sp. Specimen MCZ 3641. A, part (converted to right). B, counterpart. C, hind wing venation. Scale bar = 4 mm (all to scale)." ;
    fabio:hasRepresentation "https://zenodo.org/record/252226/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.252236>
    dc:description "FIGURE 18. Archiraphidia? somnolenta (Scudder, 1890). Wing venation of the holotype MCZ 488. A, left forewing. B, right forewing as preserved. C, right forewing, reconstruction. D, left hind wing. E, right hind wing. Scale bar = 4 mm (all to scale)." ;
    fabio:hasRepresentation "https://zenodo.org/record/252236/files/figure.png" ;
    a fabio:Figure .

