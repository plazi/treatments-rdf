    cito:cites <http://taxon-concept.plazi.org/id/Animalia/Ambigolimax_Pollonera_1887>, <http://taxon-concept.plazi.org/id/Animalia/Limax_Linnaeusi_1758>, <http://dx.doi.org/10.5281/zenodo.3670283> ;
    dc:creator "Vendetti, Jann E.; Burnett, Emily; Carlton, Lidia; Curran, Anne T.; Lee, Cedric; Matsumoto, Ron; Donnell, Rory Mc; Reich, Inga; Willadsen, Ole" ;
    dc:title "Ambigolimax nyctelius" ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Ambigolimax_nyctelius>, <http://taxon-name.plazi.org/id/Animalia/Ambigolimax_nycteliusi> ;
    trt:deprecates <http://taxon-concept.plazi.org/id/Animalia/Ambigolimax_valentianus_Ferussaci_1821>, <http://taxon-concept.plazi.org/id/Plantae/Lehmannia_marginata_Mulleri_1774> ;
