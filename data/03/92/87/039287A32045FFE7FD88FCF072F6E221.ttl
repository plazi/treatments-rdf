    dc:creator "Sonali Garg; Robin Suyesh; Sandeep Sukesan; Sd Biju" ;
    dc:title "Nyctibatrachus webilla Garg, Suyesh, Sukesan & Biju, 2017, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Nyctibatrachus_webilla_Garg_2017> ;
