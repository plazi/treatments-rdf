    bibo:volume "2269" ;
    dc:creator "Pugliese, Adriana; Baêta, Délio; Pombal, José P." ;
    dc:date "2009" ;
    dc:title "A new species of Scinax (Anura: Hylidae) from Rocky Montane Fields in Southeastern and Central Brazil" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.190906>, <http://dx.doi.org/10.5281/zenodo.190907>, <http://dx.doi.org/10.5281/zenodo.190908> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.190906>
    dc:description "FIGURE 3. Adult male in life of Scinax rogerioi sp. nov. (uncollected specimen) from Chapada dos Veadeiros, Alto Paraíso de Goiás, State of Goiás, Brazil. Photo by L. D. Guimarães." ;
    fabio:hasRepresentation "https://zenodo.org/record/190906/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.190907>
    dc:description "FIGURE 4. (A) Spectrogram and (B) Waveform of the advertisement call of Scinax rogerioi sp. nov. (MNRJ 27754) from type – locality at Alto Paraíso de Goiás, Goiás, Brazil, recorded on 1 – 2 December 2001. Air temperature 18 ° C; water temperature 19 ° C." ;
    fabio:hasRepresentation "https://zenodo.org/record/190907/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.190908>
    dc:description "FIGURE 5. Geographical distribution of Scinax rogerioi sp. nov., in central and southeastern Brazil. Star, type locality at Alto Paraíso de Goiás; triangle, Ouro Branco, and square, Ouro Preto. BA, State of Bahia; ES, State of Espiríto Santo; RJ, State of Rio de Janeiro; SP, State of São Paulo; GO, State of Goiás; DF, Distrito Federal; and MG, State of Minas Gerais." ;
    fabio:hasRepresentation "https://zenodo.org/record/190908/files/figure.png" ;
    a fabio:Figure .

