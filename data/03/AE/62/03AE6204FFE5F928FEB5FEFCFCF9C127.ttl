    cito:cites <http://dx.doi.org/10.5281/zenodo.168834>, <http://dx.doi.org/10.5281/zenodo.156664>, <http://dx.doi.org/10.5281/zenodo.168835>, <http://dx.doi.org/10.5281/zenodo.156666> ;
    dc:creator "Leonard, William P.; Chichester, Lyle; Baugh, Jim; Wilke, Thomas" ;
    dc:title "Kootenaia burkei Leonard, Chichester, Baugh & Wilke, 2003, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Kootenaia_burkei_Leonard_2003> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.156662> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.156662>
    bibo:endPage "16" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "1" ;
    bibo:volume "355" ;
    dc:creator "Leonard, William P.; Chichester, Lyle; Baugh, Jim; Wilke, Thomas" ;
    dc:date "2003" ;
    dc:title "Kootenaia burkei, a new genus and species of slug from northern Idaho, United States (Gastropoda: Pulmonata: Arionidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.168834>, <http://dx.doi.org/10.5281/zenodo.156664>, <http://dx.doi.org/10.5281/zenodo.168835>, <http://dx.doi.org/10.5281/zenodo.156666> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.168834>
    dc:description "FIGURE 1: Relief map of Idaho showing the localities of Kootenaia burkei new species. 1) Little Bumblebee Creek, Shoshone County (type locality), 2) Trestle Creek, Bonner County, 3) Beauty Creek, Kootenai County, 4) Heyburn State Park, Benewah County, and 5) East side of Harrison, Kootenai County. For detailed locality information see the Appendix. The lower photograph shows paratype CM 66247." ;
    fabio:hasRepresentation "https://zenodo.org/record/168834/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.156664>
    dc:description "FIGURE 2. Dissected holotype of Kootenaia burkei from Shoshone County, Idaho, showing the reproductive and digestive systems. Dorsal view of reproductive system on the left and ventral view of digestive system on the right. Total body length in alcohol = 10 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/156664/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.168835>
    dc:description "FIGURE 3. Eggs of Kootenaia burkei photographed on 10 September 2003, 62 days after being laid in the laboratory." ;
    fabio:hasRepresentation "https://zenodo.org/record/168835/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.156666>
    dc:description "FIGURE 4: A. Maximum parsimony tree for representatives of the genera Hemphillia, Kootenaia, Prophysaon, and Zacoleus based on 15 anatomical characters. Bootstrap values (10,000 replicates) are given at the nodes. The scale bar indicated the number of changes. B. Bayesian phylogram for the same species based on combined fragments of mitochondrial COI DNA and LSU rRNA showing the 50 % majority­rule consensus of topologies sampled during the Bayesian search. The scale bar indicates the substitution rate according to the model of sequence evolution applied. The numbers at the branches are the percentages that the clade occurs among all sampled trees; i. e. the posterior probability of that clade." ;
    fabio:hasRepresentation "https://zenodo.org/record/156666/files/figure.png" ;
    a fabio:Figure .

