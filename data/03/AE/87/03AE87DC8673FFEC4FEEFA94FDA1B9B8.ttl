    dc:title "Cladocerans of genus Alona Baird, 1843 (Cladocera: Anomopoda: Chydoridae) and related genera from Aguascalientes State, Mexico" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.214761>, <http://dx.doi.org/10.5281/zenodo.214762>, <http://dx.doi.org/10.5281/zenodo.214763> ;
