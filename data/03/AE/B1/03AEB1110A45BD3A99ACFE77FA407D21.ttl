    dc:creator "Altuna, Álvaro; Murillo, Francisco J.; Calder, Dale R." ;
    dc:title "Cladocarpus integer G.O. Sars 1874" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cladocarpus_integer_Sars_1874> ;
