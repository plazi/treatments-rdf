    dc:date "2018" ;
    dc:title "Black corals (Anthozoa: Antipatharia) from the deep (916 m - 2542 m) Coral Sea, north-eastern Australia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1440227>, <http://dx.doi.org/10.5281/zenodo.1440235>, <http://dx.doi.org/10.5281/zenodo.1440237> ;
