    dc:creator "DELER-HERNÁNDEZ, ALBERT", "DELGADO, JUAN A." ;
    dc:date "2012" ;
    dc:title "The Hydraenidae of Cuba (Insecta: Coleoptera) I: Contribution to the fauna of eastern Cuba" ;
    bibo:endPage "238" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2012-09-11" ;
    bibo:startPage "213" ;
    bibo:volume "3478" ;
