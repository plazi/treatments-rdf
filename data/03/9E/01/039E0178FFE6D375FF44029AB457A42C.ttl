    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.10145806>
    dc:description "FIGURES 40–41. Live aspects. 40. Amorphoscelis tigrina, female nymph. Note enlarged cercal segments. 41. Elaea marchali, female." ;
    fabio:hasRepresentation "https://zenodo.org/record/10145806/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10145826>
    dc:description "FIGURES 71–76. Compsothespis occidentalis Sĵstedt, 1930. 71–72, 75. Female. 73–74, 76. Male. 71, 73. Dorsal view. 72, 74, 76. Ventral view. 75. Anterodorsal view of head. 76. Genitalia." ;
    fabio:hasRepresentation "https://zenodo.org/record/10145826/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10145880>
    dc:description "FIGURES 170–173. Polyspilota aeruginosa (Goeze, 1778). 170–171. Female. 172–173. Male. 170, 172. Dorsal view. 171, 173. Ventral view." ;
    fabio:hasRepresentation "https://zenodo.org/record/10145880/files/figure.png" ;
    a fabio:Figure .

