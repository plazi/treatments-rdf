    dc:date "2016" ;
    dc:title "A new two-pored species of Amphisbaena (Squamata, Amphisbaenidae) from the Brazilian Cerrado, with a key to the two-pored species of Amphisbaena" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.262987>, <http://dx.doi.org/10.5281/zenodo.262988>, <http://dx.doi.org/10.5281/zenodo.262989>, <http://dx.doi.org/10.5281/zenodo.262990>, <http://dx.doi.org/10.5281/zenodo.262991>, <http://dx.doi.org/10.5281/zenodo.262986>, <http://dx.doi.org/10.5281/zenodo.262992> ;
