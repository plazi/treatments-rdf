    cito:cites <http://dx.doi.org/10.5281/zenodo.206015>, <http://dx.doi.org/10.5281/zenodo.206016>, <http://dx.doi.org/10.5281/zenodo.206012> ;
    dc:creator "Vardo-Zalik, Anne M.; Campbell, Ronald A." ;
    dc:title "Acanthobothrium westi Vardo-Zalik & Campbell, 2011, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Acanthobothrium_westi_Vardo-Zalik_2011> ;
