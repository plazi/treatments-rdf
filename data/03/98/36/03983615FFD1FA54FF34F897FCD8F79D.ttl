    dc:title "Speleogobius llorisi Kovacic, Ordines & Schliewen, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Speleogobius_llorisi_Kovacic_2016> ;
