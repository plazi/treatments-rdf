    dc:creator "Batelka, Jan" ;
    dc:title "Ptilophorus purcharti Batelka 2012, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Ptilophorus_purcharti_Batelka_2012> ;
