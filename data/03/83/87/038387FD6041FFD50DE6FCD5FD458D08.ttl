    dc:title "Luticola permuticopsis Kopalova & Van de Vijver 2011, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/038387FD6041FFD50DE6FCD5FD458D08.mc.3B423CB66041FFD00D9CFBE7FC838CDC> ;
