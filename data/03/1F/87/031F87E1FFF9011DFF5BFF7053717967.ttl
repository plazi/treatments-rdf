    dc:title "Unexpected occurrence of the genus Eratigena in Laos with description of a new species (Araneae: Agelenidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.238675>, <http://dx.doi.org/10.5281/zenodo.238676>, <http://dx.doi.org/10.5281/zenodo.238677>, <http://dx.doi.org/10.5281/zenodo.238678> ;
