    dc:creator "Mound, Laurence A.; Minaei, Kambiz" ;
    dc:title "Bamboosiella australis" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Bamboosiella_australis_Pitkin_1977> ;
    trt:deprecates <http://taxon-concept.plazi.org/id/Animalia/Antillothrips_australis_Pitkin_1977>, <http://taxon-concept.plazi.org/id/Animalia/Bamboosiella_cingulata_Hood_1919> ;
