    dc:title "Systematics of the genus Euryoryzomys Weksler et al., 2006 (Rodentia: Cricetidae): integrative analysis reveals a new species from north-eastern Brazil" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.10469900>, <http://dx.doi.org/10.5281/zenodo.10469876>, <http://dx.doi.org/10.5281/zenodo.10469902>, <http://dx.doi.org/10.5281/zenodo.10469892>, <http://dx.doi.org/10.5281/zenodo.10469896>, <http://dx.doi.org/10.5281/zenodo.10469898>, <http://dx.doi.org/10.5281/zenodo.10469904> ;
