    dc:creator "Morgan, David L.; Beatty, Stephen J.; Adams, Mark" ;
    dc:title "Nannoperca pygmaea Morgan, Beatty & Adams, 2013, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Nannoperca_pygmaea_Morgan_2013> ;
