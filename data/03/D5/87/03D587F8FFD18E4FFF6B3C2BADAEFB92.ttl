    dc:creator "Schlüter, Nils" ;
    dc:date "2024" ;
    dc:title "One steps out of line-A “ modern ” Micraster species (Echinoidea, Spatangoida) with some old-fashioned look, Micraster ernsti sp. nov. from the Campanian (Cretaceous)" ;
    bibo:endPage "90" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2024-01-18" ;
