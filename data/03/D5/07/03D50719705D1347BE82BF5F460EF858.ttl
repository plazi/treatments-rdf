    dc:description "FIGURES 2–28. Sellaphora jiuzhaienis sp. nov. Light microscopy (LM). Valve size diminution series. Scale bar = 10 μm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10212879/files/figure.png" ;
