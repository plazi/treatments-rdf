    dc:title "Une Nouvelle Cigale Néotropicale, Halophile Et Crépusculaire [Homoptera, Cicadoidea]" ;
    bibo:endPage "112" ;
    bibo:issue "3" ;
    bibo:journal "Revue Française d'Entomologie" ;
