    bibo:startPage "108" ;
    bibo:volume "4" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.10497703>, <http://dx.doi.org/10.5281/zenodo.10497705>, <http://dx.doi.org/10.5281/zenodo.10497711> ;
