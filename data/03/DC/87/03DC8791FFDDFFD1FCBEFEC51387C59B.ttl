    dc:description "Figures 48–53. Pupal spiracles of Copestylum, scanning electron photomicrographs. 48, 50, Copestylum fornax; 48, dorsolateral view length 0.38 mm; 50, whole view from above scale as indicated; 49, Copestylum satur, lateral view length 0.73 mm; 51, 53, Copestylum marginatum; 51, dorsolateral view length 0.82 mm; 53, sculpture between openings, view from above; 52, Copestylum limbipenne, sculpture between openings, view from above." ;
    fabio:hasRepresentation "https://zenodo.org/record/5443508/files/figure.png" ;
    a fabio:Figure .

