    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.281201>
    dc:description "FIGURE 9. Left: The male genitalia of Chondrolepis uluguru (paratype) (SCC 706). The inset is the dorsal view of C. obscurior, which has the same blunt projections from the shoulders of the tegumen and the genitalia of the two are generally similar." ;
    fabio:hasRepresentation "https://zenodo.org/record/281201/files/figure.png" ;
    a fabio:Figure .

