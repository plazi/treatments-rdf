    dc:creator "Lienhard, Charles; Ferreira, Rodrigo F." ;
    dc:date "2013" ;
    dc:title "A new species of Neotrogla from Brazilian caves (Psocodea: ‘ Psocoptera’: Prionoglarididae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5822936>, <http://dx.doi.org/10.5281/zenodo.5822930>, <http://dx.doi.org/10.5281/zenodo.5822932>, <http://dx.doi.org/10.5281/zenodo.5822934> ;
