    dc:title "A new Cambrian catillicephalid trilobite from the Shallow Bay Formation of western Newfoundland, Canada" ;
    bibo:endPage "33" ;
    bibo:issue "1" ;
    bibo:journal "Acta Palaeontologica Polonica" ;
