    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.3349451>
    dc:description "FIGURES 1–4. Cryptachaea pilar Santanna & Rodrigues, new species: 1–2, Male: 1, Palp, ventral. 2, Palp, expanded. 3–4, Female, 3, Epigynum, ventral. 4, Dorsal, clarified. Scale bars 0.25 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/3349451/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3349455>
    dc:description "FIGURES 9–14. Body, dorsal view. Cryptachaea pilar new species: 9, Male. 10 Female. Cryptachaea parana (Levi, 1963): 11, Male. 12, Female. Cryptachaea schneirlai (Levi, 1959): 13, Male. 14, Female. Scale bars 0,25 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/3349455/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3349459>
    dc:description "FIGURES 20–25. Cryptachaea pilar new species: 20–23, Male palp: 20, ventral. 21, Prolateral. 22, Ventral. 23, stridulatory ridges and tarsal organ. 24, Male chelicerae. 25, Epigynum." ;
    fabio:hasRepresentation "https://zenodo.org/record/3349459/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.3349463>
    dc:description "FIGURE 32. Distribution of Cryptachaea species: Rectangle, Cryptachaea pilar Santanna & Rodrigues, new species; Losangle, Cryptachaea alacris (Keyserling, 1884); Circle, Cryptachae benivia Rodrigues & Poeta, 2015." ;
    fabio:hasRepresentation "https://zenodo.org/record/3349463/files/figure.png" ;
    a fabio:Figure .

