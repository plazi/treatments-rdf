    dc:creator "Brescovit, Antonio Domingos", "Cizauskas, Igor", "Rodrigues, Everton Nei Lopes", "Santanna, Manoela" ;
    dc:date "2019" ;
    dc:title "On the spider genus Cryptachaea from Peru, Bolivia and cave environments in Brazil: a new species, additional descriptions and new records (Araneae, Theridiidae)" ;
    bibo:endPage "292" ;
    bibo:issue "2" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2019-07-24" ;
