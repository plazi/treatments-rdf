    dc:creator "Bravo, Freddy" ;
    dc:title "Maruina guria Bravo, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Maruina_guria_Bravo_2004> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.158387> ;
