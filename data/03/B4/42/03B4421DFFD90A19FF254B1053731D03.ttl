    dc:creator "Hormiga, Gustavo; Scharff, Nikolaj" ;
    dc:title "Laetesia raveni Hormiga & Scharff, 2014, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Laetesia_raveni_Hormiga_2014> ;
