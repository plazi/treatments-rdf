    dc:title "Cyrtodactylus dati, a new forest dwelling Bent-toed Gecko (Squamata: Gekkonidae) from southern Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.220368>, <http://dx.doi.org/10.5281/zenodo.220369>, <http://dx.doi.org/10.5281/zenodo.220370> ;
