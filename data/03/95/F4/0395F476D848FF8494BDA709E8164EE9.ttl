    dc:title "Deltamys araucaria Quintela & Bertuol & González & Cordeiro-Estrela & Freitas & Gonçalves 2017, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Deltamys_araucaria_Quintela_2017> ;
