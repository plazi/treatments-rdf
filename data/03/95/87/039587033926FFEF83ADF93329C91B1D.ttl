    dc:title "Two new species of Turleania McLaughlin, 1997 (Crustacea: Decapoda: Anomura: Paguridae) from the Ryukyu Islands, southwestern Japan, and a redescription of T. balli (McLaughlin & Haig, 1996)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.181767>, <http://dx.doi.org/10.5281/zenodo.181760>, <http://dx.doi.org/10.5281/zenodo.181761>, <http://dx.doi.org/10.5281/zenodo.181762>, <http://dx.doi.org/10.5281/zenodo.181763> ;
