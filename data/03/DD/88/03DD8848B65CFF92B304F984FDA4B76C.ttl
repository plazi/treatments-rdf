    dc:title "Cis leoi Lopes-Andrade, Gumier-Costa & Zacaro, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cis_leoi_Lopes-Andrade_2003> ;
