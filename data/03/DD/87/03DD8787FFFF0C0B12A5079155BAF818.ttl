<http://dx.doi.org/10.5281/zenodo.274132>
    bibo:endPage "42" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "27" ;
    bibo:volume "1715" ;
    dc:creator "Tri, Ngo Van; Bauer, Aaron M." ;
    dc:date "2008" ;
    dc:title "Descriptions of two new species of Cyrtodactylus Gray 1827 (Squamata: Gekkonidae) endemic to southern Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.274141>, <http://dx.doi.org/10.5281/zenodo.274143>, <http://dx.doi.org/10.5281/zenodo.274139>, <http://dx.doi.org/10.5281/zenodo.274144> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.274141>
    dc:description "FIGURE 9. Cloacal and ventral surface of hindlimbs of holotype (USN 0256) of Cyrtodactylus huynhi sp. nov. showing the disposition of the enlarged precloacal and femoral scales and precloacal and femoral pores. Larger arrows indicate the extent of the enlarged femoral scale series (pores are minute and not clearly visible). Smaller arrows indicate lateralmost pore-bearing precloacal scales. Scale bar = 5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/274141/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.274143>
    dc:description "FIGURE 11. Paratype (USN 0257) adult female of Cyrtodactylus huynhi sp. nov. in life. This specimen exhibits a particularly bold dorsal pattern." ;
    fabio:hasRepresentation "https://zenodo.org/record/274143/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.274139>
    dc:description "FIGURE 7. Map of southern Vietnam illustrating the type localities of Cyrtodactylus takouensis (circle) and C. huynhi (star). Base map from Central Intelligence Agency." ;
    fabio:hasRepresentation "https://zenodo.org/record/274139/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.274144>
    dc:description "FIGURE 12. Habitat of Cyrtodactylus huynhi sp. nov. on Chua Chan Mountain, Dong Nai province, southeastern Vietnam." ;
    fabio:hasRepresentation "https://zenodo.org/record/274144/files/figure.png" ;
    a fabio:Figure .

