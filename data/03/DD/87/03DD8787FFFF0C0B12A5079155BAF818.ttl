    dc:creator "Tri, Ngo Van; Bauer, Aaron M." ;
    dc:title "Cyrtodactylus huynhi Tri & Bauer, 2008, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cyrtodactylus_huynhi_Tri_2008> ;
