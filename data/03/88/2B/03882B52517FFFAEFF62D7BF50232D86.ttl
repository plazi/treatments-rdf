    dc:title "Hydroporus cagrankaya Fery & Erman, 2009, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Hydroporus_cagrankaya_Fery_2009> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.186322> ;
