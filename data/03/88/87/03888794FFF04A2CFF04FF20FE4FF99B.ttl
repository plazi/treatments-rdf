    dc:title "Litoria watjulumensis" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03888794FFF04A2CFF04FF20FE4FF99B.mc.3B493CDFFFF04A2BFF04FEDDFF18FE3A> ;
