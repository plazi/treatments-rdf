    dc:creator "Xu, Yu; Zhan, Zifeng; Xu, Kuidong" ;
    dc:title "Parachrysogorgia Xu & Zhan & Xu 2023, gen. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Parachrysogorgia_Xu_2023> ;
