    dc:creator "Šumpich, Jan; Huemer, Peter; Bidzilya, Oleksiy" ;
    dc:title "Caryocolum atrum Šumpich & Huemer & Bidzilya 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Caryocolum_atrum_%C5%A0umpich_2020> ;
