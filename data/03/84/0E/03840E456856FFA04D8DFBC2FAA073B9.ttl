    dc:title "Two new ant-eating spiders of the genus Mallinella Strand, 1906 (Araneae, Zodariidae) from Hainan Island, China" ;
    bibo:endPage "254" ;
    bibo:issue "2" ;
    bibo:journal "Zootaxa" ;
