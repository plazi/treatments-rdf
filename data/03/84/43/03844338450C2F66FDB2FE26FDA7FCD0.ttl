    dc:title "Taxonomic revision of the Campoplex difformis group (Ichneumonidae, Campopleginae), with particular reference to species of economic importance" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4637842>, <http://dx.doi.org/10.5281/zenodo.4637854>, <http://dx.doi.org/10.5281/zenodo.4637858>, <http://dx.doi.org/10.5281/zenodo.4637860>, <http://dx.doi.org/10.5281/zenodo.4637862> ;
