    dc:creator "Chatfield-Taylor, Will", "Cole, Jeffrey A.", "Cooley, John R.", "Gonzalez, Valorie A.", "Smeds, Elliott A.", "Wong, Caressa" ;
    dc:date "2023" ;
    dc:title "Phylogeny of North America’s largest cicada radiation redefines Tibicinoides and Okanagana (Hemiptera: Auchenorrhyncha: Cicadidae: Tibicininae)" ;
    bibo:endPage "531" ;
    bibo:issue "5" ;
    bibo:journal "Zootaxa" ;
