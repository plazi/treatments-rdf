    dc:date "2015" ;
    dc:title "A new species of Moenkhausia Eigenmann (Characiformes: Characidae) from the upper rio Juruena basin, Central Brazil" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.239887>, <http://dx.doi.org/10.5281/zenodo.239888>, <http://dx.doi.org/10.5281/zenodo.239890> ;
