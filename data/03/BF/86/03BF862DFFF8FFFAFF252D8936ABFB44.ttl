    dc:title "Description of a new diminutive, rupicolous species of day-gecko (Squamata: Gekkonidae: Cnemaspis) from southern Sri Lanka" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2589923>, <http://dx.doi.org/10.5281/zenodo.2589925>, <http://dx.doi.org/10.5281/zenodo.2589927>, <http://dx.doi.org/10.5281/zenodo.2589929> ;
