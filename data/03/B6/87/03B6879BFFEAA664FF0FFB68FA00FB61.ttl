    dc:date "2013" ;
    dc:title "Description of new species of oak leaf-miners (Lepidoptera: Nepticulidae), with notes on the species groups of Stigmella Schrank associated with Quercus as a host-plant" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.248229>, <http://dx.doi.org/10.5281/zenodo.248225>, <http://dx.doi.org/10.5281/zenodo.248226>, <http://dx.doi.org/10.5281/zenodo.248227>, <http://dx.doi.org/10.5281/zenodo.248228> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.248229>
    dc:description "FIGURES 44, 45. Diagnostic characters of the castanopsiella and the hemargyrella species groups." ;
    fabio:hasRepresentation "https://zenodo.org/record/248229/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.248225>
    dc:description "FIGURE 37. Feeding preferences of the species groups of Stigmella associated with Quercus as a host-plant. Some species of the ruficapitella group may feed on more than one host-plant, thus the total percentage of host use for the group exceeds 100 %." ;
    fabio:hasRepresentation "https://zenodo.org/record/248225/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.248226>
    dc:description "FIGURE 38. Feeding preferences of the saginella, the cornuta and the hemargyrella groups. Some species of the saginella group may feed on more than one host-plant, thus the total percentage of host use for the group exceeds 100 %." ;
    fabio:hasRepresentation "https://zenodo.org/record/248226/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.248227>
    dc:description "FIGURES 39 – 41. Diagnostic characters of the caesurifasciella, the cornuta and the saginella species groups." ;
    fabio:hasRepresentation "https://zenodo.org/record/248227/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.248228>
    dc:description "FIGURES 42, 43. Diagnostic characters of the quercipulchella and the ruficapitella species groups." ;
    fabio:hasRepresentation "https://zenodo.org/record/248228/files/figure.png" ;
    a fabio:Figure .

