    dc:title "Nesticella inthanoni (Lehtinen & Saaristo, 1980) is the correct name for the spider Nesticella mollicula (Thorell, 1898) (Araneae, Nesticidae)" ;
    bibo:endPage "450" ;
    bibo:issue "3" ;
