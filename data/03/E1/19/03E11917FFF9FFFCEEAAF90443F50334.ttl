    cito:cites <http://taxon-concept.plazi.org/id/Animalia/Crocodylus_niloticus_Laurenti_1768>, <http://taxon-concept.plazi.org/id/Animalia/Sarcosuchus_hartti_Campos_1991>, <http://taxon-concept.plazi.org/id/Animalia/Tomistoma_schlegelii_Muller_1838>, <http://taxon-concept.plazi.org/id/Animalia/Mecistops_cataphractus_Cuvier_1825>, <http://taxon-concept.plazi.org/id/Animalia/Alligator_mississippiensis_Daudin_1802>, <http://taxon-concept.plazi.org/id/Animalia/Deinosuchus_riograndensis_Colbert_1954>, <http://dx.doi.org/10.5281/zenodo.5719182>, <http://dx.doi.org/10.5281/zenodo.5719178>, <http://dx.doi.org/10.5281/zenodo.5719186> ;
    dc:creator "Souza, Rafael G.; Figueiredo, Rodrigo G.; Azevedo, Sérgio A. K.; Riff, Douglas; Kellner, Alexander W. A." ;
    dc:title "Sarcosuchus PALAEOECOLOGY" ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Sarcosuchus>, <http://taxon-name.plazi.org/id/Animalia/Crocodylia>, <http://taxon-name.plazi.org/id/Animalia/Sarcosuchus_imperator>, <http://taxon-name.plazi.org/id/Animalia/Sarcosuchus_undetermined> ;
    trt:publishedIn <http://dx.doi.org/10.1093/zoolinnean/zlz057> ;
