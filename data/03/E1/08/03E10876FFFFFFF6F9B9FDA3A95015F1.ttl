    dc:creator "Michelsen, Verner" ;
    dc:title "Pegomya meridiana Villeneuve 1923" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Pegomya_meridiana_Villeneuve_1923> ;
