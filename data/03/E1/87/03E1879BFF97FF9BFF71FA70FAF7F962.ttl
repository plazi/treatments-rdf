    dc:title "A new Mniotype Franclemont (Lepidoptera, Noctuidae) species from China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.266190>, <http://dx.doi.org/10.5281/zenodo.266191>, <http://dx.doi.org/10.5281/zenodo.266193>, <http://dx.doi.org/10.5281/zenodo.266192> ;
