    dc:title "Eucholoeops Ameghino, 1887 (Xenarthra, Tardigrada, Megalonychidae) from the Santa Cruz Formation, Argentine Patagonia: implications for the systematics of Santacrucian sloths" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4538399>, <http://dx.doi.org/10.5281/zenodo.4538409>, <http://dx.doi.org/10.5281/zenodo.4819465>, <http://dx.doi.org/10.5281/zenodo.4538411>, <http://dx.doi.org/10.5281/zenodo.4538401>, <http://dx.doi.org/10.5281/zenodo.4538403>, <http://dx.doi.org/10.5281/zenodo.4538415>, <http://dx.doi.org/10.5281/zenodo.4538417>, <http://dx.doi.org/10.5281/zenodo.4538419> ;
