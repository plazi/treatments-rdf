    dc:creator "Packer, Laurence" ;
    dc:title "Triepeolus cecilyae Packer 2016, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03E187A0FFB7FFF1FE4369245B2A42E2.mc.3B203CEBFFB5FFF6FF2369A45B5D400B> ;
