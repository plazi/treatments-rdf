    dc:creator "Grazia, Jocelia; Schuh, Randall T.; Wheeler, Ward C." ;
    dc:title "Phloeidae Amyot & Serville 1843" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Phloeidae_Amyot_1843> ;
