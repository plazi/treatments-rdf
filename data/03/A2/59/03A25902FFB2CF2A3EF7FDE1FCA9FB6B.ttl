    dc:title "The Goniodidae (Phthiraptera: Ischnocera) of peafowl (Aves: Galliformes: Pavo), with description of a new genus" ;
    bibo:endPage "1048" ;
    bibo:issue "17 - 20" ;
    bibo:journal "Journal of Natural History" ;
    bibo:pubDate "2023-07-14" ;
