    dc:title "Taxonomic and nomenclatorial revision of the Neotropical genus Phaeoxantha Chaudoir (Coleoptera: Cicindelidae)" ;
    bibo:endPage "83" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
