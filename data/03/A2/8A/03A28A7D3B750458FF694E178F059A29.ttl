    dc:title "Maroccohoratia bouregregensis Ghamizi et Falniowski 2024, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03A28A7D3B750458FF694E178F059A29.mc.3B6331363B750459FF394D368CFE9FAD> ;
