    dc:creator "Nadolny, Anton A.; Ponomarev, Alexandr V.; Dvadnenko, Konstantin V." ;
    dc:title "Alopecosa kovblyuki Nadolny & Ponomarev, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Alopecosa_kovblyuki_Nadolny_2012> ;
