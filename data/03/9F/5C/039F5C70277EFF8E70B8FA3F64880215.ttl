    dc:creator "Yasunaga, Tomohide; Yamada, Kazutaka; Tsai, Jing-Fu" ;
    dc:title "Rhopalimiris Yasunaga & Yamada & Tsai 2023, n. gen." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Rhopalimiris_Yasunaga_2023> ;
