    dc:creator "Stuart, Bryan L.; Phimmachak, Somphouthone; Seateun, Sengvilay; Sheridan, Jennifer A." ;
    dc:title "Philautus nianeae Stuart, Phimmachak, Seateun & Sheridan, 2013, sp. nov." ;
