    dc:creator "Araya, Juan Francisco; Catalán, Ricardo; Aliaga, Juan Antonio" ;
    dc:date "2016" ;
    dc:title "A new deep-water Astyris species (Buccinoidea: Columbellidae) from the southeastern Pacific" ;
