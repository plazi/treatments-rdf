    dc:title "New species of Pseudoscalibregma Ashworth, 1901 (Annelida: Scalibregmatidae Malmgren, 1867) from Brazil" ;
    bibo:endPage "36" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
