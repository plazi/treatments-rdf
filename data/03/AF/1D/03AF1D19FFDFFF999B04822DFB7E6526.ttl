    dc:date "2004" ;
    dc:title "A new species of the genus Feuerborniella Vaillant, from Mexico (Diptera: Psychodidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5027842>, <http://dx.doi.org/10.5281/zenodo.5027844> ;
