    dc:title "Calyptocephalella Mörs, Reguero & Vasilyan 2020" ;
    dwc:basisOfRecord <http://treatment.plazi.org/id/03AF87E1EC5EFFFFFE52F92A6171F9E8/NRM-PZ%20B282%2C%20NRM-PZ%20B281> ;
