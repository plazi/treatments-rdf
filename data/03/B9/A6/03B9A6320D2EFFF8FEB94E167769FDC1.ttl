    bibo:endPage "33" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "1" ;
    bibo:volume "1128" ;
    dc:creator "Geiger, Daniel L." ;
    dc:date "2006" ;
    dc:title "Eight new species of Scissurellidae and Anatomidae (Mollusca: Gastropoda: Vetigastropoda) from around the world, with discussion of two new senior synonyms" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.273364>, <http://dx.doi.org/10.5281/zenodo.273365>, <http://dx.doi.org/10.5281/zenodo.273366>, <http://dx.doi.org/10.5281/zenodo.273367> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.273364>
    dc:description "FIGURE 7. Holotype of Scissurella maraisorum new species (NMSA W 3498 / T 1616). Aliwal Shoal, Kwazulu­Natal south coast, SCUBA 20 m. June 2003. 30.250 ° S 30.817 ° E. Uncoated specimens, variable pressure, VPSE detector. Scale bar shell = 500 µm. Scale bar protoconch = 100 µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/273364/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.273365>
    dc:description "FIGURE 8. Paratypes of Scissurella maraisorum new species. A. Collection J. P. & A. P. Marais, South Africa. B. (SBMNH 359327). C. (SBMNH 359324). All specimens from Aliwal, Kwazulu­ Natal south coast, SCUBA 20 m. June 2003. 30.250 ° S 30.817 ° E. Uncoated specimens, variable pressure, VPSE detector. Scale bars shell = 200 µm. Scale bars protoconch = 100 µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/273365/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.273366>
    dc:description "FIGURE 9. Holotype of Sinezona garciai new species. Behind outer reef, Courtown Cays, W. Caribbean, Colombia, 12.383 ° N, 81.433 ° W (USNM 1081940: ex UMML 30.12043). Scale bar shell = 500 µm. Scale bar protoconch = 100 µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/273366/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.273367>
    dc:description "FIGURE 10. Paratypes of Sinezona garciai new species. A­B. 1.5 m, Behind outer reef, Courtown Cays, W. Caribbean, Colombia, 12.383 ° N, 81.433 ° W (SBMNH 359317: ex. UMML 30.12043). C. 16 m, St. Croix, 17.800 ° N, 64.800 ° W (UMML 30.12051). Scale bars shell = 500 µm. Scale bars protoconch = 100 µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/273367/files/figure.png" ;
    a fabio:Figure .

