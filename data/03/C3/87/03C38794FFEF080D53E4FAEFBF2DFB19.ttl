    dc:creator "Hendrickx, Christophe; Mateus, Octávio" ;
    dc:title "Richardoestesia gilmorei Currie et al. 1990" ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.3759.1.1> ;
