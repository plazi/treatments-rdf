    dc:creator "Dow, Rory A.; Stokvis, Frank; Ngiam, Robin W. J." ;
    dc:title "Leptogomphus Selys in Borneo 1878" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Leptogomphus_Borneo_1878> ;
