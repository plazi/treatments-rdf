    dc:creator "Pyrcz, Tomasz W.; Prieto, Carlos; Viloria, Angel L.; Andrade, Gonzalo" ;
    dc:title "Pedaliodes philinae Pyrcz & Prieto, n. sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Pedaliodes_philinae_Pyrcz_2013> ;
