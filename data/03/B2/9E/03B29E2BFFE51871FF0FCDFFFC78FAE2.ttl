    dc:date "2013" ;
    dc:title "New species of high elevation cloud forest butterflies of the genus Pedaliodes Butler from the northern Colombian Andes (Lepidoptera, Nymphalidae, Satyrinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.220317>, <http://dx.doi.org/10.5281/zenodo.220318> ;
