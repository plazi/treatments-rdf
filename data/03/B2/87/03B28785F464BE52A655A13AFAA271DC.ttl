    cito:cites <http://dx.doi.org/10.5281/zenodo.4436912> ;
    dc:creator "Villalobos-Guerrero, Tulio F." ;
    dc:title "Perinereis Kinberg 1865" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Perinereis_Kinberg_1865> ;
    trt:publishedIn <http://dx.doi.org/10.5252/zoosystema2019v41a24> ;
