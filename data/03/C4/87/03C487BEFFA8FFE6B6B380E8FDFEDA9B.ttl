<http://dx.doi.org/10.5281/zenodo.276989>
    bibo:endPage "62" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "51" ;
    bibo:volume "2792" ;
    dc:creator "Batelka, Jan; Straka, Jakub" ;
    dc:date "2011" ;
    dc:title "Ripiphorus caboverdianus sp. nov. — the first ripiphorid record from the Macaronesian volcanic islands (Coleoptera: Ripiphoridae: Ripiphorinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.276990>, <http://dx.doi.org/10.5281/zenodo.276991>, <http://dx.doi.org/10.5281/zenodo.276992> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.276990>
    dc:description "FIGURES 1 – 2. Type locality of Ripiphorus caboverdianus sp. nov. 1 — view towards west; 2 — view towards south-east (town of Sal Rei with a lagoon and newly built hotel complex close to the rock)." ;
    fabio:hasRepresentation "https://zenodo.org/record/276990/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.276991>
    dc:description "FIGURES 3 – 8. Females of Ripiphorus caboverdianus sp. nov. lying eggs into the tips of inflorescences of Aerva javanica. Arrows in Figs. 5, 7 and 8 indicate freely moving first instar larva. Not to scale." ;
    fabio:hasRepresentation "https://zenodo.org/record/276991/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.276992>
    dc:description "FIGURES 9 – 12. 9 — Female of Ripiphorus caboverdianus sp. nov., dorsal view, 4.0 mm; 10 — Female hind tibia and tarsomeres, 2.5 mm; 11 — Male (holotype), dorsal view, 4.5 mm; 12 a—first instar larva, dorsal view, 0.66 mm, 12 b—first instar larva, ventral view, 0.6 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/276992/files/figure.png" ;
    a fabio:Figure .

