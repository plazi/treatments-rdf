<http://dx.doi.org/10.1093/zoolinnean/zlac072>
    bibo:endPage "898" ;
    bibo:issue "4" ;
    bibo:journal "Zoological Journal of the Linnean Society" ;
    bibo:pubDate "2022-11-07" ;
