    dc:creator "Fontoura, Paulo; Lisi, Oscar; Pilato, Giovanni" ;
    dc:title "Doryphoribius maasaimarensis Fontoura, Lisi & Pilato, 2013, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Doryphoribius_maasaimarensis_Fontoura_2013> ;
