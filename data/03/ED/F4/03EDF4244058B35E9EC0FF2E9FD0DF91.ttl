    dc:creator "Wang, Zhu-Hong; Huang, Jian; Polaszek, Andrew" ;
    dc:title "Baeoentedon balios Wang, Huang & Polaszek, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Baeoentedon_balios_Wang_2014> ;
