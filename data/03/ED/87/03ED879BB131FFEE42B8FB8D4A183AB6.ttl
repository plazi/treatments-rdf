    dc:title "Salvia cajamarcana (Lamiaceae), a new species from Cajamarca Department, Peru, and lectotypification of S. revoluta" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7918764>, <http://dx.doi.org/10.5281/zenodo.7918766>, <http://dx.doi.org/10.5281/zenodo.7918760>, <http://dx.doi.org/10.5281/zenodo.7918762>, <http://dx.doi.org/10.5281/zenodo.7918758> ;
