    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.206735>
    dc:description "FIGURES 26 – 35. Darwinoplectanum amphiatlanticus n. gen. n. sp. 26. Holotype whole-mount (ventral). 27 – 28. Copulatory complex. 29. Hook. 30. Rodlets. 31. Ventral bar. 32. Dextral dorsal bar. 33 – 34. Ventral anchor. 35. Dorsal anchor. Fig. 26 scale of 50 μm; Figs. 27 – 30 scale of 10 μm; Figs. 31 – 35 scale of 25 μm." ;
    fabio:hasRepresentation "https://zenodo.org/record/206735/files/figure.png" ;
    a fabio:Figure .

