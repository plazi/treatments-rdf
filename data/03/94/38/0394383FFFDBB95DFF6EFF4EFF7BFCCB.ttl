    dc:title "Anisogomphus yingsaki (Odonata: Gomphidae) sp. nov., a new gomphid species from Thailand" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.844476>, <http://dx.doi.org/10.5281/zenodo.844478>, <http://dx.doi.org/10.5281/zenodo.844480> ;
