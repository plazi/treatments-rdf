    dc:creator "Lyons And Martin Avery Snyder, William G." ;
    dc:title "Pustulatirus virginensis Abbott 1958, n. sp." ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Pustulatirus_virginensis_Abbott_1958> ;
