    dc:creator "Michelsen, Verner" ;
    dc:title "Delia coarctoides Michelsen, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Delia_coarctoides_Michelsen_2007> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.175665> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.175665>
    bibo:endPage "67" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "61" ;
    bibo:volume "1412" ;
    dc:creator "Michelsen, Verner" ;
    dc:date "2007" ;
    dc:title "A new European species of Delia Robineau­Desvoidy (Diptera: Anthomyiidae) near the wheat bulb fly, D. coarctata (Fallén)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.175666>, <http://dx.doi.org/10.5281/zenodo.175667>, <http://dx.doi.org/10.5281/zenodo.175668>, <http://dx.doi.org/10.5281/zenodo.175669> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.175666>
    dc:description "FIGURES 1 – 2. Male right distal fore tibia and tarsus. 1. Delia coarctoides sp. nov. with numbered tarsomeres. 2. D. coarctata (Fallén). Arrows point at apical pv seta. Same scale." ;
    fabio:hasRepresentation "https://zenodo.org/record/175666/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.175667>
    dc:description "FIGURES 3 – 4. Hypopygium, caudal. 3. Delia coarctoides sp. nov. 4. D. coarctata (Fallén). Notice shape of cercal plate. Same scale." ;
    fabio:hasRepresentation "https://zenodo.org/record/175667/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.175668>
    dc:description "FIGURES 5 – 6. Hypopygium, lateral. 5. Delia coarctoides sp. nov. 6. D. coarctata (Fallén). Notice shape of cercal plate and subdistal surstylus. Same scale." ;
    fabio:hasRepresentation "https://zenodo.org/record/175668/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.175669>
    dc:description "FIGURES 7 – 11. Delia coarctoides sp. nov. 7. Male hypopygial parts in left lateral view. 8. Male sternite V. 9. Female spermathecae and ducts. 10. Female cerci, epiproct and tergite VIII. 11. Female hypoproct and sternite VIII. Same scale for 7 – 8 and 10 – 11 respectively." ;
    fabio:hasRepresentation "https://zenodo.org/record/175669/files/figure.png" ;
    a fabio:Figure .

