    dc:description "FIGURE 1. Passalozetes (Passalozetes) alumbrensis n. sp. Adult. A. Dorsal view. B. Ventral view. Scale bar = 100 m." ;
    fabio:hasRepresentation "https://zenodo.org/record/5058320/files/figure.png" ;
