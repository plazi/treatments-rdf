    dc:creator "Kok, Philippe J. R.; Sambhu, Hemchandranauth; Roopsind, Indranee; Lenglet, Georges L.; Bourne, Godfrey R." ;
    dc:title "Colostethus kaiei Kok, Sambhu, Roopsind, Lenglet & Bourne, 2006, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Colostethus_kaiei_Kok_2006> ;
