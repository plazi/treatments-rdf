    dc:title "Wiederentdeckung von Dichrorampha rejectana (DE LA HARPE, 1858) stat. rev., bona species in der Schweiz (Lepidoptera, Tortricidae: Olethreutinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5851549>, <http://dx.doi.org/10.5281/zenodo.5851567>, <http://dx.doi.org/10.5281/zenodo.5851569>, <http://dx.doi.org/10.5281/zenodo.5851571> ;
