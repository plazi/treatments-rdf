    dc:title "A new large caseid (Synapsida, Caseasauria) from the Permian of Rodez (France), including a reappraisal of “ Casea ” rutena Sigogneau- Russell & Russell, 1974" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4597078>, <http://dx.doi.org/10.5281/zenodo.4597082>, <http://dx.doi.org/10.5281/zenodo.4597084>, <http://dx.doi.org/10.5281/zenodo.4597086>, <http://dx.doi.org/10.5281/zenodo.4597091>, <http://dx.doi.org/10.5281/zenodo.4597093>, <http://dx.doi.org/10.5281/zenodo.4597095>, <http://dx.doi.org/10.5281/zenodo.4597097> ;
