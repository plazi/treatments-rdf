    cito:cites <http://dx.doi.org/10.5281/zenodo.1059239>, <http://dx.doi.org/10.5281/zenodo.1059241>, <http://dx.doi.org/10.5281/zenodo.1059251> ;
    dc:creator "Rendón-Mera, Diana Isabel; Serna, Francisco; Burckhardt, Daniel" ;
    dc:title "Heteropsylla Crawford 1914" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Heteropsylla_Crawford_1914> ;
