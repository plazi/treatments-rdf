    cito:cites <http://dx.doi.org/10.5281/zenodo.2585045>, <http://dx.doi.org/10.5281/zenodo.2585049>, <http://dx.doi.org/10.5281/zenodo.2585051> ;
    dc:creator "Packer, Laurence; Dumesh, Sheila" ;
    dc:title "Chilicola" ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.4559.1.1> ;
    trt:treatsTaxonName <http://taxon-name.plazi.org/id/Animalia/Chilicola> ;
    a trt:Treatment .

<http://dx.doi.org/10.11646/zootaxa.4559.1.1>
    bibo:endPage "56" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2019-02-19" ;
    bibo:startPage "1" ;
    bibo:volume "4559" ;
    dc:creator "Packer, Laurence; Dumesh, Sheila" ;
    dc:date "2019" ;
    dc:title "Fifteen new species of Chilicola (Oroediscelis) (Hymenoptera: Colletidae: Xeromelissinae) with illustrated keys to the males and females of the subgenus" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2585045>, <http://dx.doi.org/10.5281/zenodo.2585049>, <http://dx.doi.org/10.5281/zenodo.2585051> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.2585045>
    dc:description "FIGURES 79–80. Ventral view of S4 of male to show length (red lines) of processes in relation to distance separating them (blue lines). 79. length> distance between processes (C. goloboffi holotype); 80. length at most 2/3 distance separating processes (C. maculiPes paratype)." ;
    fabio:hasRepresentation "https://zenodo.org/record/2585045/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.2585049>
    dc:description "FIGURES 81–82. Face, anterior view, showing: 81. presence (C. Pustulata paratype); 82. absence of yellow clypeal maculation (C. carPenteri holotype)." ;
    fabio:hasRepresentation "https://zenodo.org/record/2585049/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.2585051>
    dc:description "FIGURES 83–84. Lateral view of metasomal apex to show process of S4 and S5. 83. process of S4 strongly upturned and process of S5 present (red line) (C. abrebotellas paratype); 84. process of S4 straight and narrowing apically and process of S5 absent (C. caPillitas holotype)." ;
    fabio:hasRepresentation "https://zenodo.org/record/2585051/files/figure.png" ;
    a fabio:Figure .

