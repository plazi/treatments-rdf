    dc:creator "Ruiz, Gustavo Rodrigo Sanches" ;
    dc:date "2010" ;
    dc:title "Proposal of Kupiuka and Plesiopiuka, two new genera of jumping spiders from Brazil (Araneae: Salticidae: Heliophaninae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.198309>, <http://dx.doi.org/10.5281/zenodo.198312>, <http://dx.doi.org/10.5281/zenodo.198313> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.198309>
    dc:description "FIGURES 1 – 7. Kupiuka extratheca sp. nov. 1 male habitus; 2 – 3 left male palp, (2 ventral, 3 retrolateral); 4 – 5 male palpal femur (4 retrolateral, 5 prolateral); 6 epigyne, ventral view; 7 vulva, dorsal view. Scales: 0.25 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/198309/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.198312>
    dc:description "FIGURES 15 – 16. Kupiuka taruman sp. nov. 15 epigyne, ventral view; 16 vulva, dorsal view. Scale: 0.25 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/198312/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.198313>
    dc:description "FIGURES 17 – 22. Kupiuka heteropicta sp. nov. 17 – 19 left male palp (17 ventral, 18 retrolateral, 19 ventroretrolateral); 20 male palpal femur, prolateral view; 21 epigyne, ventral view; 22 vulva, dorsal view. Scales: 0.25 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/198313/files/figure.png" ;
    a fabio:Figure .

