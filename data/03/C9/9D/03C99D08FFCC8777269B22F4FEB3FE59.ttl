    bibo:volume "2694" ;
    dc:creator "Loader, Simon P.; Gower, David J.; Müller, Hendrik; Menegon, Michele" ;
    dc:date "2010" ;
    dc:title "Two new species of Callulina (Amphibia: Anura: Brevicipitidae) from the Nguru Mountains, Tanzania" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.199641>, <http://dx.doi.org/10.5281/zenodo.199642>, <http://dx.doi.org/10.5281/zenodo.199643>, <http://dx.doi.org/10.5281/zenodo.199646> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.199641>
    dc:description "FIGURE 1. a) Map of the Eastern Arc Mountains of Tanzania and southern Kenya showing the distribution of Callulina b) Distribution of C. hanseni sp. nov. (circle) and C. kanga sp. nov. (triangle) in the Nguru Mountains." ;
    fabio:hasRepresentation "https://zenodo.org/record/199641/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.199642>
    dc:description "FIGURE 2. Dorsal, ventral and lateral views of the holotype (BMNH 2008.130) of Callulina hanseni sp. nov." ;
    fabio:hasRepresentation "https://zenodo.org/record/199642/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.199643>
    dc:description "FIGURE 4. Comparison of key morphometric ratios across nominate species of Callulina, see also Table 2." ;
    fabio:hasRepresentation "https://zenodo.org/record/199643/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.199646>
    dc:description "FIGURE 9. Habitats of the Nguru mountains. Upper left, the habitat at the collecting site of Callulina kanga at about 800 m asl; Upper right: Kanga forest with Kanga peak in the background. Lower left: habitat of Callulina hanseni at about 2000 m asl. Lower right: the forest of Nguru South viewed from one of the several rocky outcrops present at higher elevation." ;
    fabio:hasRepresentation "https://zenodo.org/record/199646/files/figure.png" ;
    a fabio:Figure .

