    dc:title "Chinchaysuyoa Marceniuk & Marchena & Oliveira & Betancur-R 2019, new genus" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Chinchaysuyoa_Marceniuk_2019> ;
