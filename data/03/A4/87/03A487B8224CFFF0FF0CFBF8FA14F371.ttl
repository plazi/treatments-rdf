    dc:title "Pinnularia qinghainensis Bing Liu & S. Blanco 2021, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03A487B8224CFFF0FF0CFBF8FA14F371.mc.3B653CF3224CFFF1FF0CF9D8FA0EF25F> ;
