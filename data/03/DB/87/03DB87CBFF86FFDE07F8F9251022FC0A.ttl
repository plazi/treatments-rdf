    dc:title "A new genus and a new species of treehopper (Hemiptera: Membracidae) from the páramo of Tatamá in Colombia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7184665>, <http://dx.doi.org/10.5281/zenodo.7184667>, <http://dx.doi.org/10.5281/zenodo.7184661>, <http://dx.doi.org/10.5281/zenodo.7184671>, <http://dx.doi.org/10.5281/zenodo.7184675> ;
