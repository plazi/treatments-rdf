    dc:title "The maximum and the minimum: two new species of Tovomita Aubl. (Clusiaceae) from the Guiana Shield with an unusual number of stamens" ;
    bibo:endPage "174" ;
    bibo:issue "16" ;
    bibo:journal "Adansonia" ;
