    dc:creator "Ji, Hwan-Sung; Kim, Jin-Koo" ;
    dc:date "2011" ;
    dc:title "A new species of snake eel, Pisodonophis sangjuensis (Anguilliformes: Ophichthidae) from Korea" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.276777>, <http://dx.doi.org/10.5281/zenodo.276778>, <http://dx.doi.org/10.5281/zenodo.276779>, <http://dx.doi.org/10.5281/zenodo.276780>, <http://dx.doi.org/10.5281/zenodo.276781>, <http://dx.doi.org/10.5281/zenodo.276782> ;
