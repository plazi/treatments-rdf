    dc:title "New species, synonymies and transfers in Neotropical Lamiinae (Coleoptera: Cerambycidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.8222282>, <http://dx.doi.org/10.5281/zenodo.8222277>, <http://dx.doi.org/10.5281/zenodo.8222275> ;
