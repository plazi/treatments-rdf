    dc:title "The genus Afrosyrphus Curran (Diptera, Syrphidae), with a description of a new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3778835>, <http://dx.doi.org/10.5281/zenodo.3778837>, <http://dx.doi.org/10.5281/zenodo.3778839>, <http://dx.doi.org/10.5281/zenodo.3778831>, <http://dx.doi.org/10.5281/zenodo.3778833> ;
