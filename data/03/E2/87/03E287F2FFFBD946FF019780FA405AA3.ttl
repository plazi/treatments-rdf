<http://dx.doi.org/10.11646/zootaxa.3972.1.2>
    dc:creator "Reshchikov, Alexey; Sääksjärvi, Ilari Eerikki" ;
    dc:date "2015" ;
    dc:title "Seven new species of the genus Physotarsus Townes 1966 (Hymenoptera, Ichneumonidae) from South America" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.244171>, <http://dx.doi.org/10.5281/zenodo.244175>, <http://dx.doi.org/10.5281/zenodo.244172>, <http://dx.doi.org/10.5281/zenodo.244173>, <http://dx.doi.org/10.5281/zenodo.244174>, <http://dx.doi.org/10.5281/zenodo.244176>, <http://dx.doi.org/10.5281/zenodo.244178>, <http://dx.doi.org/10.5281/zenodo.244179> .

<http://dx.doi.org/10.5281/zenodo.244171>
    dc:description "FIGURES 1 – 3. Paratype female (1, 3) and paratype male (2) Physotarsus iquitos Reshchikov and Sääksjärvi sp. n. 1) habitus; 2) male genitalia; 3) face." ;
    fabio:hasRepresentation "https://zenodo.org/record/244171/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244175>
    dc:description "FIGURES 15, 16. Holotype female Physotarsus polleti Reshchikov and Sääksjärvi sp. n. 15) face; 16) habitus." ;
    fabio:hasRepresentation "https://zenodo.org/record/244175/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244172>
    dc:description "FIGURES 4 – 8. Paratype male Physotarsus mishanensis Reshchikov and Sääksjärvi sp. nov. 4) habitus; 5) face; 6) head, dorsal view; 7) male genitalia; 8) propodeum." ;
    fabio:hasRepresentation "https://zenodo.org/record/244172/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244173>
    dc:description "FIGURES 9 – 11. Male of Physotarsus oculatus Zhaurova, 2009. 9) habitus; 10) face; 11) male genitalia." ;
    fabio:hasRepresentation "https://zenodo.org/record/244173/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244174>
    dc:description "FIGURES 12 – 14. Holotype male Physotarsus orellanensis Reshchikov and Sääksjärvi sp. n. 12) habitus; 13) male genitalia; 14) face." ;
    fabio:hasRepresentation "https://zenodo.org/record/244174/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244176>
    dc:description "FIGURES 17 – 19. Holotype female. Physotarsus saltilloensis Reshchikov sp. n. 17) habitus, lateral view; 18) face; 19) habitus, dorsal view, punctuation of mesonotum." ;
    fabio:hasRepresentation "https://zenodo.org/record/244176/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244178>
    dc:description "FIGURES 20 – 23. Holotype female Physotarsus tampobata Reshchikov and Sääksjärvi sp. n. 20) habitus; 21) ovipositor; 22) face; 23) male genitalia." ;
    fabio:hasRepresentation "https://zenodo.org/record/244178/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.244179>
    dc:description "FIGURES 24 – 26. Holotype male Physotarsus tunchi Reshchikov sp. n. 24) habitus; 25) face; 26) male genitalia." ;
    fabio:hasRepresentation "https://zenodo.org/record/244179/files/figure.png" ;
    a fabio:Figure .

