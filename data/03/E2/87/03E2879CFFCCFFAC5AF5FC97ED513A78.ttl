    cito:cites <http://taxon-concept.plazi.org/id/Animalia/Agrotis_herrichschaefferi_Alpheraky_1895>, <http://taxon-concept.plazi.org/id/Animalia/Erebophasma_haematina_Boursin_1963>, <http://dx.doi.org/10.5281/zenodo.283167> ;
    dc:creator "Kononenko, Vladimir S.; Volynkin, Anton V.; Yu, Alexei" ;
    dc:title "Raddea Alpheraky 1892" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Raddea_Alpheraky_1892> ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Estimata>, <http://taxon-name.plazi.org/id/Animalia/Raddea>, <http://taxon-name.plazi.org/id/Animalia/Erebophasma>, <http://taxon-name.plazi.org/id/Animalia/Xestia> ;
