    dc:date "2018" ;
    dc:title "A promiscuous beta-glucosidase is involved in benzoxazinoid deglycosylation in Lamium galeobdolon" ;
    bibo:endPage "233" ;
    bibo:journal "Phytochemistry" ;
    bibo:pubDate "2018-12-31" ;
