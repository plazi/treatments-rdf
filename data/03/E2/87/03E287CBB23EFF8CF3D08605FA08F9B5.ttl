    dc:title "Revision of world Ceroptresini (Hymenoptera: Cynipidae) with the description of a new genus and five new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3772837>, <http://dx.doi.org/10.5281/zenodo.3772842>, <http://dx.doi.org/10.5281/zenodo.3772858>, <http://dx.doi.org/10.5281/zenodo.3772839>, <http://dx.doi.org/10.5281/zenodo.3772846> ;
