    dc:creator "Pérez-González, Sergio; Zaballos, Juan P." ;
    dc:title "Typhlocharis scrofa Perez-Gonzalez & Zaballos, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Typhlocharis_scrofa_Perez-Gonzalez_2013> ;
