    dc:creator "Carvalho, Mariana De S.; Da Silva, Suzane M.; Pinheiro, Ulisses" ;
    dc:date "2013" ;
    dc:title "Two new species of Aaptos (Demospongiae, Hadromerida) from Brazil (western Atlantic)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.222638>, <http://dx.doi.org/10.5281/zenodo.222639> ;
