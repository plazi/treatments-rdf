    dc:title "Ia io subsp. peninsulata Soisook, Sribuarod, Karapan, Safoowong, Billasoy, Thong, Chang, Gong, Lin, Sztencel-Jabłonka, Bogdanowicz & Bates, 2017, subsp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Ia_io_peninsulata_Soisook_2017> ;
