    dc:date "2019" ;
    dc:title "A new species of the genus Microhyla Tschudi, 1838 (Amphibia: Anura: Microhylidae) from Tay Nguyen Plateau, Central Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2618055>, <http://dx.doi.org/10.5281/zenodo.2618045>, <http://dx.doi.org/10.5281/zenodo.2618047>, <http://dx.doi.org/10.5281/zenodo.2618049>, <http://dx.doi.org/10.5281/zenodo.2618051>, <http://dx.doi.org/10.5281/zenodo.2618057>, <http://dx.doi.org/10.5281/zenodo.2618039>, <http://dx.doi.org/10.5281/zenodo.2618043>, <http://dx.doi.org/10.5281/zenodo.2618053> ;
