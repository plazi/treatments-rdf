    dc:title "A new micropterous winter species of Leuctra (Plecoptera: Leuctridae) and little known endemic stoneflies from the Greater Caucasus" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3404577>, <http://dx.doi.org/10.5281/zenodo.3404573>, <http://dx.doi.org/10.5281/zenodo.3404575>, <http://dx.doi.org/10.5281/zenodo.3404579> ;
