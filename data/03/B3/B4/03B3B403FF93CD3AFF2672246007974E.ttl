    dc:title "Fridericia transylvanica Boros & Dózsa-Farkas, 2015, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Fridericia_transylvanica_Boros_2015> ;
