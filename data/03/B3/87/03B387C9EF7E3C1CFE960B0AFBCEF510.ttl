    dc:creator "Dugdale, John S." ;
    dc:title "Tracholena liparodes Dugdale, 2005, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Tracholena_liparodes_Dugdale_2005> ;
