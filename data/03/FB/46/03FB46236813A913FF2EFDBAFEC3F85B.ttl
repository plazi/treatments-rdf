    cito:cites <http://dx.doi.org/10.5281/zenodo.207355> ;
    dc:creator "Pike, Keith S.; Starý, Petr; Graf, George; Raworth, David A.; Mathur, Sneh; Tanigoshi, Lynell K.; Murray, Todd" ;
    dc:title "Aphidius ericaphidis Pike & Stary, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Aphidius_ericaphidis_Pike_2011> ;
