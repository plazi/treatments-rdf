    dc:creator "Ermilov, Sergey G.; Behan-Pelletier, Valerie M." ;
    dc:title "Fenestrobates Balogh and Mahunka 1969" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Fenestrobates_Mahunka_1969> ;
