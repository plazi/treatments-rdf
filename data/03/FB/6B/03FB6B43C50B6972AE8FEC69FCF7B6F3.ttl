    dc:creator "Grismer, L. Lee; Wood, Perry L.; Anuar, Shahrul; Grismer, Marta S.; Quah, Evan S. H.; Murdoch, Matthew L.; Muin, Mohd Abdul; Davis, Hayden R.; Aguilar, César; Klabacka, Randy; Cobos, Anthony J.; Aowphol, Anchalee; Sites, Jack W." ;
    dc:title "Cyrtodactylus hidupselamanya Grismer, Wood, Anuar, Grismer, Quah, Murdoch, Muin, Davis, Aguilar, Klabacka, Cobos, Aowphol & Sites, 2016, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cyrtodactylus_hidupselamanya_Grismer_2016> ;
