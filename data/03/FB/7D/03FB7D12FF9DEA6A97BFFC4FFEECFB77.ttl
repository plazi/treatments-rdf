treatment:03FB7D12FF9DEA6A97BFFC4FFEECFB77
    cito:cites <http://dx.doi.org/10.5281/zenodo.199150>, <http://dx.doi.org/10.5281/zenodo.199151>, <http://dx.doi.org/10.5281/zenodo.199152> ;
    dc:creator "Lindsay, Dhugal; Pagès, Francesc" ;
    dc:title "Voragonema tatsunoko Lindsay & Pagès, 2010, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Voragonema_tatsunoko_Lindsay_2010> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.199149> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.199149>
    bibo:endPage "39" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "31" ;
    bibo:volume "2671" ;
    dc:creator "Lindsay, Dhugal; Pagès, Francesc" ;
    dc:date "2010" ;
    dc:title "Voragonema tatsunoko (Trachymedusae: Rhopalonematidae), a new species of benthopelagic medusa, host to the hyperiid amphipod Mimonectes spandli (Physosomata: Mimonectidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.199150>, <http://dx.doi.org/10.5281/zenodo.199151>, <http://dx.doi.org/10.5281/zenodo.199152> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.199150>
    dc:description "FIGURE 1. Specimen of Voragonema tatsunoko with the hyperiid amphipod Mimonectes spandli Stephensen and Pirlot, 1931 attached [paratype: 2 K 1337 SS 6 h]. Specimen collected at 15: 24: 36 above muddy sediment in Suruga Bay at 1967 m depth on 7 April 2002 and photographed in an aquarium on board ship. Voragonema tatsunoko: lateral (A), apicolateral (B), and oral (C) views; scale: 10 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/199150/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.199151>
    dc:description "FIGURE 2. Lateral views of the holotype of Voragonema tatsunoko [2 K 1337 SS 6 g], collected at 15: 18: 15, under darkfield illumination (A) and transmitted light (B), and the paratype [2 K 1337 SS 6 h] under transmitted light after removal of the parasitoid amphipod (C). Note the striations on the external surface of the exumbrella (A), reminiscent of those in Crossota rufobrunnea (Kramp, 1913); scale: 10 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/199151/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.199152>
    dc:description "FIGURE 3. (A) Lateral view of the holotype of Voragonema tatsunoko [2 K 1337 SS 6 g], collected at 15: 18: 15; scale: 1 mm. (B) detail of the bell margin of the paratype [2 K 1337 SS 6 h], from the external surface showing the proximal part of the autotomized marginal tentacles superimposed in several rows together; scale: 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/199152/files/figure.png" ;
    a fabio:Figure .

