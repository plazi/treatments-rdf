    dc:creator "Shea, Glenn M." ;
    dc:title "Anilios fossor Shea, 2015, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Anilios_fossor_Shea_2015> ;
