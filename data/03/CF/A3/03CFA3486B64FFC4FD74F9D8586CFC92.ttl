    dc:title "Descriptions of New Species ofAnomalaSamouelle (Coleoptera: Scarabaeidae: Rutelinae) from Costa Rica" ;
    bibo:endPage "476" ;
    bibo:issue "3" ;
    bibo:journal "The Coleopterists Bulletin" ;
