    dc:title "Ernogamasus papilio Witaliński & Fenďa 2020, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03C8755EF02CDA2D39C016C9FCDCA99A.mc.3B09CE15F02CDA243DAB120CFBB5AD9E> ;
