    dc:title "Balacha ancora Quintas & Takiya & Cavichioli & Mejdalani 2020, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03C868630D43FF82FF4215F02470CEC1.mc.3B09D3280D45FF80FE62128926ACC845> ;
