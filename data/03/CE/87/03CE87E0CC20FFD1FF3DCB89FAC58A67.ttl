    dc:title "New species of Cophixalus (Anura: Microhylidae) from Papua New Guinea" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.188302>, <http://dx.doi.org/10.5281/zenodo.188315>, <http://dx.doi.org/10.5281/zenodo.188304> ;
