    dc:title "A revision of the genus Ima Tindale (Mantodea: Nanomantidae: Fulciniinae) with the description of a new genus" ;
    bibo:endPage "226" ;
    bibo:issue "3" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2023-11-30" ;
