    dc:title "Geotrechus sarpedon Faille, Fresneda & Bourdeau, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Geotrechus_sarpedon_Faille_2013> ;
