    dc:title "Gonatodes lichenosus Rojas-Runjaic, Infante-Rivero, Cabello & Velozo, 2010, sp. nov." ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Gonatodes_lichenosus>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes_alexandermendesi>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes_hasemani>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes_superciliaris>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes_albogularis>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes_petersi>, <http://taxon-name.plazi.org/id/Animalia/Gonatodes_vittatus> ;
