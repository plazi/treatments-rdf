    dc:title "Erichsonius (Sectophilonthus) dorsumsuis sp. nov. from Eastern Cape and KwaZulu-Natal Provinces, South Africa (Coleoptera: Staphylinidae, Staphylininae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5740383>, <http://dx.doi.org/10.5281/zenodo.5740387>, <http://dx.doi.org/10.5281/zenodo.5740385>, <http://dx.doi.org/10.5281/zenodo.5740389> ;
