    dc:title "Eleutherodactylus juanariveroi Rios-López & Thomas, 2007, n. sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Eleutherodactylus_juanariveroi_Rios-L%C3%B3pez_2007> ;
