    dc:title "Irene litanga, a new genus and new species in the Polia generic-complex from China (Lepidoptera, Noctuidae, Hadeninae, Hadenini)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.345274>, <http://dx.doi.org/10.5281/zenodo.345277>, <http://dx.doi.org/10.5281/zenodo.345275>, <http://dx.doi.org/10.5281/zenodo.345276> ;
