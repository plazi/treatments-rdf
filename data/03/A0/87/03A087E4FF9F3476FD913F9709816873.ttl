    dc:title "New family and genus Rostrocalanus gen. nov. (Crustacea: Calanoida: Rostrocalanidae fam. nov.) from deep Atlantic waters" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5224089>, <http://dx.doi.org/10.5281/zenodo.5224091>, <http://dx.doi.org/10.5281/zenodo.5224093> ;
