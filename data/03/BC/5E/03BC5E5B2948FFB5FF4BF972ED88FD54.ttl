    dc:title "Revision of the Palaearctic and Oriental representatives of Lachnocrepis LeConte and Oodes Bonelli (Coleoptera: Carabidae), with special account on Chinese species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4407076>, <http://dx.doi.org/10.5281/zenodo.4407086>, <http://dx.doi.org/10.5281/zenodo.4407100>, <http://dx.doi.org/10.5281/zenodo.4407104> ;
