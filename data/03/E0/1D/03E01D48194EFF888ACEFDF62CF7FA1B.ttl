    dc:title "Boana hobbsi" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03E01D48194EFF888ACEFDF62CF7FA1B.mc.3B21A603194EFF878ACEFD2E2B4AFD6C> ;
