    dc:creator "Shelley, Rowland M.; Richart, Casey H." ;
    dc:title "Diactis hedini Shelley & Richart 2014, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Diactis_hedini_Shelley_2014> ;
