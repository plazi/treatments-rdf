<http://dx.doi.org/10.5281/zenodo.266228>
    dc:description "FIGURES 1 – 13. Paraleptophlebia falcula, larvae. 1, labrum, dorsal view; 2, 3, left and right mandibles, dorsal view; 4, 5, incisors and kinetodonts of left and right mandibles; 6, maxillary palp, ventral view; 7, labium, dorsal view; 8, segments 2 and 3 of labial palp; 9, hypopharynx and superlinguae, dorsal view; 10, femur of foreleg; 11, foreclaw, dorsal view; 12, posterior margin of abdominal tergum IV; 13, abdominal sternum IX, female." ;
    fabio:hasRepresentation "https://zenodo.org/record/266228/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266229>
    dc:description "FIGURES 14 – 15. Paraleptophlebia falcula, larvae, habitus. 14, dorsal view; 15, ventral view." ;
    fabio:hasRepresentation "https://zenodo.org/record/266229/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266230>
    dc:description "FIGURES 16 – 22. Paraleptophlebia falcula, larvae, tergalii of I, II, III, IV, V, VI and VII pairs." ;
    fabio:hasRepresentation "https://zenodo.org/record/266230/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266231>
    dc:description "FIGURES 23 – 25. Paraleptophlebia falcula, male imago. 23, lateral view; 24, dorsal view; 25, ventral view." ;
    fabio:hasRepresentation "https://zenodo.org/record/266231/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266232>
    dc:description "FIGURES 26 – 30. Paraleptophlebia falcula, genitals of male imago. 26 – 28, specimens from Transbaikal Kray; 29, 30, specimen from Komi Republic. 26, 29, ventral view; 27, penis, ventral view; 28, penis, dorsal view, 30, lateral view." ;
    fabio:hasRepresentation "https://zenodo.org/record/266232/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266233>
    dc:description "FIGURES 31 – 32. Paraleptophlebia falcula, female imago. 31, lateral view; 32, subanal plate, ventral view." ;
    fabio:hasRepresentation "https://zenodo.org/record/266233/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266234>
    dc:description "FIGURES 33 – 37. Paraleptophlebia falcula, eggs." ;
    fabio:hasRepresentation "https://zenodo.org/record/266234/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.266235>
    dc:description "FIGURES 38 – 39. Paraleptophlebia falcula, localities. 38, Bolshaya Makcha river (Amurskiy Region); 39, Amnunnykta river (Sakha Yakutia)." ;
    fabio:hasRepresentation "https://zenodo.org/record/266235/files/figure.png" ;
    a fabio:Figure .

