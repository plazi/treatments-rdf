    dc:creator "Mendoza Marroquín, Jorge I." ;
    dc:date "2014" ;
    dc:title "Taxonomic revision of Hemirrhagus Simon, 1903 (Araneae: Theraphosidae, Theraphosinae), with description of five new species from Mexico" ;
