    dc:title "Superodontella gladiator Agolin, Houssin & Deharveng, 2009, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Superodontella_gladiator_Agolin_2009> ;
