    dc:creator "Palma, Ricardo L." ;
    dc:date "2012" ;
    dc:title "Three new species of the louse genus Saemundssonia (Insecta: Phthiraptera: Philopteridae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.214090>, <http://dx.doi.org/10.5281/zenodo.214091>, <http://dx.doi.org/10.5281/zenodo.214092>, <http://dx.doi.org/10.5281/zenodo.214094> ;
