    cito:cites <http://dx.doi.org/10.5281/zenodo.199536>, <http://dx.doi.org/10.5281/zenodo.199537> ;
    dc:creator "Isaia, Marco; Pantini, Paolo" ;
    dc:title "Troglohyphantes lanai Isaia and Pantini, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Troglohyphantes_lanai_Pantini_2010> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.199535> ;
