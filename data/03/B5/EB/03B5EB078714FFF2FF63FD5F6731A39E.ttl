    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.10151366>
    dc:description "FIGURE 13A–D. Lepidocyrtus (Fractocyrtus) chicomendesi sp. nov., habitus of specimens fixed in ethanol (lateral view); A, specimen (frequent color pattern) from type locality, Mâncio Lima municipality,Acre State; B–C, specimens from type locality, Manoel Urbano municipality, Acre State; D, specimen from São Gabriel da Cachoeira municipality, Amazonas State. Scale bar: 0.5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151366/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10151368>
    dc:description "FIGURE 14A–E. Lepidocyrtus (Fractocyrtus) chicomendesi sp. nov., head; A, Ant III distal end (lateral view); B, dorsal head chaetotaxy (left side); C, clypeal and prelabral chaetotaxy; D, labial papillae E (right side); E, basomedian and basolateral labial fields and complete postlabial chaetotaxy (left side), arrow indicate spine present or absent." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151368/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10151372>
    dc:description "FIGURE 15A–D. Lepidocyrtus (Fractocyrtus) chicomendesi sp. nov., dorsal chaetotaxy (left side); A, Th II; B, Th III; C, Abd I; D, Abd II." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151372/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10151374>
    dc:description "FIGURE 16A–C. Lepidocyrtus (Fractocyrtus) chicomendesi sp. nov., dorsal chaetotaxy (left side); A, Abd III; B, Abd IV; C, Abd V." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151374/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10151376>
    dc:description "FIGURE 17A–B. Lepidocyrtus (F.) chicomendesi sp. nov., body psp distribution; A, dorsal side; B, ventral side." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151376/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10151378>
    dc:description "FIGURE 18A–G. Lepidocyrtus (F.) chicomendesi sp. nov., trunk appendages; A–C, chaetotaxy of subcoxa I–III, respectively; D, trochanteral organ (posterior view); E, collophore (lateral view), arrows on anterior region indicate chaetae or scale (rarely), on posterior region point out chaetae of different lengths, on lateral flap variable ciliate or smooth chaetae; F, distal end of manubrium (anterior view), arrow shows elongated scale; G, distal end of manubrium and proximal end of dens (lateral view), arrows on manubrial plate identify chaetae of different lengths, arrows on dens indicate pseudopore present or absent." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151378/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10151380>
    dc:description "FIGURE 19. Records map of Lepidocyrtus (Fractocyrtus) species; stars represent type localities and circles additional localities." ;
    fabio:hasRepresentation "https://zenodo.org/record/10151380/files/figure.png" ;
    a fabio:Figure .

