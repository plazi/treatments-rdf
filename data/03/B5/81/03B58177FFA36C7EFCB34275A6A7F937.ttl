    dc:title "Late Miocene Conidae (Mollusca: Gastropoda) of Crete (Greece). Part 1: genera Conilithes Swainson, 1840 and Conus (Kalloconus) da Motta, 1991" ;
    bibo:endPage "1339" ;
    bibo:issue "24" ;
    bibo:journal "Geodiversitas" ;
    bibo:pubDate "2021-12-02" ;
