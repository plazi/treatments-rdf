    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10086587>
    dc:description "FIGURE 41. Halistemma striata. Upper views of young Type A bracts. Type A-1 (left and centre), Type A-2 (right). Proximal at top, distal at bottom. Scale bar 5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10086587/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10086591>
    dc:description "FIGURE 43. Halistemma striata. Type B bracts—upper views. Proximal at top, distal at bottom. Scale 5 mm." ;
