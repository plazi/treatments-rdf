    dc:description "FIGURE 30. Adults of Siberian Sterrhinae. A—Timandra rectistrigaria; B—T. griseata; C—T. recompta; D—T. paralias." ;
    fabio:hasRepresentation "https://zenodo.org/record/7965167/files/figure.png" ;
