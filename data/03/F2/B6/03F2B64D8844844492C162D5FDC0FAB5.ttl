    dc:creator "Liebherr, James K.; Kahoolaa, Raina L." ;
    dc:title "Blackburnia fulgida Liebherr 2000" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Plantae/Blackburnia_fulgida_Liebherr_2000> ;
