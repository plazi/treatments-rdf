    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.207000>
    dc:description "FIGURES 1 – 3. Macrobiotus binieki sp. nov. adult: 1. habitus (ventral view, holotype), 2. buccal apparatus (ventral view, holotype), 3. claws III." ;
    fabio:hasRepresentation "https://zenodo.org/record/207000/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.207001>
    dc:description "FIGURES 4 – 8. Macrobiotus binieki sp. nov. egg: 4. mid-section, 5 – 6. egg surface (at two different focusing levels), 7 – 8. processes. Scale on 6 same as on 5 and scale on 8 same as on 7." ;
    fabio:hasRepresentation "https://zenodo.org/record/207001/files/figure.png" ;
    a fabio:Figure .

