    dc:date "2021" ;
    dc:title "Systematics of Helioandesia tarregai gen. et sp. nov. (Lepidoptera: Yponomeutoidea: Heliodinidae) from the Andes of Northern Chile" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4452227>, <http://dx.doi.org/10.5281/zenodo.4452229>, <http://dx.doi.org/10.5281/zenodo.4452231>, <http://dx.doi.org/10.5281/zenodo.4452233> ;
