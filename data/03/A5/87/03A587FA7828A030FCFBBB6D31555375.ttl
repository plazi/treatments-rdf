    dc:creator "Pholyotha, Arthit; Sutcharit, Chirasak; Panha, Somsak" ;
    dc:title "Macrochlamys tanymentula Pholyotha & Sutcharit & Panha 2018, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/03A587FA7828A030FCFBBB6D31555375.mc.3B643CB17828A032FBCBBBED37B451C3>, <http://tb.plazi.org/GgServer/dwcaRecords/03A587FA7828A030FCFBBB6D31555375.mc.3B643CB17828A032FC6DBA8E30E75263> ;
