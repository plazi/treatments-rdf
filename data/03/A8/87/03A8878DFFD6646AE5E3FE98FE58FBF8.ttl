    dc:title "Description of a new species of the genus Neolucanus Thomson, 1862 (Coleoptera: Lucanidae) from central Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.220459>, <http://dx.doi.org/10.5281/zenodo.220464>, <http://dx.doi.org/10.5281/zenodo.220460> ;
