    dc:title "Auchenoglanis Gunther 1865" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Auchenoglanis_Gunther_1865> ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Pimelodus> ;
    trt:deprecates <http://taxon-concept.plazi.org/id/Animalia/Oxyglanis_Vinciguerra_1898>, <http://taxon-concept.plazi.org/id/Animalia/Auchenaspis_Bleeker_1858>, <http://taxon-concept.plazi.org/id/Animalia/Auchenaspis_Egerton_1857> ;
