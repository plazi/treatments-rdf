    dc:creator "Gentili, Elio; Fikaček, Martin" ;
    dc:title "Laccobius (Glyptolaccobius) sipeki Gentili & Fikaček 2009, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/039387B6FFA6156E7F37FBD4FE6BFDE7.mc.3B523CFDFFA6156A7EA7FB48FEBEFAD7> ;
