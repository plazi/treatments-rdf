    dc:title "Two new species of Metacyclops Kiefer, 1927 (Copepoda, Cyclopoida) from Thailand and an up-to-date key to the species recorded in Asia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5837681>, <http://dx.doi.org/10.5281/zenodo.5837699>, <http://dx.doi.org/10.5281/zenodo.5837701>, <http://dx.doi.org/10.5281/zenodo.5837703>, <http://dx.doi.org/10.5281/zenodo.5837705>, <http://dx.doi.org/10.5281/zenodo.5837707>, <http://dx.doi.org/10.5281/zenodo.5837709> ;
