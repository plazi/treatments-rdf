    cito:cites <http://dx.doi.org/10.5281/zenodo.215181>, <http://dx.doi.org/10.5281/zenodo.215182> ;
    dc:creator "Turak, Emre; Devantier, Lyndon; Erdmann, Mark" ;
    dc:title "Euphyllia baliensis Turak, Devantier & Erdmann, 2012, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Euphyllia_baliensis_Turak_2012> ;
