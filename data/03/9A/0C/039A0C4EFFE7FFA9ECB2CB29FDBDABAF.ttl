    bibo:volume "1616" ;
    dc:creator "Willems, Wim R.; Sandberg, Maria I.; Jondelius, Ulf" ;
    dc:date "2007" ;
    dc:title "First report on Rhabdocoela (Rhabditophora) from deep parts of Skagerrak, with the description of four new species" ;
