    dc:title "Isospora sepetibensis Berto, Flausino, Luz, Ferreira, Lopes 2008" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/039AAF577F56FFBDFCDB560AFA7968F3.mc.3B5B141C7F55FFBCFED95707FC0F69FF> ;
