    bibo:endPage "240" ;
    bibo:issue "2" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "226" ;
    bibo:volume "4294" ;
    dc:creator "Roxo, Fábio F.; Silva, Gabriel S. C.; Zawadzki, Cláudio H.; Oliveira, Claudio" ;
    dc:date "2017" ;
    dc:title "Neoplecostomus canastra, a new catfish (Teleostei: Siluriformes) species from upper Rio Paraná basin" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.831862>, <http://dx.doi.org/10.5281/zenodo.831864>, <http://dx.doi.org/10.5281/zenodo.831866> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.831862>
    dc:description "FIGURE 1. Neoplecostomus canastra, MZUSP 121504, (male), SL = 82.5 mm, holotype from córrego Tamborete, in municipality of Capitólio, Minas Gerais state, Brazil." ;
    fabio:hasRepresentation "https://zenodo.org/record/831862/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.831864>
    dc:description "FIGURE 2. (a) Map showing the type locality of Neoplecostomus canastra (red star) at córrego Tamborete, 20 ° 38 ' 54 '' S, 46 ° 09 ' 52 '' W, rio Grande basin, Southeastern of Brazil. (b) Habitat at type locality of N. canastra with clear-water steam about 0.25 – 1.5 m depth, bottom with small to medium-sized rocks, loose stones and sand." ;
    fabio:hasRepresentation "https://zenodo.org/record/831864/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.831866>
    dc:description "FIGURE 3. Bayesian consensus tree for Neoplecostomus species obtained from 5 million generations. Numbers after branches are posterior probabilities. Values below 0.95 are not shown. Results from different methods of species delimitation are shown with bars colored at right side of the phylogeny. Pink bars represent morphospecies, yellow bars GMYC model and blue bars 2 % genetic distance between clusters. The upper-left graphic is the Lineage-through-time plot representing the threshold time at - 0.007195772 (yellow line)." ;
    fabio:hasRepresentation "https://zenodo.org/record/831866/files/figure.png" ;
    a fabio:Figure .

