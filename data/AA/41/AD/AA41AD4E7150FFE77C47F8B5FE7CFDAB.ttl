    dc:creator "Sabatinelli, Guido" ;
    dc:date "2020" ;
    dc:title "Taxonomic notes on the genus Cyphochilus Waterhouse, 1867 (Coleoptera, Scarabaeoidea, Melolonthinae) with description of 10 new species" ;
