    dc:title "Contribution to the knowledge of Aegidinus Arrow (Coleoptera: Scarabaeidae: Orphninae): new species and comments on the classification and nomenclature" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3675573>, <http://dx.doi.org/10.5281/zenodo.3675583>, <http://dx.doi.org/10.5281/zenodo.3675575>, <http://dx.doi.org/10.5281/zenodo.3675579>, <http://dx.doi.org/10.5281/zenodo.3675577>, <http://dx.doi.org/10.5281/zenodo.3675581> ;
