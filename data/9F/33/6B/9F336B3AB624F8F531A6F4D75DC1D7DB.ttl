    dc:creator "Lacey, L. Mae; Cantley, Jason T.; Martine, Christopher T." ;
    dc:date "2017" ;
    dc:title "Solanum jobsonii, a novel andromonoecious bush tomato species from a new Australian national park" ;
    fabio:hasPart <http://dx.doi.org/10.3897/phytokeys.82.12106.figure2>, <http://dx.doi.org/10.3897/phytokeys.82.12106.figure3> ;
