    dc:creator "Masroor, Rafaqat" ;
    dc:date "2009" ;
    dc:title "A new arboreal species of Cyrtopodion (Squamata: Gekkonidae) from Deh Akro-II Wetlands Complex, Sindh, Pakistan" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.275214>, <http://dx.doi.org/10.5281/zenodo.275211>, <http://dx.doi.org/10.5281/zenodo.275213> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.275214>
    dc:description "FIGURE 4. Dorsal view of the hindlimbs and tail of the holotype of Cyrtopodion dehakroense sp. nov. (PMNH 2167). Note large tubercles on hindlimbs and mucronate tubercles on tail. Scale bar = 10 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/275214/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.275211>
    dc:description "FIGURE 1. Map of Deh Akro-II Wetlands Complex, Nawabshah, Sindh, showing the collection localities for Cyrtopodion dehakroense sp. nov." ;
    fabio:hasRepresentation "https://zenodo.org/record/275211/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.275213>
    dc:description "FIGURE 3. Prosopis cineraria, the tree from which the holotype of Cyrtopodion dehakroense sp. nov. (PMNH 2167) was collected" ;
    fabio:hasRepresentation "https://zenodo.org/record/275213/files/figure.png" ;
    a fabio:Figure .

