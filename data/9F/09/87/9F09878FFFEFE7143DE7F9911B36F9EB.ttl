    dc:creator "Rose, Robert K.; Pemberton, David A.; Mooney, Nick J.; Jones, Menna E." ;
    dc:title "Sarcophilus harrisii" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Sarcophilus_harrisii_Boitard_1842> ;
