    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212629>
    dc:description "FIGURES 6 – 9. Adults of Eudonia spp. 6. E. zhongdianensis sp. n., paratype, female; 7. E. furva sp. n., paratype, female; 8. E. hexamera sp. n., paratype, female; 9. E. magna sp. n., paratype, male." ;
    fabio:hasRepresentation "https://zenodo.org/record/212629/files/figure.png" ;
