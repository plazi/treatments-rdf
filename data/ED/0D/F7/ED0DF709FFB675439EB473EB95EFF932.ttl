    dc:title "Phrynopus capitalis Rodriguez & Catenazzi, 2017, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/ED0DF709FFB675439EB473EB95EFF932.mc.D5CC4C42FFB675409EB4724196FDFA56> ;
