    dc:title "Phrynopus anancites Rodriguez & Catenazzi, 2017, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/ED0DF709FFBB75409EB477D196ACFBA1.mc.D5CC4C42FFBB754D9EB476469604FE50> ;
