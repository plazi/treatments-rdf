    dc:date "2008" ;
    dc:title "A new species of Systelloderes (Hemiptera: Heteroptera: Enicocephalidae) from South Africa" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5340868>, <http://dx.doi.org/10.5281/zenodo.5340874>, <http://dx.doi.org/10.5281/zenodo.5340872> ;
