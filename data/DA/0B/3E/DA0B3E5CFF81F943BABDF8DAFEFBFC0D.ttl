    cito:cites <http://dx.doi.org/10.5281/zenodo.191356> ;
    dc:creator "Renoult, Julien P.; Raselimanana, Achille P." ;
    dc:title "Typhlops rajeryi Renoult & Raselimanana, 2009, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Typhlops_rajeryi_Renoult_2009> ;
