    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10273202>
    dc:description "Figs 8-12: aedeagus of Thyreocephalus macrophallus nov.sp. (8) (bar scale: 0,5 mm); head and pronoum (bar scale: 1 mm), labrum, male genital segment, sternite of the same of Thyreocephalus depressus nov.sp. (9-12)." ;
    fabio:hasRepresentation "https://zenodo.org/record/10273202/files/figure.png" ;
