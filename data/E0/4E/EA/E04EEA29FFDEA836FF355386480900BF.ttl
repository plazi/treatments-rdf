    dc:creator "Bauer, Christian; Prieto, Carlos E." ;
    dc:title "Chilon robustus Sorensen 1896" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Chilon_robustus_Sorensen_1896> ;
