    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.7836043>
    dc:description "FIGURE 5. Hyalella cuyana n. sp., male holotype (FML-CRUST 01282) and female paratype (FML-CRUST 01284). A male gnathopod 1, arrows indicate enlargement of the palmar angle B male gnathopod 2 C female gnathopod 2, arrows indicate curled setae of oostegites. Scale bars: 0.1mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/7836043/files/figure.png" ;
