    dc:date "2023" ;
    dc:title "Revision of the Palaearctic species of the genus Plateumaris C. G. Thomson, 1859 (Coleoptera, Chrysomelidae, Donaciinae)" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.1177.103214.figure11>, <http://dx.doi.org/10.3897/zookeys.1177.103214.figure12>, <http://dx.doi.org/10.3897/zookeys.1177.103214.figure9> ;
