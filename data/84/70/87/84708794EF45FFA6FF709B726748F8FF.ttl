treatment:84708794EF45FFA6FF709B726748F8FF
    cito:cites <http://dx.doi.org/10.5281/zenodo.211035>, <http://dx.doi.org/10.5281/zenodo.211036>, <http://dx.doi.org/10.5281/zenodo.211037>, <http://dx.doi.org/10.5281/zenodo.211043>, <http://dx.doi.org/10.5281/zenodo.211042>, <http://dx.doi.org/10.5281/zenodo.211032>, <http://dx.doi.org/10.5281/zenodo.211044>, <http://dx.doi.org/10.5281/zenodo.211046> ;
    dc:creator "Luque, Carlos G.; Labrada, Lucia" ;
    dc:title "Ischyropsalis cantabrica Luque & Labrada, 2012, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Ischyropsalis_cantabrica_Luque_2012> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.211031> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.211031>
    bibo:endPage "42" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "26" ;
    bibo:volume "3506" ;
    dc:creator "Luque, Carlos G.; Labrada, Lucia" ;
    dc:date "2012" ;
    dc:title "A new cave-dwelling endemic Ischyropsalis C. L. Koch, 1839 (Opiliones: Dyspnoi: Ischyropsalididae) from the karstic region of Cantabria (Spain)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.211035>, <http://dx.doi.org/10.5281/zenodo.211036>, <http://dx.doi.org/10.5281/zenodo.211037>, <http://dx.doi.org/10.5281/zenodo.211043>, <http://dx.doi.org/10.5281/zenodo.211042>, <http://dx.doi.org/10.5281/zenodo.211032>, <http://dx.doi.org/10.5281/zenodo.211044>, <http://dx.doi.org/10.5281/zenodo.211046> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.211035>
    dc:description "FIGURES 6 – 10. Ischyropsalis cantabrica sp. n., male holotype from Rogeria Cave (MNCN 20.02 / 12828). Cephalothorax, lateral view (10). Male cheliceral apophysis on distal basal segment, medial view (8 a, 9), female chelicerae (8 b). Total view of ventral penis (6); distal part of penis with glans and stylus, ventral view (7)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211035/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211036>
    dc:description "FIGURES 11 – 15. Ischyropsalis cantabrica sp. n., male paratype from Cerviz Cave (MNCN 20.02 / 12857). Distal part of penis with glans and stylus: dorsal view (11), ventral view (12), lateral view (13), dorsolateral view (14), detail of the funnel-like sclerite (15)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211036/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211037>
    dc:description "FIGURES 16 – 17. Ischyropsalis cantabrica sp. n., male paratype from Cerviz Cave (MNCN 20.02 / 12857). Male cheliceral apophysis on distal basal segment, medial view." ;
    fabio:hasRepresentation "https://zenodo.org/record/211037/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211043>
    dc:description "FIGURES 32 – 37. Ischyropsalis gigantea, male from Recuistro Cave (MNCN 20.02 / 9957, Upper Miera Mountains). Male cheliceral apophysis on distal basal segment, medial view (32 – 33). Detail of bristle with basal socket structure revealing the whorled striae on the external surface and the lack of a discernable pore at the tip (34). Distal part of penis with glans and stylus: dorsal view (35), ventral view (36) and lateral view (37)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211043/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211042>
    dc:description "FIGURES 27 – 31. Ischyropsalis gigantea, male from Los Moros del Río Munio Cave (Upper Asón Mountain). Cephalothorax, lateral view (27). Male cheliceral apophysis on distal basal segment, medial view (Figs 28 a – 29, female 28 b). Total penis, ventral view (30); distal part of penis with glans and stylus, ventral view (31)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211042/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211032>
    dc:description "FIGURES 1 – 3. Type locality and habitus of Ischyropsalis cantabrica sp. n. 1: Entrance to ‘ Rogeria Cave’ in Spain, Prov. Cantabria. 2: ‘ Rogeria Cave’ Digital Orthophoto with UTM grid, Zone 30, ED 50; 3: Life female specimen from ‘ Rogeria Cave’ (CGL 369)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211032/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211044>
    dc:description "FIGURES 38 – 41. Ischyropsalis sp. aff. dispar from La Baja Cave (MNCN 20.02 / 12858, Laredo, Hacha Mountain). Male cheliceral apophysis on distal basal segment, medial view (38). Distal part of penis with glans and stylus: dorsal view (39), ventral view (40) and lateral view (41)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211044/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.211046>
    dc:description "FIGURES 50 – 57. Ischyropsalis cf. noltei (or Ischyropsalis sp. aff. dispar) from Abaro Pit (MNCN 20.02 / 12860, Indusi Mountain; 50 – 53); Ischyropsalis sp. aff. dispar from La Pasada Cave (MNCN 20.02 / 12859, Guriezo; 54 – 57). Male cheliceral apophysis on distal basal segment, medial view (50, 54). Distal part of penis with glans and stylus: dorsal view (51, 55), ventral view (52, 56) and lateral view (53, 57)." ;
    fabio:hasRepresentation "https://zenodo.org/record/211046/files/figure.png" ;
    a fabio:Figure .

