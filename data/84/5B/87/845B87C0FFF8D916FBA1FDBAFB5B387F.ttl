    cito:cites <http://dx.doi.org/10.5281/zenodo.4471394>, <http://dx.doi.org/10.5281/zenodo.4471396>, <http://dx.doi.org/10.5281/zenodo.4471406>, <http://dx.doi.org/10.5281/zenodo.4471408> ;
    dc:creator "Ballarin, Francesco; Yamasaki, Takeshi" ;
    dc:title "Nihonella Ballarin & Yamasaki 2021, gen. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Nihonella_Ballarin_2021> ;
