    dc:creator "Hernandez, Osvaldo; Gomez-Gutierrez, Jaime; Sanchez, Carlos" ;
    dc:title "Leptogorgia iridis Hernández & Gómez-Gutiérrez & Sánchez 2021, sp. nov." ;
