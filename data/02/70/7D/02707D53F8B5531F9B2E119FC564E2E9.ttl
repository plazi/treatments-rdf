    dc:creator "Luo, Tao; Chen, Zhi-Xia; Zhao, Xin-Rui; Yu, Jing; Lan, Chang-Ting; Zhou, Jia-Jun; Xiao, Ning; Zhou, Jiang" ;
    dc:title "Balitora anlongensis Luo, Chen, Zhao, Yu, Lan & Zhou 2023, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Balitora_anlongensis_Luo_2023> ;
