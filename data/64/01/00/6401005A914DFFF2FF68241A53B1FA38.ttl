    dc:creator "Ng, Peter K. L.; Ahyong, Shane T." ;
    dc:date "2013" ;
    dc:title "Discovery of a new genus and new species of Indo-West Pacific pilumnoidid crab from a semisubmersible oil platform (Crustacea: Brachyura: Pseudozioidea)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.218156>, <http://dx.doi.org/10.5281/zenodo.218158>, <http://dx.doi.org/10.5281/zenodo.218157> ;
