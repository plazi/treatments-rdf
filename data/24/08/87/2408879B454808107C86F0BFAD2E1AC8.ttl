    dc:date "2020" ;
    dc:title "A New Species of Mud Turtle of Genus Kinosternon (Testudines: Kinosternidae) from the Pacific Coastal Plain of Northwestern Mexico" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4296904>, <http://dx.doi.org/10.5281/zenodo.4296910>, <http://dx.doi.org/10.5281/zenodo.4296906>, <http://dx.doi.org/10.5281/zenodo.4296908>, <http://dx.doi.org/10.5281/zenodo.4296912>, <http://dx.doi.org/10.5281/zenodo.4296916>, <http://dx.doi.org/10.5281/zenodo.4296918>, <http://dx.doi.org/10.5281/zenodo.4296920> ;
