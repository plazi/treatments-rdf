    dc:creator "Barquez, Rubén M", "Boero, Lourdes", "Díaz, M Mónica", "Rodriguez, Alejandro Daniel", "Sánchez, R Tatiana", "Tomasco, Ivanna H" ;
    dc:date "2023" ;
    dc:title "A new species of bat in the genus Nyctinomops Miller, 1902 (Chiroptera: Molossidae) from Misiones, Argentina" ;
    bibo:endPage "1071" ;
    bibo:issue "5" ;
    bibo:journal "Journal of Mammalogy" ;
    bibo:pubDate "2023-07-04" ;
    bibo:startPage "1062" ;
    bibo:volume "104" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.10266225>, <http://dx.doi.org/10.5281/zenodo.10266227>, <http://dx.doi.org/10.5281/zenodo.10266233>, <http://dx.doi.org/10.5281/zenodo.10266235>, <http://dx.doi.org/10.5281/zenodo.10266237>, <http://dx.doi.org/10.5281/zenodo.10266243> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.10266225>
    dc:description "Fig. 1.—A) Map of ecoregions and known distribution points for the three species of Nyctinomops from Argentina: N. laticaudatus (triangles), N. macrotis (circles), and N. new sp. (star); B) roost of Nyctinomops new sp. in a deep crevice in the rock cliffs; C) strip of land between the rock wall and the river bank, where the mist nets were placed." ;
    fabio:hasRepresentation "https://zenodo.org/record/10266225/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10266227>
    dc:description "Fig. 2.—Scatter plot of the two principal components of eight cranial measurements of two specimens of the new species of Nyctinomops (crosses) compared with the four known species of the genus: triangles = N. laticaudatus; dots = N. aurispinosus; star = N. femorosaccus; squares = N. macrotis; crosses = N. new sp." ;
    fabio:hasRepresentation "https://zenodo.org/record/10266227/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10266233>
    dc:description "Fig. 4.—Dorsal and ventral views of the skin of the holotype of Nyctinomops mbopicuare (CML 14170). Scale bar = 10 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10266233/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10266235>
    dc:description "Fig. 6.—Frontal viewof aliving specimenofNyctinomops mbopicuare." ;
    fabio:hasRepresentation "https://zenodo.org/record/10266235/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10266237>
    dc:description "Fig. 5.—Lateral view of the skull and mandible (top), dorsal (bottom left), and ventral (bottom right) views of skull of the holotype of Nyctinomops mbopicuare (CML 14170). Scale bar = 5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10266237/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10266243>
    dc:description "Fig. 7.—Top row: dorsal view of skulls of the three species of Nyctinomops known from Argentina: N. laticaudatus (CML 1913); N. mbopicuare (CML 14170); and N. macrotis (CML 1082). Bottom row: ventral view of the mandible of N. laticaudatus (CML 1913); N. mbopicuare (CML 14170); and N. macrotis (CML 1082) showing the difference in development of the process located at the symphysis. Scale bar = 5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/10266243/files/figure.png" ;
    a fabio:Figure .

