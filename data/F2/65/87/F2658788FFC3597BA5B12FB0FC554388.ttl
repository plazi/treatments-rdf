    dc:title "Microlicia indurata (Melastomataceae: Lavoisiereae), a new narrow endemic from Serra dos Pireneus, Goiás, Brazil" ;
    bibo:endPage "292" ;
    bibo:issue "4" ;
    bibo:journal "Phytotaxa" ;
