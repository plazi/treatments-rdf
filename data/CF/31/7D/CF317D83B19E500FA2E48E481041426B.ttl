    dc:date "2020" ;
    dc:title "A new species of Laoennea microsnail (Stylommatophora, Diapheridae) from a cave in Laos" ;
    fabio:hasPart <http://dx.doi.org/10.3897/subtbiol.36.58977.figure1>, <http://dx.doi.org/10.3897/subtbiol.36.58977.figure3> ;
