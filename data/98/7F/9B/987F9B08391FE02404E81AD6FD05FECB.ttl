    dc:title "Oncelytris esquamatus gen. et sp. nov. from mid-Cretaceous amber of northern Myanmar (Coleoptera: Lucanidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7918880>, <http://dx.doi.org/10.5281/zenodo.7918882>, <http://dx.doi.org/10.5281/zenodo.7918884> ;
