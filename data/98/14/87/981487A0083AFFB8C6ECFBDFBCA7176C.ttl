    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.257167>
    dc:description "FIGURE 5. Collection site of Hypostomus leucophaeus, rio Itapicuru, Fazenda Coqueiro, Conde, Bahia, Brazil." ;
