    dc:creator "Lisi, Oscar; Sabella, Giorgio; Pilato, Giovanni" ;
    dc:title "Mixibius parvus Lisi, Sabella & Pilato, 2014, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Mixibius_parvus_Lisi_2014> ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.3802.4.3> ;
