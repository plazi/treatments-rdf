    dc:title "Anthrenus (Helocerus) cechovskyi Háva & Kadej, 2015, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Anthrenus_cechovskyi_H%C3%A1va_2015> ;
