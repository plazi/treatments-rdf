    dc:title "Stenorhamphus phuphan Smith & Hwang & Weirauch 2019, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/DC5787F2FFD5FA76FC3F8013FB8CF894.mc.E4963CB9FFD7FA76FCD781EFFB61FA14> ;
