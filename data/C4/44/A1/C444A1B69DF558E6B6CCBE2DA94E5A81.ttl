    cito:cites <http://dx.doi.org/10.3897/zse.97.57968.figure10>, <http://dx.doi.org/10.3897/zse.97.57968.figure11>, <http://dx.doi.org/10.3897/zse.97.57968.figure1> ;
    dc:creator "Gorin, Vladislav A.; Scherz, Mark D.; Korost, Dmitriy V.; Poyarkov, Nikolay A." ;
    dc:title "Nanohyla Poyarkov, Gorin & Scherz 2021, gen. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Nanohyla_Poyarkov_2021> ;
