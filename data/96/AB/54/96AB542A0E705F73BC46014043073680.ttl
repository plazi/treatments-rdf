    dc:date "2023" ;
    dc:title "New record and dietary ecology of a poorly known frog, Amolops shihaitaoi Wang, Li, Du, Hou & Yu, 2022 (Amphibia, Anura, Ranidae), from Ha Giang Province, Vietnam" ;
    bibo:endPage "104316" ;
    bibo:journal "Biodiversity Data Journal" ;
    bibo:pubDate "2023-05-11" ;
    bibo:startPage "104316" ;
