    dc:title "Cyrtodactylus hutchinsoni Oliver & Karkkainen & Richards 2021, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/96639F7BFFD6FFACAACCFB75FE2E6798.mc.AEA22430FFD6FFAAAACCFAC9FE6263D0> ;
