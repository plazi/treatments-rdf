    bibo:volume "2030" ;
    dc:creator "Fontoura, Paulo; Pilato, Giovanni; Lisi, Oscar; Morais, Paulo" ;
    dc:date "2009" ;
    dc:title "Tardigrades from Portugal: four new records and description of two new species" ;
