    dc:title "Typhloelmis finegan Barr & Gibson & Diaz 2015, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/DD05DA243464E963A895654D5885F9D7.mc.E5C4616F3464E962A92D658B58D7FCED> ;
