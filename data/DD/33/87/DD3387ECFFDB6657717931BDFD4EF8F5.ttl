    dc:date "1994" ;
    dc:title "A revision of the genus Uromys Peters, 1867 (Muridae: Mammalia) with descriptions of two new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4654703>, <http://dx.doi.org/10.5281/zenodo.4658476> ;
