    dc:creator "Joele, Flávia R.; Rezende, Uiara C.; Samacá-Sáenz, Ernesto; Cardoso, João C. F.; Oliveira, Denis C.; Zaldívar-Riverón, Alejandro" ;
    dc:title "Allorhogas uberlandiensis Joele & Zaldivar-Riveroni 2019, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/CE3687BCFFAFFFF54558FE34FBA43929.mc.F6F73CF7FFADFFFB45CFFCE1FB57398F>, <http://tb.plazi.org/GgServer/dwcaRecords/CE3687BCFFAFFFF54558FE34FBA43929.mc.F6F73CF7FFADFFFB44F9FC49FC363E34> ;
