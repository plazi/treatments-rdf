    dc:creator "Aalbu, Rolf L.; Kanda, Kojun; Merkl, Otto; Ivie, Michael A.; Johnston, M. Andrew" ;
    dc:title "Plastica Aalbu, Kanda, Merkl, Ivie & Johnston, 2023, stat. rev." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Phobeliina_Aalbu_2023> ;
