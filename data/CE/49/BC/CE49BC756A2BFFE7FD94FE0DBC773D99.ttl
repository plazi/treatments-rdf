    dc:title "Land snail genus Sarika Godwin-Austen, 1907 (Eupulmonata: Ariophantidae) from Cambodia, with description of three new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.3908383>, <http://dx.doi.org/10.5281/zenodo.3908385>, <http://dx.doi.org/10.5281/zenodo.3908387>, <http://dx.doi.org/10.5281/zenodo.3908389>, <http://dx.doi.org/10.5281/zenodo.3908377> ;
