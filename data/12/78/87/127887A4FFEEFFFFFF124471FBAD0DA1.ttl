    dc:title "Lutosa horribilis Heleodoro & Mendes, 2016, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/127887A4FFEEFFFFFF124471FBAD0DA1.mc.2AB93CEFFFEEFFF9FF1244EDFC8C0D8F> ;
