    dc:title "Revision of the genus Leptobatopsis Ashmead, 1900 (Hymenoptera, Ichneumonidae, Banchinae) from Japan, with some taxonomic notes of Asian species" ;
    bibo:endPage "426" ;
    bibo:issue "5" ;
