    dc:creator "Yasunaga, Tomohide; Yamada, Kazutaka; Duwal, Ram Keshari" ;
    dc:title "Orius (Orius) ekaii Yasunaga & Yamada & Duwal 2019, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/3B55375F940AFFE9FC39FF743E3839CD.mc.03948C14940AFFEFFC38FEAD3E26398A> ;
