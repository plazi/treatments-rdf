    a fabio:Figure .

<http://dx.doi.org/10.3897/dez.70.108096.figure2>
    dc:description "Figure 2. Male adult of D. pseudopoda sp. nov.: A. Head (ventral view); B. Oral region (ventral view); C. Flagellomeres; D. Foreleg; E. Midleg; F. hindleg; G. Terminalia (dorsal view). Abbreviations: cp, median clypeal lobe; pd, pedicel; fl, flagellomere; or, oral region; mt, mental tooth; pg, postgena; co, coxa; tr, trochanter; fe, femur; tb, tibia; ts, tarsomere; em, empodium; dp, dorsal plate; gc, gonocoxite; gs, gonostylus; ad, aedeagus. Scale bars: 0.1 mm (A, C, G); 0.05 mm (B); 0.5 mm (D-F)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/925434" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/dez.70.108096.figure6>
    dc:description "Figure 6. Male adult of D. pachychaeta sp. nov.: A. Head (ventral view); B. Oral region (ventral view); C. Flagellomeres; D. Foreleg; E. Midleg; F. Hindleg; G. Terminalia (dorsal view). Scale bars: 0.1 mm (A, C, G); 0.05 mm (B); 0.5 mm (D-F)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/925438" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/dez.70.108096.figure7>
    dc:description "Figure 7. Female adult of D. pachychaeta sp. nov.: A. Head (ventral view); B. Foreleg; C. Midleg; D. Hindleg. Scale bars: 0.1 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/925439" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/dez.70.108096.figure8>
    dc:description "Figure 8. Pupae of D. pachychaeta sp. nov.: A. Male pupa (dorsal view); B. Male pupa (ventral view); C. Female pupa (dorsal view); D. Female pupa (ventral view). Scale bars: 1.0 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/925440" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/dez.70.108096.figure9>
    dc:description "Figure 9. Male pupa of D. pachychaeta sp. nov.: A. Thoracic spine (dorsal view); B. Gill (ventral view). Scale bar: 0.1 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/925441" ;
