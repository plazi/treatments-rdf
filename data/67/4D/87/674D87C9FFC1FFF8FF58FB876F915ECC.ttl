    dc:title "The genus Odontothrips in Iran with two new species (Thysanoptera: Thripidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6450821>, <http://dx.doi.org/10.5281/zenodo.6450825>, <http://dx.doi.org/10.5281/zenodo.6450827> ;
