    cito:cites <http://dx.doi.org/10.3897/subtbiol.41.76926.figure1>, <http://dx.doi.org/10.3897/subtbiol.41.76926.figure2>, <http://dx.doi.org/10.3897/subtbiol.41.76926.figure3>, <http://dx.doi.org/10.3897/subtbiol.41.76926.figure4> ;
    dc:creator "Nilsai 1, Areeruk; Detcharoen 1, Matsapume; Godeiro 2, Nerivania Nunes; Jantarit 3, Sopark" ;
    dc:title "Coecobrya whitteni Nilsai & Jantarit 2021, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Coecobrya_whitteni_Nilsai_2021> ;
