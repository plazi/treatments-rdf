    dc:description "FIGURE 5. Podotarsonemus australiensis sp. nov. (A) female, tibiotarsus I; (B) female, tarsus II; (C) male, tibia and tarsus I." ;
    fabio:hasRepresentation "https://zenodo.org/record/1242445/files/figure.png" ;
