    dc:creator "Vandenberg, Natalia J.; Hanson, Paul E." ;
    dc:title "Moiradiomus Vandenberg & Hanson 2019, gen. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Plantae/Moiradiomus_Vandenberg_2019> ;
