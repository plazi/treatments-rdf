    dc:title "Contribution to the knowledge of cotylean flatworms (Turbellaria, Polycladida) from Iranian coasts: Introducing a new species, with remarks on new records" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.249709>, <http://dx.doi.org/10.5281/zenodo.249710>, <http://dx.doi.org/10.5281/zenodo.249708>, <http://dx.doi.org/10.5281/zenodo.249715>, <http://dx.doi.org/10.5281/zenodo.249717> ;
