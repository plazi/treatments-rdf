    dc:creator "Plisko, Jadwiga Danuta" ;
    dc:date "2013" ;
    dc:title "A new family Tritogeniidae for the genera Tritogenia and Michalakus, earlier accredited to the composite Microchaetidae (Annelida: Oligochaeta)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7649569>, <http://dx.doi.org/10.5281/zenodo.7649571>, <http://dx.doi.org/10.5281/zenodo.7649573>, <http://dx.doi.org/10.5281/zenodo.7649563> ;
