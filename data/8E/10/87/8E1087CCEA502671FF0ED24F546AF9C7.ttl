    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8255386>
    dc:description "FIGURE 4. Live specimen of Moenkhausia guaruba, MZUSP 119389, paratype, SL uncertain, Brazil, Pará, Novo Progresso, rio Braço Norte, rio Tapajós basin." ;
