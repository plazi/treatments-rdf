    dc:creator "Babaran, Ricardo P.", "Barnuevo, Kyle Dominic E.", "Cabebe-Barnuevo, Roxanne A.", "Cadiz, Rowena E.", "Labrador, Hannah Kathleen S.", "Lumayno, Sanny David P." ;
    dc:date "2023" ;
    dc:title "Infection parameters of Norileca indica and a new record of Ceratothoa carinata (Crustacea: Isopoda: Cymothoidae) on Selar crumenophthalmus (Actinopterygii: Carangiformes: Carangidae) in the waters of the Sibuyan Sea, the Philippines" ;
    bibo:endPage "155" ;
    bibo:journal "Acta Ichthyologica et Piscatoria" ;
    bibo:pubDate "2023-10-06" ;
    bibo:startPage "147" ;
    bibo:volume "53" ;
    fabio:hasPart <http://dx.doi.org/10.3897/aiep.53.108918.figure4>, <http://dx.doi.org/10.3897/aiep.53.108918.figure5> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.3897/aiep.53.108918.figure4>
    dc:description "Figure 4. Non-ovigerous female (SC 005) Ceratothoa carinata collected from the buccal cavity of Selar crumenophthalmus captured in the Sibuyan Sea, Philippines in April 2021 (A = dorsal view; B = ventral view)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/917544" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/aiep.53.108918.figure5>
    dc:description "Figure 5. Neighbor-joining method used to estimate the phylogenetic relations among Cymothoidae based on mitochondrial CO 1 sequence. Bootstrap probabilities are indicated near the nodes. Penaeus merguiensis AF 279838 was used as outgroup." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/917545" ;
    a fabio:Figure .

