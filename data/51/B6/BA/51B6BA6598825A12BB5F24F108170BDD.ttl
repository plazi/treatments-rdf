    dc:title "A new genus and five new species of pseudoscorpions (Arachnida, Pseudoscorpiones, Withiidae) from Colombia" ;
    bibo:endPage "326" ;
    bibo:journal "ZooKeys" ;
    bibo:pubDate "2023-11-22" ;
    bibo:startPage "301" ;
    bibo:volume "1184" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.1184.106698.figure1>, <http://dx.doi.org/10.3897/zookeys.1184.106698.figure10>, <http://dx.doi.org/10.3897/zookeys.1184.106698.figure11>, <http://dx.doi.org/10.3897/zookeys.1184.106698.figure2>, <http://dx.doi.org/10.3897/zookeys.1184.106698.figure8>, <http://dx.doi.org/10.3897/zookeys.1184.106698.figure9> ;
