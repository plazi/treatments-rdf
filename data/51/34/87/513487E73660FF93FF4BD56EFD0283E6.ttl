    cito:cites <http://dx.doi.org/10.5281/zenodo.203246>, <http://dx.doi.org/10.5281/zenodo.203247>, <http://dx.doi.org/10.5281/zenodo.203248> ;
    dc:creator "Sites, Robert W.; Zettel, Herbert" ;
    dc:title "Pogonocaudina Sites and Zettel, NEW GENUS" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Pogonocaudina_Zettel_2011> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.203245> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.203245>
    bibo:endPage "17" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "1" ;
    bibo:volume "2760" ;
    dc:creator "Sites, Robert W.; Zettel, Herbert" ;
    dc:date "2011" ;
    dc:title "Waterfall-inhabiting Naucoridae (Hemiptera: Heteroptera) of southern India and Sri Lanka: Pogonocaudina Sites and Zettel, n. gen., and a review of Diaphorocoris with descriptions of two new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.203246>, <http://dx.doi.org/10.5281/zenodo.203247>, <http://dx.doi.org/10.5281/zenodo.203248> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.203246>
    dc:description "FIGURES 1 – 3. Features of Pogonocaudina, n. gen.: (1) habitus (dry specimen), (2) single segmented front tarsus with paired claws of male appressed to anterior margin of femur, (3) dense fringe of long setae on outer margin of posterior abdominal segments (specimen in alcohol)." ;
    fabio:hasRepresentation "https://zenodo.org/record/203246/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.203247>
    dc:description "FIGURES 4 – 5. (4) Kiliyur Waterfall, the type locality of Pogonocaudina indica n. sp. and Diaphorocoris kiliyur n. sp., (5) habitat of Pogonocaudina indica n. sp., Diaphorocoris arunachalami n. sp. and Diaphorocoris kiliyur n. sp." ;
    fabio:hasRepresentation "https://zenodo.org/record/203247/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.203248>
    dc:description "FIGURE 6. Live specimen of Pogonocaudina indica n. sp." ;
    fabio:hasRepresentation "https://zenodo.org/record/203248/files/figure.png" ;
    a fabio:Figure .

