    dc:date "2019" ;
    dc:title "Mesoparasitic copepods (Copepoda: Cyclopoida) associated with polychaete worms in European seas" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2637495>, <http://dx.doi.org/10.5281/zenodo.2637493>, <http://dx.doi.org/10.5281/zenodo.2637491> ;
