    dc:creator "Doan, Tiffany M.; Lamar, William W." ;
    dc:date "2012" ;
    dc:title "A new montane species of Cercosaura (Squamata: Gymnophthalmidae) from Colombia, with notes on the distribution of the genus" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.208568>, <http://dx.doi.org/10.5281/zenodo.208569>, <http://dx.doi.org/10.5281/zenodo.208571>, <http://dx.doi.org/10.5281/zenodo.208570>, <http://dx.doi.org/10.5281/zenodo.208572> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.208568>
    dc:description "FIGURE 1. — Holotype of Cercosaura hypnoides (UTA R- 60249) in life." ;
    fabio:hasRepresentation "https://zenodo.org/record/208568/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.208569>
    dc:description "FIGURE 2. — Holotype of adult Cercosaura hypnoides (UTA R- 60249). Top left: dorsal head view; top middle: ventral head view; bottom left: lateral head view; right: ventral body view. Scale bars = 5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/208569/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.208571>
    dc:description "FIGURE 4. — Relief map of Colombia with type locality of Cercosaura hypnoides indicated by a red square. (Base map courtesy of mapsof. net)" ;
    fabio:hasRepresentation "https://zenodo.org/record/208571/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.208570>
    dc:description "FIGURE 3. — Paratype of juvenile Cercosaura hypnoides (UTA R- 60248) in life." ;
    fabio:hasRepresentation "https://zenodo.org/record/208570/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.208572>
    dc:description "FIGURE 5. — (A) Vereda de Portachuelo, Meta, Colombia, the type locality; (B) view across the gorge taken from the type locality itself, where the vegetation borders the clearing. Epiphytic growth can be seen." ;
    fabio:hasRepresentation "https://zenodo.org/record/208572/files/figure.png" ;
    a fabio:Figure .

