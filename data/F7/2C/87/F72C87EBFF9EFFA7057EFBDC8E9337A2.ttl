    dc:creator "Radashevsky, Vasily I.; Lana, Paulo C.; Nalesso, Rosebel C." ;
    dc:title "Polydora haswelli Blake & Kudenov 1978" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Polydora_haswelli_Blake_1978> ;
