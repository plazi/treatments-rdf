treatment:3E4EC554FFB7FF84FE0AFD1FD9CCFE04
    cito:cites <http://taxon-concept.plazi.org/id/Animalia/Sphecidae_Latreille_1802>, <http://taxon-concept.plazi.org/id/Animalia/Sceliphron_Klug_1801>, <http://taxon-concept.plazi.org/id/Animalia/Prionyx_Sphecinae_1827>, <http://taxon-concept.plazi.org/id/Animalia/Prionyx_Linden_1827>, <http://dx.doi.org/10.5281/zenodo.4632169>, <http://dx.doi.org/10.5281/zenodo.4632167>, <http://dx.doi.org/10.5281/zenodo.4632165> ;
    dc:creator "Buys, Sandor Christiano" ;
    dc:title "Sceliphron fistularium" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Sceliphron_fistularium_Dahlbom_1843> ;
    trt:deprecates <http://taxon-concept.plazi.org/id/Animalia/Penepodium_luteipenne_Fabricius_1804> ;
    trt:publishedIn <http://dx.doi.org/10.1080/00222933.2013.802385> ;
    a trt:Treatment .

<http://dx.doi.org/10.1080/00222933.2013.802385>
    bibo:endPage "386" ;
    bibo:issue "7 - 8" ;
    bibo:journal "Journal of Natural History" ;
    bibo:pubDate "2013-08-13" ;
    bibo:startPage "375" ;
    bibo:volume "48" ;
    dc:creator "Buys, Sandor Christiano" ;
    dc:date "2013" ;
    dc:title "Morphology of the last instar larvae of Sceliphron asiaticum (Linnaeus, 1758) and S. fistularium (Dahlbom, 1843), with a review on larval characters in Sceliphrinae (Hymenoptera: Sphecidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4632169>, <http://dx.doi.org/10.5281/zenodo.4632167>, <http://dx.doi.org/10.5281/zenodo.4632165> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.4632169>
    dc:description "Figures 13–19. Last instar larva of Sceliphron fistularium, scanning electron micrographs: (13) pore in the labrum; (14) sensila in the labrum; (15) marginal portion of the clypeus; (16) marginal portion of the epipharynx; (17) base of the epipharynx, showing sensilae; (18) maxillary palpus, apical portion; (19), labial palpus, apical portion." ;
    fabio:hasRepresentation "https://zenodo.org/record/4632169/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4632167>
    dc:description "Figures 7–12. Last instar larva of Sceliphron fistularium, scanning electron micrographs: (7) frontal view of the head (AO = antennal orbit, Lb = labrum, La = labium, Ma = mandible, Mx = maxilla); (8) oral portion of the head (MT2 = second mandibular tooth, other legends as in Figure 7); (9) antennal orbits; (10) labium, median portion, dorsal view; (11) labium, ventral/frontal view; (12) lips of the spinneret." ;
    fabio:hasRepresentation "https://zenodo.org/record/4632167/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4632165>
    dc:description "Figures 1–6. Last instar larva of Sceliphron asiaticum: (1) body, lateral view; (2) labrum/epipharynx, frontal view (between microscope slides). Last instar larva of Sceliphron fistularium: (3) body, lateral view; (4) labrum/epipharynx, frontal view" ;
    fabio:hasRepresentation "https://zenodo.org/record/4632165/files/figure.png" ;
    a fabio:Figure .

