    cito:cites <http://dx.doi.org/10.3897/zookeys.683.12080.figures46–54>, <http://dx.doi.org/10.3897/zookeys.683.12080.figures103–105> ;
    dc:creator "Anzaldo, Salvatore S." ;
    dc:title "Zygopsella Champion 1906" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Zygopsella_Champion_1906> ;
    trt:publishedIn <http://dx.doi.org/10.3897/zookeys.683.12080> ;
