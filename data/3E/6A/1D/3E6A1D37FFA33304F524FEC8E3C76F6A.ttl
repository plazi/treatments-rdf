    dc:date "2017" ;
    dc:title "A new species of the genus Typhlocharis Dieck, 1869 (Coleoptera, Carabidae) from Portugal" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1040830>, <http://dx.doi.org/10.5281/zenodo.1040828>, <http://dx.doi.org/10.5281/zenodo.1040832> ;
