    dc:creator "Beretta, Mario", "Bonelli, Marco", "Caccianiga, Marco", "Eustacchio, Elena", "Federici, Germano", "Gallo, Guido Roberto", "Gianfranceschi, Luca", "Mangili, Federico", "Mangili, Luca", "Perico, Giovanni", "Traini, Myriam", "Valle, Barbara", "Zanzottera, Alice" ;
    dc:date "2024" ;
    dc:title "Campanula bergomensis (Campanulaceae), a new species from Bergamo Prealps (Northern Italy)" ;
    bibo:endPage "132" ;
    bibo:issue "2" ;
    bibo:journal "Phytotaxa" ;
    bibo:pubDate "2024-02-20" ;
    bibo:startPage "120" ;
