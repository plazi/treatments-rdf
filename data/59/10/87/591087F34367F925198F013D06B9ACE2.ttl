    bibo:startPage "51" ;
    bibo:volume "2750" ;
    dc:creator "Polaszek, Andrew; Gill, Raymond" ;
    dc:date "2011" ;
    dc:title "A new species of whitefly (Hemiptera: Aleyrodidae) and its parasitoid (Hymenoptera: Aphelinidae) from desert lavender in California" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.203138>, <http://dx.doi.org/10.5281/zenodo.203139> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.203138>
    dc:description "FIGURE 1. Aleuropleurocelus hyptisemoryi. Left side of puparium showing anatomical details of holotype, depicting relatively shallow development of projections as seen in younger specimens and specimens from the type locality and elsewhere." ;
    fabio:hasRepresentation "https://zenodo.org/record/203138/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.203139>
    dc:description "FIGURE 2. Aleuropleurocelus hyptisemoryi. Left side of puparium showing anatomical details of a paratype, depicting advanced development of conical projections around the false margin as found in some specimens from the collection at the Living Desert Museum, Palm Desert, Riverside County, California." ;
    fabio:hasRepresentation "https://zenodo.org/record/203139/files/figure.png" ;
    a fabio:Figure .

