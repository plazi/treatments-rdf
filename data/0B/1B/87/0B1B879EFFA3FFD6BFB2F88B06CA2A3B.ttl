    bibo:startPage "395" ;
    bibo:volume "5175" ;
    dc:creator "Higgins, Kathleen; Ibáñez, Roberto" ;
    dc:date "2022" ;
    dc:title "Description of two dendrobatid tadpoles (Anura: Dendrobatidae: Andinobates and Oophaga) with comments on egg clutches" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7003722>, <http://dx.doi.org/10.5281/zenodo.7003724> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.7003722>
    dc:description "FIGURE 1. (a) Tadpole of Andinobates geminisae at Stage 28, oral apparatus and left lateral view; (b) Tadpole of Oophaga vicentei, combining the body shape at Stage 33 and the oral disc of a Stage 41 specimen to show the highest LTRF 1/1. Scale bars = 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/7003722/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.7003724>
    dc:description "FIGURE 2. Stage 41 tadpoles of (a) preserved Andinobates geminisae and (b) live Oophaga vicentei and ≤ 3 Stage eggs of (c) A. geminisae and (d) O. vicentei. Scale bars = 10 mm (a,b) and 5 mm (c,d)." ;
    fabio:hasRepresentation "https://zenodo.org/record/7003724/files/figure.png" ;
    a fabio:Figure .

