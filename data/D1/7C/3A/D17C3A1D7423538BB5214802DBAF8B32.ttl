    dc:date "2023" ;
    dc:title "A new species of the Cyrtodactylus brevipalmatus group (Squamata, Gekkonidae) from Tak Province, northwestern Thailand" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.1164.101263.figure4>, <http://dx.doi.org/10.3897/zookeys.1164.101263.figure5>, <http://dx.doi.org/10.3897/zookeys.1164.101263.figure6>, <http://dx.doi.org/10.3897/zookeys.1164.101263.figure1>, <http://dx.doi.org/10.3897/zookeys.1164.101263.figure7> ;
