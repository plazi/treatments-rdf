    dc:title "Re-descriptions of eight chigger mite species (Acariformes: Trombiculidae) of the Leptotrombidium generic complex from Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5591559>, <http://dx.doi.org/10.5281/zenodo.5591561>, <http://dx.doi.org/10.5281/zenodo.5591563> ;
