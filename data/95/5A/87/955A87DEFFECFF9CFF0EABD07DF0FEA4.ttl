    dc:creator "Lehr, Edgar; Catenazzi, Alessandro" ;
    dc:title "Bryophryne nubilosus Lehr & Catenazzi, 2008, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Bryophryne_nubilosus_Lehr_2008> ;
