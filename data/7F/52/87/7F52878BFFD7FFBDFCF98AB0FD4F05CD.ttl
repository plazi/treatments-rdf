    dc:creator "Foissner, Wilhelm", "Kumar, Santosh", "Quintela-Alonso, Kuidong Xu and Pablo", "Wolf, Klaus W." ;
    dc:date "2014" ;
    dc:title "Five New Spathidiids (Ciliophora: Bromeliads Haptoria) from Caribbean Tank" ;
    bibo:endPage "194" ;
    bibo:journal "Acta Protozoologica" ;
    bibo:startPage "159" ;
