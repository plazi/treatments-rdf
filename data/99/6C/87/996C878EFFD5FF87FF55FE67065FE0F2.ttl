    dc:creator "Koeda, Keita; Yoshino, Tetsuo; Tachihara, Katsunori" ;
    dc:title "Pempheris ufuagari" ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.3609.2.9> ;
