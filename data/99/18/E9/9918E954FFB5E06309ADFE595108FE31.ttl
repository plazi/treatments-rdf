    dc:date "2004" ;
    dc:title "New Species Of Amynthas, Pheretima And Pleionogaster (Clitellata: Megascolecidae) Of The Mt. Kitanglad Range, Mindanao Island, Philippines" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4618927> ;
