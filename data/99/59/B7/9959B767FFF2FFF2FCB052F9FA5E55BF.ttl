    dc:date "2016" ;
    dc:title "Jumping Plant Lice of the genus Calophya (Hemiptera: Calophyidae) in Mexico" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.247285>, <http://dx.doi.org/10.5281/zenodo.247289>, <http://dx.doi.org/10.5281/zenodo.247290> ;
