    dc:creator "Bank, Sarah", "Bradler, Sven", "Cumming, Royce T.", "Eulin, Norman Enrico C.", "Foley, Evelyn Marie", "Lavado, Ramon", "Le Tirant, Ste ́ phane", "Linde, Jackson B.", "Solan, Megan E.", "Whiting, Michael F." ;
    dc:date "2023" ;
    dc:title "On seven undescribed leaf insect species revealed within the recent \" Tree of Leaves \" (Phasmatodea, Phylliidae)" ;
    bibo:endPage "229" ;
    bibo:journal "ZooKeys" ;
    bibo:pubDate "2023-08-03" ;
