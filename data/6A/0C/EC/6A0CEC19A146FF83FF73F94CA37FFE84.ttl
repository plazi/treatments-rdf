    dc:creator "Hall, Jason P. W.; Lamas, Gerardo" ;
    dc:date "2007" ;
    dc:title "Four new symmachiine taxa from the eastern Andes of Peru and Ecuador (Lepidoptera: Riodinidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.177752>, <http://dx.doi.org/10.5281/zenodo.177753> ;
