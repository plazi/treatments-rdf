    dc:title "Rhacophorus dulitensis" ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.208711> ;
    trt:treatsTaxonName <http://taxon-name.plazi.org/id/Animalia/Rhacophorus_dulitensis> ;
