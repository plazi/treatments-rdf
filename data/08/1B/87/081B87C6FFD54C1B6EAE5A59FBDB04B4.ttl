    dc:creator "Brescovit, Antonio D.", "Bustamante, Abel A.", "Hagopián, Damián", "Marta, Kimberly S.", "Rodrigues, Everton N. L.", "Teixeira, Renato A.", "Valiati, Victor H." ;
    dc:date "2024" ;
    dc:title "Taxonomic revision of the jumping spider genus Tullgrenella Mello-Leitão, 1941 (Araneae: Salticidae: Freyina)" ;
    bibo:endPage "71" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
