    dc:date "2024" ;
    dc:title "Taxonomic revision of the jumping spider genus Tullgrenella Mello-Leitão, 1941 (Araneae: Salticidae: Freyina)" ;
    bibo:endPage "71" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
