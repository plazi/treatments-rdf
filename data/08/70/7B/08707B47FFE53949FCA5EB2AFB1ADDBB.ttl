    dc:title "Orphnebius (Deroleptus) protuberatus Assing 2017, spec. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/08707B47FFE53949FCA5EB2AFB1ADDBB.mc.30B1C00CFFE53952FC3CEBB0FAD3DE5B> ;
