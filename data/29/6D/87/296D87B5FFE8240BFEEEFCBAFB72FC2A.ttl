    dc:title "A Review of the Genera Dysanellus Bernhauer and Torobus Herman (Coleoptera: Staphylinidae: Staphylininae: Staphylinini)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5381966>, <http://dx.doi.org/10.5281/zenodo.5381970>, <http://dx.doi.org/10.5281/zenodo.5381972>, <http://dx.doi.org/10.5281/zenodo.5381978>, <http://dx.doi.org/10.5281/zenodo.5381986> ;
