    dc:creator "Marusik, Yuri M.", "Zamani, Alireza" ;
    dc:date "2023" ;
    dc:title "New species and records of Oecobius Lucas, 1846 (Araneae: Oecobiidae) from Iran and Azerbaijan" ;
    bibo:endPage "1709" ;
    bibo:issue "37 - 40" ;
    bibo:journal "Journal of Natural History" ;
