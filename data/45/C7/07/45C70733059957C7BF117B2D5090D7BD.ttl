    cito:cites <http://dx.doi.org/10.3897/zookeys.939.31764.figure5>, <http://dx.doi.org/10.3897/zookeys.939.31764.figure4>, <http://dx.doi.org/10.3897/zookeys.939.31764.figure7>, <http://dx.doi.org/10.3897/zookeys.939.31764.figure8> ;
    dc:creator "Li, Guogang; Lwin, Ye Htet; Yang, Bin; Qin, Tao; Phothisath, Phouthong; Maung, Kyaw-Win; Quan, Rui-Chang; Li, Song" ;
    dc:title "Biswamoyopterus sp. L 35" ;
    trt:publishedIn <http://dx.doi.org/10.3897/zookeys.939.31764> ;
    trt:treatsTaxonName <http://taxon-name.plazi.org/id/Animalia/Biswamoyopterus> ;
    a trt:Treatment .

<http://dx.doi.org/10.3897/zookeys.939.31764>
    bibo:endPage "85" ;
    bibo:journal "ZooKeys" ;
    bibo:startPage "65" ;
    bibo:volume "939" ;
    dc:creator "Li, Guogang; Lwin, Ye Htet; Yang, Bin; Qin, Tao; Phothisath, Phouthong; Maung, Kyaw-Win; Quan, Rui-Chang; Li, Song" ;
    dc:date "2020" ;
    dc:title "Taxonomic revision and phylogenetic position of the flying squirrel genus Biswamoyopterus (Mammalia, Rodentia, Sciuridae, Pteromyini) on the northern Indo-China peninsula" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.939.31764.figure5>, <http://dx.doi.org/10.3897/zookeys.939.31764.figure4>, <http://dx.doi.org/10.3897/zookeys.939.31764.figure7>, <http://dx.doi.org/10.3897/zookeys.939.31764.figure8> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.3897/zookeys.939.31764.figure5>
    dc:description "Figure 5. Comparison of ear tufts of all known Biswamoyopterus specimens. The red arrow indicates the anterior tufts, and the yellow arrow indicates the posterior tufts A B. biswasi, ZSI 20705 B B. gaoligongensis, KIZ 034924 A, B were derived from Li et al. (2019) C B. laoensis NUoL FES. MM. 12.163 from Sanamxay et al. (2013) D Biswamoyopterus sp. M 644 from this study." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/419811" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/zookeys.939.31764.figure4>
    dc:description "Figure 4. Comparison of skins of all known Biswamoyopterus specimens A, B B. biswasi, ZSI 20705 C, D B. gaoligongensis, KIZ 034924 A-D were derived from Li et al. (2019) E, F B. laoensis, NUoLFES. MM. 12.163, from Sanamxay et al. (2013) G, H Biswamoyopterus sp. M 644 from this study." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/419810" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/zookeys.939.31764.figure7>
    dc:description "Figure 7. The posterior margin of the palatal bones relative to the posterior margin of M 3 (dotted line) and shape of the preglenoid process (arrow) of all known Biswamoyopterus specimens A B. biswasi, ZSI 20705 B B. gaoligongensis, KIZ 034924) A, B were derived from Li et al. (2019) C B. laoensis, NUoL FES. MM. 12.163, from Sanamxay et al. (2013) D Biswamoyopterus sp. M 644 from this study." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/419813" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/zookeys.939.31764.figure8>
    dc:description "Figure 8. Bayesian Inference and Maximum Likelihood inference tree (GTR + G + I model) of flying squirrels based on combined mitochondrial and nuclear DNA data. Numbers on branches indicate posterior probability in BI and bootstrap support from ML." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/419814" ;
    a fabio:Figure .

