    dc:creator "Hansson, Christer; Schmidt, Stefan" ;
    dc:title "Euplectrus geometricida Hansson & Schmidt 2018, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Euplectrus_geometricida_Hansson_2018> ;
