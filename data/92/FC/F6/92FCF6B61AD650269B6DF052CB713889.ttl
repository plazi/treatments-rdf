    dc:date "2021" ;
    dc:title "Thirty-five new species of the spider genus Pimoa (Araneae, Pimoidae) from Pan-Himalaya" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.1029.64080.figure1>, <http://dx.doi.org/10.3897/zookeys.1029.64080.figure2> ;
