    dc:title "A new species of Lophostreptus Cook, 1895 discovered among syntypes of L. regularis Attems, 1909 (Diplopoda, Spirostreptida, Spirostreptidae)" ;
    bibo:endPage "274" ;
    bibo:journal "ZooKeys" ;
