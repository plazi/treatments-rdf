    dc:title "Three new species of the genus Neuquenaphis (Hemiptera, Aphididae, Spicaphidinae) from southernmost South America" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2656397>, <http://dx.doi.org/10.5281/zenodo.2656399>, <http://dx.doi.org/10.5281/zenodo.2656405> ;
