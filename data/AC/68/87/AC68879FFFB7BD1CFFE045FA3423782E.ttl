    dc:creator "Akhtar, Tariq A.", "Al-Abdul-Wahid, M. Sameer", "Casaretto, José A.", "Geddes-McAlister, Jennifer", "Rea, Kevin A", "Rothstein, Steven J.", "Sukumaran, Arjun" ;
    dc:date "2019" ;
    dc:title "Biosynthesis of cannflavins A and B from Cannabis sativa L" ;
