    dc:title "Detection of Prorocentrum shikokuense in the Mediterranean Sea and evidence that P. dentatum, P. obtusidens and P. shikokuense are three different species (Prorocentrales, Dinophyceae)" ;
    bibo:endPage "59" ;
    bibo:journal "Acta Protozoologica" ;
    bibo:pubDate "2022-02-14" ;
    bibo:startPage "47" ;
