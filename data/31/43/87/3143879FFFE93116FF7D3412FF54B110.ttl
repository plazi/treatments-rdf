treatment:3143879FFFE93116FF7D3412FF54B110
    cito:cites <http://dx.doi.org/10.5281/zenodo.181613>, <http://dx.doi.org/10.5281/zenodo.181614>, <http://dx.doi.org/10.5281/zenodo.181615>, <http://dx.doi.org/10.5281/zenodo.181616> ;
    dc:creator "Sanamyan, Karen; Hissmann, Karen" ;
    dc:title "Polycarpa urmeli Sanamyan & Hissmann, 2008, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Polycarpa_urmeli_Sanamyan_2008> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.181612> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.181612>
    bibo:endPage "49" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "41" ;
    bibo:volume "1744" ;
    dc:creator "Sanamyan, Karen; Hissmann, Karen" ;
    dc:date "2008" ;
    dc:title "A new stalked species of Polycarpa (Tunicata: Ascidiacea) from deeper waters of the tropical Western Pacific and in situ observations on sympatric species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.181613>, <http://dx.doi.org/10.5281/zenodo.181614>, <http://dx.doi.org/10.5281/zenodo.181615>, <http://dx.doi.org/10.5281/zenodo.181616> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.181613>
    dc:description "FIGURE 1. Polycarpa urmeli sp. nov. Images of living specimens in their natural environment. (A) Specimen with widely open branchial and atrial aperture; (B-D) various views through atrial aperture onto branchial sac and anus, and into peribranchial cavity; (E) view through the branchial aperture onto opening of the branchial sac surrounded by tentacles; (F) Specimen with second ascidian species attached to its dorsal surface; (G) small eel trapped between body wall and branchial sac of same specimen; (H) spider crab (Maiidae) and feather-star (Crinoidea) as epibionts." ;
    fabio:hasRepresentation "https://zenodo.org/record/181613/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.181614>
    dc:description "FIGURE 2. Polycarpa urmeli sp. nov. (A) Holotype opened along ventral mid line, branchial sac removed; (B) branchial tentacles, prepharyngeal band and dorsal tubercle; (C) neural gland, ganglion and dorsal tubercle as seen through transparent body wall from the outside; (D) gonad." ;
    fabio:hasRepresentation "https://zenodo.org/record/181614/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.181615>
    dc:description "FIGURE 3. Polycarpa urmeli sp. nov. (A) Formalin preserved specimen; (B) detail of the branchial sac between the most ventral fold and the endostyle; (C) dorsal lamina. (B and C – stained with toluydine blue)" ;
    fabio:hasRepresentation "https://zenodo.org/record/181615/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.181616>
    dc:description "FIGURE 4. Three stalked solitary ascidians from northern Indonesia. (A) Translucent specimen of unknown species; (B) Pterygascidia mirabilis; (C, D) specimen with enlarged oral siphon." ;
    fabio:hasRepresentation "https://zenodo.org/record/181616/files/figure.png" ;
    a fabio:Figure .

