    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.10281267>
    dc:description "FIGURE 3. Valeriana dacica. Left: Valeriana tripteris var. bijuga Simonkai (lectotype, BP); right: Valeriana tripteris var. carpatica Soó (lectotype, BP)." ;
