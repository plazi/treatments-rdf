    dc:title "Ophiotaenia lapata sp. n. (Eucestoda: Proteocephalidea) from Madagascar: a parasite of the endemic snake Madagascarophis colubrinus (Colubridae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6040102>, <http://dx.doi.org/10.5281/zenodo.6040104>, <http://dx.doi.org/10.5281/zenodo.6040106> ;
