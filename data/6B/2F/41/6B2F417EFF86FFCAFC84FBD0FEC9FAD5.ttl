    dc:creator "Bernonville, Thomas Dugé de", "Besseau, Sébastien", "Billet, Kévin", "Clastre, Marc", "Courdavault, Vincent", "Craene, Johan-Owen De", "Elejalde-Palmett, Carolina", "Giglioli-Guivarc'h, Nathalie", "Glévarec, Gaëlle", "Lanoue, Arnaud", "Pichon, Olivier", "St-Pierre, Benoit" ;
    dc:date "2019" ;
    dc:title "Genome-wide identification and biochemical characterization of the UGT 88 F subfamily in Malus x domestica Borkh" ;
    bibo:endPage "144" ;
