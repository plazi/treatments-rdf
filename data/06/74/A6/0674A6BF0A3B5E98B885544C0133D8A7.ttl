    dc:title "Apseudomorpha brasiliensis Segadilha & Serejo 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Apseudomorpha_brasiliensis_Segadilha_2020> ;
