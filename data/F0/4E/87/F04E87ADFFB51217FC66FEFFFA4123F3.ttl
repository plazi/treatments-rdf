    dc:date "2023" ;
    dc:title "Molecular-assisted taxonomic study on the Sargassum C. Agardh (Fucales, Phaeophyceae) in northwestern Luzon, Philippines" ;
    bibo:endPage "142" ;
    bibo:issue "7" ;
    bibo:journal "Cryptogamie, Algologie" ;
