    dc:title "The reinstatement of Rafflesia banaoana (Rafflesiaceae), and implications for assessing species diversity and conservation requirements of the world's largest flowers" ;
    bibo:endPage "216" ;
    bibo:issue "2" ;
    bibo:journal "Phytotaxa" ;
