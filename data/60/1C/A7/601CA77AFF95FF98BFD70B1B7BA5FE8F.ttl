    dc:creator "Chani-Posse, Mariana; Couturier, Guy" ;
    dc:title "Delgadobius amazonensis Chani-Posse & Couturier, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Plantae/Delgadobius_amazonensis_Chani-Posse_2012> ;
