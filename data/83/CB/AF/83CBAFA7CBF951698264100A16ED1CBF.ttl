    dc:title "New data on the longhorn beetles of Mongolia with particular emphasis on the genus Eodorcadion Breuning, 1947 (Coleoptera, Cerambycidae)" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.739.23675.figure3>, <http://dx.doi.org/10.3897/zookeys.739.23675.figure4>, <http://dx.doi.org/10.3897/zookeys.739.23675.figure10> ;
