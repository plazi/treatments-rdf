    dc:creator "Kong, Xiao-Yu", "Luo, Hai-Rong", "Munroe, Thomas A." ;
    dc:date "2023" ;
    dc:title "Re-evaluation of the taxonomic status of four nominal, western Pacific species of tongue soles (Pleuronectoidei: Cynoglossidae: Cynoglossus), with redescription of C. joyneri Günther, 1878" ;
    bibo:endPage "408" ;
    bibo:issue "3" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2023-10-27" ;
