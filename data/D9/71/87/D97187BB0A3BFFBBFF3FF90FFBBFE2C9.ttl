    dc:title "Revision of Ngirhaphium (Insecta: Diptera: Dolichopodidae), with the description of two new species from Singapore’s mangroves" ;
    bibo:endPage "160" ;
    bibo:journal "Raffles Bulletin of Zoology" ;
