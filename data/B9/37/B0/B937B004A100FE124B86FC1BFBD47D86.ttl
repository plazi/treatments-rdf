    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.8225937>
    dc:description "Figure 6. Characters of forewings in dorsal view. A, Lembeja papuensis; B, Gymnotympana varicolor; C, Chlorocysta vitripennis; D, Cystosoma schmeltzi; E, Cystopsaltria immaculata; F, Cystosoma saundersii; G, Hovana distanti; H, Thaumastopsaltria lanceola; I, Prasia culta; J, Iruana rougeoti. Scale: 2 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225937/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225956>
    dc:description "Figure 13. Lectotype (A) and paralectotype (B) male of Hemidictya frondosa (ZMHB) in dorsal and lateral view, respectively. Scale: 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225956/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225966>
    dc:description "Figure 16. Holotype male of Hovana distanti in dorsal (A) and lateral views (B), and pygofer in lateral view (C) (HNHM). Scale: 1 cm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225966/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225975>
    dc:description "Figure 20. A, holotype female of Lacetas annulicornis in dorsal (ZMHB); B, specimen female of Lacetas annulicornis in lateral view (ZMHB); C, pygofer in lateral view (NHMUK); D, specimen male in dorsal view (NHMUK). Scale: A, B = 5 mm; C = 1 mm; D = 20 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225975/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225977>
    dc:description "Figure 21. Syntype male of Lacetas longicollis in dorsal (A) and lateral view (B) (ZMHB); pygofer in lateral (C) and ventral views (D) (NHMUK); specimen male in dorsal view (E) (NHMUK). Scale: A, B = 5 mm; C and D = 1 mm; E = 20 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225977/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225925>
    dc:description "Figure 2. Characters of head and pronotum in dorsal view. A, Baeturia bicolorata; B, Chlorocysta vitripennis; C, Cystosoma saundersii; D, Hemidictya frondosa; E, Lacetas annulicornis; F, Iruana sulcata; G, Diemeniana hirsuta; H, Prasia culta. Scale: 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225925/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225979>
    dc:description "Figure 22. A, holotype male of Sapantanga nutans in dorsal view (NHMUK); pygofer in ventral (B) and lateral view (C) (NHMUK). Scale: A = 10 mm, B, C = 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225979/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225962>
    dc:description "Figure 14. Hemidictya frondosa (male). A, head, pronotum and mesonotum in dorsal view; B, operculum and meracanthus in ventral view; C, sternite VII in ventral view; D, forewing in dorsal view; E, pygofer in lateral view; F, aedeagus in frontal view; G, claspers in ventral view. Scale: A, D = 2 mm, B, C, E = 1 mm, F, G = 0.5 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225962/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.8225969>
    dc:description "Figure 17. Hovana distanti (male). A, head, pronotum and mesonotum in dorsal view; B, forewing in dorsal view; C, pygofer in lateral view. Scale: A, B = 2 mm, C = 1 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8225969/files/figure.png" ;
    a fabio:Figure .

