    dc:title "Geometridae (Lepidoptera) of the Baikal region: keys to species and an annotated catalogue. Part 1. Ennominae" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4694230>, <http://dx.doi.org/10.5281/zenodo.4694252>, <http://dx.doi.org/10.5281/zenodo.4694300> ;
