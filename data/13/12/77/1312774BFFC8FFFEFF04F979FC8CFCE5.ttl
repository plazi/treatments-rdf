    dc:creator "Machado, Angelo B. M." ;
    dc:title "Tuberculobasis guarani Machado, 2009, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Tuberculobasis_guarani_Machado_2009> ;
