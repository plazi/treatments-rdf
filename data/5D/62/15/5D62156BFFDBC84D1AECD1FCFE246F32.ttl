    dc:date "2018" ;
    dc:title "On spermatophore-producing aquatic microdrile oligochaetes (Annelida: Clitellata)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1451096>, <http://dx.doi.org/10.5281/zenodo.1451094> ;
