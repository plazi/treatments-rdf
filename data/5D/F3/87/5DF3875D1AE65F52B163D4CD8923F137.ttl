    dc:title "A new genus from Madagascar with strongly enlarged labium (Ephemeroptera, Baetidae)" ;
    fabio:hasPart <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure1>, <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure2>, <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure3>, <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure4>, <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure5>, <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure6>, <http://dx.doi.org/10.3897/afrinvertebr.62.73911.figure7> ;
