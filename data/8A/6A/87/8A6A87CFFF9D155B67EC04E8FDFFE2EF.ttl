    dc:title "Three new species of sea star parasite Dendrogaster (Crustacea: Thecostraca) from Japan" ;
    bibo:endPage "590" ;
    bibo:issue "4" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2024-02-01" ;
