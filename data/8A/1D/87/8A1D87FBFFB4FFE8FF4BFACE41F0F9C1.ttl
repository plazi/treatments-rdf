    dc:creator "Marshall, Stephen A." ;
    dc:date "2022" ;
    dc:title "Amapeza and Nigripeza, new genera of Neotropical micropezid flies (Diptera, Micropezidae, Taeniapterinae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5881148>, <http://dx.doi.org/10.5281/zenodo.5881160>, <http://dx.doi.org/10.5281/zenodo.5881152>, <http://dx.doi.org/10.5281/zenodo.5881156> ;
