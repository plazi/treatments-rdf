<https://binary.pensoft.net/fig/10795>
    dc:description "Figure 57. Holotype of Lepidium oblitum Houliston, Heenan et de Lange." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10795" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10796>
    dc:description "Figure 58. Wild plant of Lepidium oblitum showing growth habit of plant associated with Myosotidium hortensium, Disphyma papillatum and Festuca coxii in petrel colony on Mangere Island (image: G. A. S. Taylor)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10796" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10800>
    dc:description "Figure 62. Mature silicle of the holotype of Lepidium oblitum (AK 300342). Scale bar = 1 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10800" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10801>
    dc:description "Figure 63. Distribution of Lepidium oblitum, Lepidium oligodontum, Lepidium panniforme and Lepidium rekohuense." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10801" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10799>
    dc:description "Figure 61. A Upper stem leaves and inflorescence of Lepidium oblitum B flowers showing arrangement of sepals, petals, androecia and gynoecia C close-up of flower." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10799" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10797>
    dc:description "Figure 59. (From left to right) rosette and basal- to mid-stem leaves of Lepidium oblitum. (AK 300342). Scale bar = 20 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10797" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10798>
    dc:description "Figure 60. Cultivated plant of Lepidium oblitum showing rosette leaves." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10798" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10820>
    dc:description "Figure 82. Wild plant of Lepidium panniforme on Mangere Island showing growth habit (image: B. Gibb)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10820" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10821>
    dc:description "Figure 83. Vegetative stems and inflorescences of Lepidium panniforme." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10821" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10819>
    dc:description "Figure 81. Holotype of Lepidium panniforme de Lange et Heenan." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10819" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10822>
    dc:description "Figure 84. (From left to right) basal- and mid-stem leaves of Lepidium panniforme. Scale bar = 20 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10822" ;
    a fabio:Figure .

