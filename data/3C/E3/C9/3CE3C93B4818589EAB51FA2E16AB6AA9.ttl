    dc:title "Description of six new species of Xenorhina Peters, 1863 from southern Papua New Guinea (Amphibia, Anura, Microhylidae)" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zse.97.59696.figure10>, <http://dx.doi.org/10.3897/zse.97.59696.figure16>, <http://dx.doi.org/10.3897/zse.97.59696.figure11> ;
