    dc:creator "Edmonds, W. D." ;
    dc:date "2023" ;
    dc:title "Taxonomic review of the North American dung beetle genus Melanocanthon Halffter, 1958 (Coleoptera: Scarabaeidae: Scarabaeinae: Deltochilini)" ;
    bibo:endPage "28" ;
    bibo:issue "14" ;
    bibo:journal "Insecta Mundi" ;
