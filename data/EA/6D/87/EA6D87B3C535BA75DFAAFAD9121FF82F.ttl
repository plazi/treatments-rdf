    dc:title "Smittia solominae sp. nov. (Diptera: Chironomidae: Orthocladiinae), living on ice of high mountain glaciers of the Elbrus Region (North Caucasus)" ;
    bibo:endPage "569" ;
    bibo:issue "4" ;
