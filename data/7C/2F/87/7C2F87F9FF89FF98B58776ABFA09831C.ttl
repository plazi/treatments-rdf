    dc:title "Two new species of Thrypticus Gerstäcker from Turkey (Diptera, Dolichopodidae) with checklist and key to Palaearctic species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4411651>, <http://dx.doi.org/10.5281/zenodo.4411649>, <http://dx.doi.org/10.5281/zenodo.4411647>, <http://dx.doi.org/10.5281/zenodo.4411653>, <http://dx.doi.org/10.5281/zenodo.4411657>, <http://dx.doi.org/10.5281/zenodo.4411655>, <http://dx.doi.org/10.5281/zenodo.4411643> ;
