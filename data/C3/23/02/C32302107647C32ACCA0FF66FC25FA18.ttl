    dc:title "Marine flatworms (Platyhelminthes: Polycladida) found in empty barnacle shells including a new species, from southern Mexican Pacific" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4750211>, <http://dx.doi.org/10.5281/zenodo.4750213>, <http://dx.doi.org/10.5281/zenodo.4750215>, <http://dx.doi.org/10.5281/zenodo.4750217> ;
