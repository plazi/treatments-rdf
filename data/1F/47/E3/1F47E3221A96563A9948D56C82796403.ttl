    dc:creator "Messer, Steven J.; Cover, Stefan P.; Rabeling, Christian" ;
    dc:title "Nylanderia deyrupi Messer & Cover & Rabeling 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Nylanderia_deyrupi_Messer_2020> ;
