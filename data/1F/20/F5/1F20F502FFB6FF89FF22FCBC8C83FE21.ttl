    dc:title "The genus Tibicina Kolenati, 1857 in Morocco (Hemiptera: Cicadidae: Tibicininae): taxonomic assessment from integrative research" ;
    bibo:endPage "560" ;
    bibo:issue "4" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2023-08-17" ;
    bibo:startPage "535" ;
