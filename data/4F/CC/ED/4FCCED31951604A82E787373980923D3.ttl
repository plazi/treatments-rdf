    dc:creator "Masan, Peter" ;
    dc:date "2017" ;
    dc:title "A revision of the family Ameroseiidae (Acari, Mesostigmata), with some data on Slovak fauna" ;
    bibo:endPage "228" ;
    bibo:journal "ZooKeys" ;
    bibo:pubDate "2017-09-29" ;
    bibo:startPage "1" ;
