    dc:title "Gold in the mountains: Striking new species of Papuascincus (Sphenomorphini: Scincidae) from New Guinea" ;
    fabio:hasPart <http://dx.doi.org/10.3897/vz.74.e112782.figure2>, <http://dx.doi.org/10.3897/vz.74.e112782.figure3>, <http://dx.doi.org/10.3897/vz.74.e112782.figure4> ;
