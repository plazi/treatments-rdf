    a trt:Treatment .

<http://dx.doi.org/10.1111/zoj.12333>
    bibo:endPage "510" ;
    bibo:issue "3" ;
    bibo:journal "Zoological Journal of the Linnean Society" ;
    bibo:pubDate "2016-02-10" ;
    bibo:startPage "485" ;
    bibo:volume "176" ;
    dc:creator "Prantoni, Alessandro Lívio; Wit, Pierre De; Erséus, Christer" ;
    dc:date "2016" ;
    dc:title "First reports of Grania (Clitellata: Enchytraeidae) from Africa and South America: molecular phylogeny and descriptions of nine new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4720636>, <http://dx.doi.org/10.5281/zenodo.4720659>, <http://dx.doi.org/10.5281/zenodo.4720648>, <http://dx.doi.org/10.5281/zenodo.4720650>, <http://dx.doi.org/10.5281/zenodo.4720655>, <http://dx.doi.org/10.5281/zenodo.4720657> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.4720636>
    dc:description "Figure 6. Grania simonae sp. nov. A, chaetae. B, spermatheca. C, coelomocytes. D, penial bulb and sperm funnel. See text for abbreviations." ;
    fabio:hasRepresentation "https://zenodo.org/record/4720636/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4720659>
    dc:description "Figure 15. Multi-locus phylogeny of all available genetic data in Grania to date, using three mitochondrial and three nuclear loci. New species from this study are marked in bold. Majority-rule consensus tree from Bayesian Markov chain Monte Carlo (MCMC) inference; clade posterior probabilities are given next to the nodes." ;
    fabio:hasRepresentation "https://zenodo.org/record/4720659/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4720648>
    dc:description "Figure 11. Majority-rule consensus gene tree of cytochrome c oxidase subunit I (COI) locus from all species described in this study. Posterior probabilities calculated from Bayesian Markov chain Monte Carlo (MCMC) inference are noted above the branches. Note the four clades within Grania chilensis sp. nov." ;
    fabio:hasRepresentation "https://zenodo.org/record/4720648/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4720650>
    dc:description "Figure 12. Haplotype network of individuals of Grania chilensis sp. nov. Note the long distance (35 steps) between the two groups found in Valdivia." ;
    fabio:hasRepresentation "https://zenodo.org/record/4720650/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4720655>
    dc:description "Figure 13. Distance histogram of pairwise uncorrected p distances between all individuals analysed genetically in this study. Within-species distances range from 0 to 8% (0–3% if not counting Grania chilensis sp. nov.); between-species distances range from 16 to 25%." ;
    fabio:hasRepresentation "https://zenodo.org/record/4720655/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.4720657>
    dc:description "Figure 14. Majority-rule consensus gene tree of the ITS region (ITS1-5.8S rDNA-ITS2) from all species described in this study. Posterior probabilities calculated from Bayesian Markov chain Monte Carlo (MCMC) inference are noted above the branches. Note that the four Grania chilensis sp. nov. clades seen in the COI locus are absent here." ;
    fabio:hasRepresentation "https://zenodo.org/record/4720657/files/figure.png" ;
    a fabio:Figure .

