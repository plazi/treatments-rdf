    dc:date "2024" ;
    dc:title "Diversity of Distoseptispora (Distoseptisporaceae) taxa on submerged decaying wood from the Red River in Yunnan, China" ;
    bibo:endPage "28" ;
    bibo:journal "MycoKeys" ;
    bibo:pubDate "2024-02-05" ;
