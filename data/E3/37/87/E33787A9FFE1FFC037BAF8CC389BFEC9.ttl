    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.232354>
    dc:description "FIGURE 5. Brueelia callaeincola: (A) male habitus in ventral view; (B) female habitus in ventral view. Scale bar = 0.5 mm" ;
