    dc:date "2013" ;
    dc:title "Rothilena (Araneae: Agelenidae), a new genus of funnel-web spiders endemic to the Baja California Peninsula, Mexico" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.246872>, <http://dx.doi.org/10.5281/zenodo.246880>, <http://dx.doi.org/10.5281/zenodo.246881>, <http://dx.doi.org/10.5281/zenodo.246873> ;
