treatment:E34487A0FF8AE7302C86F98AFBDAFC88
    cito:cites <http://dx.doi.org/10.5281/zenodo.5290965> ;
    dc:creator "Prieto-Márquez, Albert" ;
    dc:title "Hadrosaurus foulkii Leidy 1858" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/E34487A0FF8AE7302C86F98AFBDAFC88.mc.DB853CEBFF8AE7322C86F912FD9AF847>, <http://tb.plazi.org/GgServer/dwcaRecords/E34487A0FF8AE7302C86F98AFBDAFC88.mc.DB853CEBFF8BE7332E19FF4CFD42FF63> ;
