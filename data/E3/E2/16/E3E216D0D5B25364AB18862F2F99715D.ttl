    dc:creator "Giron, Jennifer C.", "Short, Andrew Edward Z." ;
    dc:date "2023" ;
    dc:title "Revision of the Neotropical water scavenger beetle genus Novochares Giron & Short (Coleoptera, Hydrophilidae, Acidocerinae)" ;
    bibo:endPage "112" ;
    bibo:journal "ZooKeys" ;
