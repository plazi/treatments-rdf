    dc:creator "Oliver, Paul; Tjaturadi, Burhan; Krey, Keliopas; Richards, Stephen" ;
    dc:title "Cyrtodactylus zugi Oliver, Tjaturadi, Krey & Richards, 2008, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Cyrtodactylus_zugi_Oliver_2008> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.184390> ;
