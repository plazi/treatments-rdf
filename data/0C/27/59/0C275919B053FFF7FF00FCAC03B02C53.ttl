    cito:cites <http://dx.doi.org/10.5281/zenodo.187567>, <http://dx.doi.org/10.5281/zenodo.187568> ;
    dc:creator "Bravo, Freddy; Salazar-Valenzuela, David" ;
    dc:title "Sycorax wampukrum Bravo & Salazar-Valenzuela, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Sycorax_wampukrum_Bravo_2009> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.187566> ;
