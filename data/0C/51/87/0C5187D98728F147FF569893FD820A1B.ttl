    cito:cites <http://dx.doi.org/10.5281/zenodo.6981184>, <http://dx.doi.org/10.5281/zenodo.6981182> ;
    dc:creator "Schifani, Enrico; Prebus, Matthew M.; Alicata, Antonio" ;
    dc:title "Temnothorax Mayr 1861" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Temnothorax_Mayr_1861> ;
