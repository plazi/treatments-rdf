    dc:title "Lyropaeus kejvali Masek & Ivie & Palata & Bocak 2014, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/C701A33B5F77FF9CFC59FEBAA1600510.mc.FFC018705F77FF9DFBC7FE59A713040E>, <http://tb.plazi.org/GgServer/dwcaRecords/C701A33B5F77FF9CFC59FEBAA1600510.mc.FFC018705F77FF9DFB83FE12A6FE040E> ;
