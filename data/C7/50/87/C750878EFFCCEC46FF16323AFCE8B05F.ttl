    dc:creator "Ito, Tomiko; Sasaki, Tetsuro; Takahashi, Chicaco; Sugawara, Hirotaka; Hayashi, Fumio" ;
    dc:title "Hydroptila ogasawaraensis Ito 2011" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Hydroptila_ogasawaraensis_Ito_2011> ;
