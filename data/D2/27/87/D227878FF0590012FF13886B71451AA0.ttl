    cito:cites <http://dx.doi.org/10.5281/zenodo.216392>, <http://dx.doi.org/10.5281/zenodo.216394> ;
    dc:creator "Evenhuis, Neal L." ;
    dc:title "Mythicomyia dominicana Evenhuis 2002" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Mythicomyia_dominicana_Evenhuis_2002> ;
