    dc:title "Orthetrum coerulescens" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/D21687B9490D992D16E4B377FC576C7A.mc.EAD73CF2490D992E16E4B377FDE16F97> ;
