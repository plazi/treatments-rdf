    dc:creator "Arnscheid, Wilfried R." ;
    dc:title "Dahlica (Postsolenobia) weidlichi Arnscheid 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Dahlica_weidlichi_Arnscheid_2020> ;
