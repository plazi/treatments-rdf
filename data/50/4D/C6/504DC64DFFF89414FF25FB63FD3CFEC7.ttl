    dc:creator "Lukić, Marko; Porco, David; Bedos, Anne; Deharveng, Louis" ;
    dc:title "Heteromurus (Verhoeffiella) gamae Lukić, Porco, Bedos & Deharveng, 2015, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Heteromurus_gamae_Luki%C4%87_2015> ;
