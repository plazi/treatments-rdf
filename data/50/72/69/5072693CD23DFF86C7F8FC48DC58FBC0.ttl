    cito:cites <http://dx.doi.org/10.5281/zenodo.212067>, <http://dx.doi.org/10.5281/zenodo.212068>, <http://dx.doi.org/10.5281/zenodo.212069>, <http://dx.doi.org/10.5281/zenodo.212070> ;
    dc:creator "Mironov, Vladimir; Ratzel, Ulrich" ;
    dc:title "Eupithecia persidis Mironov & Ratzel, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Eupithecia_persidis_Mironov_2012> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.212066> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.212066>
    bibo:endPage "68" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "56" ;
    bibo:volume "3580" ;
    dc:creator "Mironov, Vladimir; Ratzel, Ulrich" ;
    dc:date "2012" ;
    dc:title "New species of the genus Eupithecia Curtis (Lepidoptera, Geometridae, Larentiinae) from Iran" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.212067>, <http://dx.doi.org/10.5281/zenodo.212068>, <http://dx.doi.org/10.5281/zenodo.212069>, <http://dx.doi.org/10.5281/zenodo.212070> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.212067>
    dc:description "FIGURES 1 – 9. Adults of Eupithecia species (enlarged; scale bar = 10 mm). 1, 2 — E. brandti sp. n. (holotype female and paratype female); 3, 4 — E. truschi sp. n. (holotype female and paratype female); 5, 6 — E. zagrosata sp. n. (holotype female and paratype male); 7 — E. basurmanca sp. n. (holotype female); 8, 9 — E. persidis sp. n. (holotype male and paratype female)." ;
    fabio:hasRepresentation "https://zenodo.org/record/212067/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212068>
    dc:description "FIGURES 10 – 12. Male genitalia (with eighth sternite, scale bar = 1 mm), aedeagus enlarged. 10 — E. truschi sp. n. (paratype); 11 — E. zagrosata sp. n. (paratype); 12 — E. persidis sp. n. (paratype)." ;
    fabio:hasRepresentation "https://zenodo.org/record/212068/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212069>
    dc:description "FIGURES 13 – 17. Female genitalia (scale bar = 1 mm). 13 — E. brandti sp. n. (holotype); 14 — E. truschi sp. n. (holotype); 15 — E. zagrosata sp. n. (paratype); 16 — E. persidis sp. n. (paratype); 17 — E. basurmanca sp. n. (holotype)." ;
    fabio:hasRepresentation "https://zenodo.org/record/212069/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212070>
    dc:description "FIGURES 18 – 23. Habitats of Eupithecia in Iran. 18 – 19 — Kuh-e Goran, Habitat of Eupithecia truschi sp. n.; 20 – 21 — Kuh-e Karkas, Habitat of Eupithecia truschi sp. n.; 22 – 23 — Shahkuh-e Bala, Habitat of Eupithecia persidis sp. n. By courtesy of Dr. R. Trusch (photos 18, 20, 22, 23) and Dr. J. - U. Meineke (photos 19, 21)." ;
    fabio:hasRepresentation "https://zenodo.org/record/212070/files/figure.png" ;
    a fabio:Figure .

