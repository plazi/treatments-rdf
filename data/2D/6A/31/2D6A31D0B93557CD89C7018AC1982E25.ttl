    dc:creator "Afonso, Oscar Martin", "Lugo, David", "Martin, Alicia", "Martin, Sonia", "Ruiz, Carlos", "Suarez, Daniel" ;
    dc:date "2023" ;
    dc:title "First record of Leptoglossus occidentalis Heidemann, 1910 (Hemiptera, Coreidae) in the Canary Islands, a novel pine pest detected through citizen science in an oceanic archipelago" ;
    bibo:endPage "109851" ;
    bibo:journal "Biodiversity Data Journal" ;
    bibo:pubDate "2023-09-11" ;
    bibo:startPage "109851" ;
    bibo:volume "11" ;
