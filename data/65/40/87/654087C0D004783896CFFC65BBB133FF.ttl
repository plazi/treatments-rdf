<http://dx.doi.org/10.5281/zenodo.1244906>
    dc:description "FIGURES 1–6. Copidosoma heinitane sp. nov., holotype ♀ (No. E1306-01): 1, head, frontal view; 2, antenna; 3, mesosoma, dorsal view; 4, fore wing; 5, legs; 6,metasoma, lateral view.Scale bars=100µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/1244906/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1244910>
    dc:description "FIGURES 13–18. Copidosoma linzhiensis sp. nov., holotype ♀ (No. E1408-01): 13, head, frontal view; 14, antenna; 15, mesosoma; 16, fore wing; 17, legs; 18, metasoma.Scale bars=100µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/1244910/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1244912>
    dc:description "FIGURES 19–24. Copidosoma longchuane sp. nov., holotype ♀ (No. E1304-01): 19, head, frontal view; 20, antenna; 21, mesosoma; 22, part of fore wing venation; 23, legs; 24, metasoma.Scale bars=100µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/1244912/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1244914>
    dc:description "FIGURES 25–30. Copidosoma longiclavatum, ♀ (No. E1505-01): 25, head, frontal view; 26, antenna; 27, meso- and metasoma; 28, fore wing; 29, hind wing; 30, legs.Scale bars=100µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/1244914/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.1244916>
    dc:description "FIGURES 31–36. Copidosoma recurvariae, ♀ (No. E1308-01): 31, head, frontal view; 32, antenna; 33, mesosoma; 34, fore wing; 35, legs; 36, metasoma.Scale bars=100µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/1244916/files/figure.png" ;
    a fabio:Figure .

