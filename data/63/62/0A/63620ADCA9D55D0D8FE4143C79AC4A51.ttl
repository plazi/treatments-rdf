    dc:date "2023" ;
    dc:title "Two new species of Dixonius from Vietnam and Laos with a discussion of the taxonomy of Dixonius (Squamata, Gekkonidae)" ;
    bibo:endPage "176" ;
    bibo:journal "ZooKeys" ;
    bibo:pubDate "2023-05-23" ;
