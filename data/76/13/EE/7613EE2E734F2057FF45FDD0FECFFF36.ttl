    dc:title "Gyrinus rozei Ochs 1953" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/7613EE2E734F2057FF45FDD0FECFFF36.mc.4ED25565734F205FFE5EFD5AFC05FCF3> ;
