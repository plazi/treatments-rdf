    dc:creator "Venegas, Pablo J.; Garcia-Ayachi, Luis A.; Echevarria, Lourdes Y.; Paluh, Daniel J.; Chavez-Arribasplata, Juan C.; Marchelie, Axel; Catenazzi, Alessandro" ;
    dc:title "Gastrotheca gemma Venegas & García-Ayachi & Echevarría & Paluh & Chávez-Arribasplata & Marchelie & Catenazzi 2021, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Gastrotheca_gemma_Venegas_2021> ;
