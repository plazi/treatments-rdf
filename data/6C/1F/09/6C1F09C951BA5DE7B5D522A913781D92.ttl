    a trt:Treatment .

<http://dx.doi.org/10.3897/vz.71.e60097>
    bibo:endPage "218" ;
    bibo:journal "Vertebrate Zoology" ;
    bibo:pubDate "2021-04-09" ;
    bibo:startPage "201" ;
    bibo:volume "71" ;
    dc:creator "Venegas, Pablo J.; Garcia-Ayachi, Luis A.; Echevarria, Lourdes Y.; Paluh, Daniel J.; Chavez-Arribasplata, Juan C.; Marchelie, Axel; Catenazzi, Alessandro" ;
    dc:date "2021" ;
    dc:title "A new species of marsupial frog (Anura; Gastrotheca) from the Cordillera de Colan in northeastern Peru" ;
    fabio:hasPart <http://dx.doi.org/10.3897/vz.71.e60097.figure2>, <http://dx.doi.org/10.3897/vz.71.e60097.figure3>, <http://dx.doi.org/10.3897/vz.71.e60097.figure4>, <http://dx.doi.org/10.3897/vz.71.e60097.figure5>, <http://dx.doi.org/10.3897/vz.71.e60097.figure6>, <http://dx.doi.org/10.3897/vz.71.e60097.figure8>, <http://dx.doi.org/10.3897/vz.71.e60097.figure7> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.3897/vz.71.e60097.figure2>
    dc:description "Figure 2. Preserved holotype of Gastrotheca gemma sp. nov. (CORBIDI 21238; female, SVL = 69.7 mm) in dorsal (A) and ventral (B) views." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530131" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/vz.71.e60097.figure3>
    dc:description "Figure 3. Some morphological details of the preserved holotype of Gastrotheca gemma sp. nov.: dorsal (A) and lateral (B) views of the head, and views of palm (C) and sole (D). Scale bar 5 mm. Photographs by LAGA." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530132" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/vz.71.e60097.figure4>
    dc:description "Figure 4. Three living adult specimens of Gastrotheca gemma sp. nov.: (A-B) dorsolateral and ventral views of female holotype (CORBIDI 21238), 69.7 mm SVL, with a zoom of its eye; (C-D) dorsolateral and ventral views of the adult male paratype (CORBIDI 21246), 57.0 mm SVL; (E-F) dorsolateral and ventral views of the adult male paratype (CORBIDI 21247), 59.5 mm SVL, with a zoom of its eye. Photographs by AM." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530133" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/vz.71.e60097.figure5>
    dc:description "Figure 5. Skull of Gastrotheca gemma sp. nov. (CORBIDI 19396) as visualized via Micro-CT scanning in dorsal (A), ventral (B), and right lateral (C) views. (D) Mandible in dorsal view. Scale bar = 5 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530134" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/vz.71.e60097.figure6>
    dc:description "Figure 6. Skeleton of Gastrotheca gemma sp. nov. (CORBIDI 19396) as visualized via Micro-CT scanning in dorsal view (A). (B) Left manus and pes in ventral view, (C) pectoral girdle in ventral view, and (D) ilium in right lateral view. Scale bar = 5 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530135" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/vz.71.e60097.figure8>
    dc:description "Figure 8. Skeleton and 34 embryos in pouch of Gastrotheca gemma sp. nov. (CORBIDI 19396) as visualized via Micro-CT scanning in dorsal (A) and right lateral (B) views. (A) Scale bar = 10 mm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530137" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/vz.71.e60097.figure7>
    dc:description "Figure 7. Geographical distribution of Gastrotheca gemma sp. nov. and closely related and similar species from Ecuador and Peru." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/530136" ;
    a fabio:Figure .

