    cito:cites <http://dx.doi.org/10.3897/phytokeys.151.53100.figure1>, <http://dx.doi.org/10.3897/phytokeys.151.53100.figure2> ;
    dc:creator "Amoroso, Victor B.; Coritico, Fulgent P.; Fritsch, Peter W." ;
    dc:title "Actinostachys minuta Amoroso & Coritico 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Plantae/Actinostachys_minuta_Amoroso_2020> ;
