    dc:creator "Gururaja, Kotambylu Vasudeva; Palot, Muhamed Jafer; Radhakrishnan, C" ;
    dc:title "Philautus ochlandrae Gururaja, Palot & Radhakrishnan, 2007, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Philautus_ochlandrae_Gururaja_2007> ;
