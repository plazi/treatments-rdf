    dc:creator "Fernandes, José Antônio Marin; Grazia, Jocélia" ;
    dc:date "2006" ;
    dc:title "Revisão do gênero Antiteuchus Dallas (Heteroptera, Pentatomidae, Discocephalinae)" ;
