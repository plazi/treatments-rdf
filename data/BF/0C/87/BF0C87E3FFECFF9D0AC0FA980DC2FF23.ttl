    dc:creator "Goncharenko, Igor V.", "Krakhmalnyi, Aleksandr F.", "Krakhmalnyi, Maxim A.", "Terenko, Galyna V." ;
    dc:date "2023" ;
    dc:title "Dominant Species Of The Genus Protoperidinium Bergh (Peridiniales: Protoperidiniaceae) In The Black Sea" ;
    bibo:endPage "448" ;
    bibo:issue "5" ;
    bibo:journal "Zootaxa" ;
