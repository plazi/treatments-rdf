    dc:title "A new genus and species of Polynoidae (Annelida, Polychaeta) from Pine Island Bay, Amundsen Sea, Southern Ocean-a region of high taxonomic novelty" ;
    bibo:endPage "88" ;
    bibo:journal "Zootaxa" ;
