    dc:title "Halecium antarcticum Vanhoffen 1910" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Halecium_antarcticum_Vanhoffen_1910> ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Halecium_antarcticum>, <http://taxon-name.plazi.org/id/Animalia/Halecium_gracile>, <http://taxon-name.plazi.org/id/Animalia/Halecium_delicatulum> ;
