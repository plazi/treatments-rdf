    dc:creator "Jia, Fenglong; Liang, Zulong; Fikacek, Martin" ;
    dc:title "Himalcercyon mirus Jia & Liang & Fikáček 2020, stat. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Himalcercyon_mirus_Hebauer_2002> ;
