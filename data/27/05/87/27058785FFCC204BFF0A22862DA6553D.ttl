    dc:creator "Baptista, Ninda L.; Pinto, Pedro Vaz; Keates, Chad; Edwards, Shelley; Rödel, Mark-Oliver; Conradie, Werner" ;
    dc:date "2021" ;
    dc:title "A new species of red toad, Schismaderma Smith, 1849 (Anura: Bufonidae), from central Angola" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.5775724>, <http://dx.doi.org/10.5281/zenodo.5775728>, <http://dx.doi.org/10.5281/zenodo.5775722>, <http://dx.doi.org/10.5281/zenodo.5775726>, <http://dx.doi.org/10.5281/zenodo.5775716>, <http://dx.doi.org/10.5281/zenodo.5775733>, <http://dx.doi.org/10.5281/zenodo.5775730>, <http://dx.doi.org/10.5281/zenodo.5775712> ;
