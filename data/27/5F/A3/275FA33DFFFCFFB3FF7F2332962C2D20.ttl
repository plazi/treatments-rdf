    dc:creator "Ballen, Gustavo A.; Mojica, José Iván" ;
    dc:title "Farlowella yarigui Ballen & Mojica, 2014, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Farlowella_yarigui_Ballen_2014> ;
    trt:publishedIn <http://dx.doi.org/10.11646/zootaxa.3765.2.2> ;
    a trt:Treatment .

<http://dx.doi.org/10.11646/zootaxa.3765.2.2>
    bibo:endPage "142" ;
    bibo:issue "2" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "134" ;
    bibo:volume "3765" ;
    dc:creator "Ballen, Gustavo A.; Mojica, José Iván" ;
    dc:date "2014" ;
    dc:title "A new trans-Andean Stick Catfish of the genus Farlowella Eigenmann & Eigenmann, 1889 (Siluriformes: Loricariidae) with the first record of the genus for the río Magdalena Basin in Colombia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.227290>, <http://dx.doi.org/10.5281/zenodo.227291>, <http://dx.doi.org/10.5281/zenodo.227292> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.227290>
    dc:description "FIGURE 1. Farlowella yarigui n. sp., holotype, ICNMHN 17819, 112.3 mm SL, dorsal, lateral, and ventral views." ;
    fabio:hasRepresentation "https://zenodo.org/record/227290/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.227291>
    dc:description "FIGURE 2. Distribution map of Farlowella yarigui n. sp. This species is only known from the type locality (indicated by a star)." ;
    fabio:hasRepresentation "https://zenodo.org/record/227291/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.227292>
    dc:description "FIGURE 3. Microhabitat where the type series of Farlowella yarigui n. sp. was collected in the río Topón, piedmont of the Serranía de los Yariguíes, Santander, Colombia. Note the clear water conditions with submerged vegetation typical of microhabitats where fishes of the genus Farlowella are common." ;
    fabio:hasRepresentation "https://zenodo.org/record/227292/files/figure.png" ;
    a fabio:Figure .

