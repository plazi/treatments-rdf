    dc:title "The Acentropinae and Musotiminae (Lepidoptera, Pyralidae) of the Galapagos Islands, Ecuador" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.174565>, <http://dx.doi.org/10.5281/zenodo.174567>, <http://dx.doi.org/10.5281/zenodo.174566> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.174565>
    dc:description "FIGURES 1 – 4. 1, 2: Parapoynx fluctuosalis (Zeller). 1, Female from Santa Cruz Island, Galapagos (FW = 9.0 mm, CNC); 2, Male from Papua New Guinea (FW = 8.0 mm, D. Agassiz Collection). 3, 4: Undulambia lindbladi Landry. 3, Holotype male; 4, Paratype female from Isabela (MHNG)." ;
    fabio:hasRepresentation "https://zenodo.org/record/174565/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.174567>
    dc:description "FIGURES 10 – 11. Undulambia lindbladi Landry. 10, Male genitalia in lateral view, without phallus, saccus partially deformed dorsally (slide MHNG 3036); 11, Female genitalia in lateral view (bursa broken proximally, from slide BMNH 21169)." ;
    fabio:hasRepresentation "https://zenodo.org/record/174567/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.174566>
    dc:description "FIGURES 6 – 9. Undulambia lindbladi Landry. 6, Male genitalia in ventral view, without phallus (slide BL 1183, CNC); 7, Phallus in laterodorsal view (slide BL 1183); 8, Phallus in side view (slide MHNG 3129); 9, Female genitalia, ventral view (slide MHNG 3039)." ;
    fabio:hasRepresentation "https://zenodo.org/record/174566/files/figure.png" ;
    a fabio:Figure .

