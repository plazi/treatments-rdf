    dc:creator "Schmelz, Rüdiger M.; Collado, Rut; Römbke, Jörg" ;
    dc:title "Xetadrilus Schmelz, Collado & Römbke, 2011, gen. nov." ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Marionina>, <http://taxon-name.plazi.org/id/Animalia/Stercutus>, <http://taxon-name.plazi.org/id/Animalia/Xetadrilus_pitucus>, <http://taxon-name.plazi.org/id/Animalia/Xetadrilus_fabryi> ;
