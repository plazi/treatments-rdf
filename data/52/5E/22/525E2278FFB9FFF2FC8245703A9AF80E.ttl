    dc:title "New taxa of pygmy grasshoppers from Australia with notes on classification of the subfamily Batrachideinae (Orthoptera: Tetrigidae)" ;
    bibo:endPage "107" ;
    bibo:issue "1" ;
    bibo:journal "Zoosystematica Rossica" ;
