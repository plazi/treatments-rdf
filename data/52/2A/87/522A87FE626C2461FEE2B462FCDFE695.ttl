    dc:date "2020" ;
    dc:title "Description of Torymus lasallei, sp. nov. (Hymenoptera: Torymidae), a species with an unusual ovipositor" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4290613>, <http://dx.doi.org/10.5281/zenodo.4290617>, <http://dx.doi.org/10.5281/zenodo.4290619>, <http://dx.doi.org/10.5281/zenodo.4290621> ;
