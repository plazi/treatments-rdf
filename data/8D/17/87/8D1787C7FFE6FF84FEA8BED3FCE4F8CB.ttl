    dc:creator "Pinho, Luiz Carlos De; Mendes, Humberto Fonseca; Marcondes, Carlos Brisola" ;
    dc:title "Stenochironomus atlanticus Pinho & Mendes, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Stenochironomus_atlanticus_Pinho_2005> ;
