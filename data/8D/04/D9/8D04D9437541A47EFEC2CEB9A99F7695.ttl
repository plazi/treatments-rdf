    dc:creator "Yan, Haijuan; Shi, Shidi; Chen, Jianxiu" ;
    dc:date "2006" ;
    dc:title "A new species of the genus Thalassaphorura from East China (Collembola: Onychiuridae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.174864>, <http://dx.doi.org/10.5281/zenodo.174865> ;
