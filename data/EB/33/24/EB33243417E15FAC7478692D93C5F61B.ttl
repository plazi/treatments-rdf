    bibo:startPage "1" ;
    bibo:volume "57" ;
    dc:creator "Huber, John T." ;
    dc:date "2017" ;
    dc:title "Eustochomorpha Girault, Neotriadomerus gen. n., and Proarescon gen. n. (Hymenoptera, Mymaridae), early extant lineages in evolution of the family" ;
    fabio:hasPart <http://dx.doi.org/10.3897/jhr.57.12892.figures104-107>, <http://dx.doi.org/10.3897/jhr.57.12892.figures126-127>, <http://dx.doi.org/10.3897/jhr.57.12892.figures1-3>, <http://dx.doi.org/10.3897/jhr.57.12892.figures4-7>, <http://dx.doi.org/10.3897/jhr.57.12892.figures165-167> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.3897/jhr.57.12892.figures104-107>
    dc:description "Figures 104 - 107. Neotriadomerus gloriosus, holotype. 104 mesosoma, dorsal 105 metasoma, lateral 106 metasoma, median plane 107 type slide. Scale bar = 200 μm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/142512" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/jhr.57.12892.figures126-127>
    dc:description "Figures 126, 127. Neotriadomerus longissimus, paratype, lateral (Brisbane Forest Park). 126 habitus, lateral 127 anterior body, enlarged. Scale bar for 126 = 2000 μm; 127 = 1000 μm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/142521" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/jhr.57.12892.figures1-3>
    dc:description "Figures 1 - 3. Eustochomorpha haeckeli, holotype female. 1 type slide, specimen under middle cover slip 2 body + legs 3 antenna. Scale bar = 100 μm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/142486" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/jhr.57.12892.figures4-7>
    dc:description "Figures 4 - 7. Eustochomorpha haeckeli, female. 4 habitus (Australia, WA, Stirling Range National Park) 5 head, anterior; 6 a head, posterior 6 b tentorium 7 antenna. Scale bar for 4 = 500 μm; 5 - 7 = 100 μm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/142487" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/jhr.57.12892.figures165-167>
    dc:description "Figures 165 - 167. Proarescon similis, holotype. 165 head, dorsal 166 a antenna without scape, lateral 166 b antenna, dorsal 167 type slide. Scale bar = 100 μm." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/142535" ;
    a fabio:Figure .

