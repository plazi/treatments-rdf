    dc:date "2023" ;
    dc:title "Sulzbacheromyces leucodontium (Basidiomycota, Lepidostromataceae), a new species of basidiolichen widely distributed in the Neotropics" ;
    bibo:endPage "164" ;
    bibo:issue "2" ;
    bibo:journal "Phytotaxa" ;
