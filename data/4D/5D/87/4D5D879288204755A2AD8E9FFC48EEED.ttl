    dc:creator "Bartlett, Justin S." ;
    dc:date "2023" ;
    dc:title "Clarification of ambiguous genus records for Australian Cleridae (Coleoptera: Cleroidea)" ;
    bibo:endPage "382" ;
    bibo:issue "3" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2023-12-12" ;
