    dc:date "2014" ;
    dc:title "A new species Chrysorithrum duda (Lepidoptera: Erebidae) from China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.224512>, <http://dx.doi.org/10.5281/zenodo.224513>, <http://dx.doi.org/10.5281/zenodo.224514> ;
