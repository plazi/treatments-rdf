    dc:creator "Kin, Adrian; Żejowski, Ej Bła" ;
    dc:title "Trimerocephalus chopini Kin & Żejowski, 2013, n. sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Trimerocephalus_chopini_Kin_2013> ;
