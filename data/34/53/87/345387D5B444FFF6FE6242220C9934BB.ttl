    dc:description "Figure 1. Metriocnemus wings. (A) M. fasciventris Edwards; (B) M. cavipenis sp. nov.; (C) M. tucumanus sp. nov. Scale bars: 100 µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/8224962/files/figure.png" ;
