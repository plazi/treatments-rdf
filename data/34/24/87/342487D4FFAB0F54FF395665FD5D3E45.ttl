    dc:creator "Kinsella, John M.; Robles, Maria Del Rosario; Preisser, Whitney C." ;
    dc:title "Gongylonema archboldi Kinsella, Robles & Preisser, 2016, n. sp." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Gongylonema_archboldi_Kinsella_2016> ;
