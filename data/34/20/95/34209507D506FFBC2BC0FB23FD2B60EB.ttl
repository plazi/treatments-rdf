    dc:title "Description of a new species of Eucynorta (Opiliones, Cosmetidae) from Cortés, Honduras" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.1444644>, <http://dx.doi.org/10.5281/zenodo.1444638>, <http://dx.doi.org/10.5281/zenodo.1444640>, <http://dx.doi.org/10.5281/zenodo.1444642> ;
