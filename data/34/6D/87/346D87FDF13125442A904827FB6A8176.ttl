    dc:title "A Revision of the Australian species of Lynceus Müller, 1776 (Crustacea: Branchiopoda: Laevicaudata, Lynceidae)" ;
    bibo:endPage "533" ;
    bibo:issue "6" ;
    bibo:journal "Zootaxa" ;
