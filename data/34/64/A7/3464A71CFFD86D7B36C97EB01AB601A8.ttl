treatment:3464A71CFFD86D7B36C97EB01AB601A8
    cito:cites <http://dx.doi.org/10.5281/zenodo.212607>, <http://dx.doi.org/10.5281/zenodo.212608>, <http://dx.doi.org/10.5281/zenodo.212609>, <http://dx.doi.org/10.5281/zenodo.212610> ;
    dc:creator "Ukuwela, Kanishka D. B.; Sanders, Kate L.; Fry, Bryan G." ;
    dc:title "Hydrophis donaldi Ukuwela, Sanders & Fry, 2012, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Hydrophis_donaldi_Ukuwela_2012> ;
    trt:publishedIn <http://dx.doi.org/10.5281/zenodo.212606> ;
    a trt:Treatment .

<http://dx.doi.org/10.5281/zenodo.212606>
    bibo:endPage "57" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "45" ;
    bibo:volume "3201" ;
    dc:creator "Ukuwela, Kanishka D. B.; Sanders, Kate L.; Fry, Bryan G." ;
    dc:date "2012" ;
    dc:title "Hydrophis donaldi (Elapidae, Hydrophiinae), a highly distinctive new species of sea snake from northern Australia" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.212607>, <http://dx.doi.org/10.5281/zenodo.212608>, <http://dx.doi.org/10.5281/zenodo.212609>, <http://dx.doi.org/10.5281/zenodo.212610> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.212607>
    dc:description "FIGURE 1. Hydrophis donaldi sp. nov. (A) Dorsal aspect of holotype QM J 90700 (before preservation), (B) Ventral aspect of holotype QM J 90700 (before preservation), (C) strongly spinous dorsal scales, (D) micro-CT scan of the lateral view of the head of SAMA R 65216 (Scale = 10 mm). Note that the maxillary bone does not extend forward far beyond the palatine and that the fang is followed by a diastema. both character states were used by Smith (1926) to diagnose Hydrophis." ;
    fabio:hasRepresentation "https://zenodo.org/record/212607/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212608>
    dc:description "FIGURE 2. Hydrophis donaldi sp. nov., holotype QM J 90700 (A) lateral aspect of head, (B) Dorsal aspect of head. Scale = 10 mm." ;
    fabio:hasRepresentation "https://zenodo.org/record/212608/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212609>
    dc:description "FIGURE 3. Bayesian majority rule consensus tree of the sea snakes sampled in this study based on the concatenated mitochondrial alignment. Hydrophis donaldi sp. nov. forms a highly divergent lineage although its phylogentic position remains poorly resolved. Nodes with maximum likelihood bootstrap support> 70 (below) and Bayesian posterior probability> 0.8 (above) are indicated. The outgroup Aipysurus laevis is not shown. Scale bar indicates the number of nucleotide substitutions per site." ;
    fabio:hasRepresentation "https://zenodo.org/record/212609/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.212610>
    dc:description "FIGURE 4. The single most parsimonious trees for phased haplotypes of the nuclear loci (A) G 1888 (B) G 1894. Scale bars indicate branch lengths corresponding to 1 step." ;
    fabio:hasRepresentation "https://zenodo.org/record/212610/files/figure.png" ;
    a fabio:Figure .

