    dc:title "Two new remarkable species of Barbacenia (Velloziaceae) from the Brazilian Espinhaço Range in honor of Renato Mello-Silva" ;
    bibo:endPage "287" ;
    bibo:issue "3" ;
    bibo:journal "Phytotaxa" ;
    bibo:pubDate "2023-09-28" ;
