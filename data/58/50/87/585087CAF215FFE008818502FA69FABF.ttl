    dc:creator "Kamiński, Marcin Jan" ;
    dc:title "Anchophthalmops brevipleurum Koch 1956" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Anchophthalmops_brevipleurum_Koch_1956> ;
