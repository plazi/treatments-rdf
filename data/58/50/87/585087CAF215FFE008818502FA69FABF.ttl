    a trt:Treatment .

<http://dx.doi.org/10.11646/zootaxa.3709.6.1>
    bibo:endPage "523" ;
    bibo:issue "6" ;
    bibo:journal "Zootaxa" ;
    bibo:startPage "501" ;
    bibo:volume "3709" ;
    dc:creator "Kamiński, Marcin Jan" ;
    dc:date "2013" ;
    dc:title "Taxonomy and distribution of the Afrotropical genus Anchophthalmops Koch, 1956 with a key to species (Coleoptera: Tenebrionidae: Pedinini)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.247755>, <http://dx.doi.org/10.5281/zenodo.247758>, <http://dx.doi.org/10.5281/zenodo.247756>, <http://dx.doi.org/10.5281/zenodo.247759>, <http://dx.doi.org/10.5281/zenodo.247757> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.247755>
    dc:description "FIGURES 9 – 16. Aedeagal tegmen dorsal and ventral view (10, 11), ovipositor with part of bursa copulatrix (11), spermatheca (12), labels of primary types (13 – 16). A. foveipennis (9, 10, 13), A. maximus (11, 12), A. ventralis (14), A. neumanni sp. nov. (15), A. zablockii sp. nov. (16)." ;
    fabio:hasRepresentation "https://zenodo.org/record/247755/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.247758>
    dc:description "FIGURES 46 – 49. Distribution of the species of Anchophthalmops. The division of Afrotropical Realm into ecoregions was adopted after Olson et al. 2001. Different colors were used to distinguish the adjacent ecoregions." ;
    fabio:hasRepresentation "https://zenodo.org/record/247758/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.247756>
    dc:description "FIGURES 21 – 24. Body habitus. A. maximus (21), A. menouxi (22), A. neumanni sp. nov. (23), A. ventralis (24)." ;
    fabio:hasRepresentation "https://zenodo.org/record/247756/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.247759>
    dc:description "FIGURE 50. Modeled range of A. menouxi generated in MaxEnt. Different hues of green indicate the probability of occurrence in percent. The model was calculated with exclusion of locations situated closer than 20 km from each other. White dots indicate the documented species distribution. Training AUC = 0.946." ;
    fabio:hasRepresentation "https://zenodo.org/record/247759/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.247757>
    dc:description "FIGURES 25 – 30. Body habitus (25, 26), epipleuron (27, 28), pronotal disc (29, 30). A. uhligi (25), A. zablockii sp. nov. (26), A. menouxi (27, 29), A. neumanni sp. nov. (28, 30)." ;
    fabio:hasRepresentation "https://zenodo.org/record/247757/files/figure.png" ;
    a fabio:Figure .

