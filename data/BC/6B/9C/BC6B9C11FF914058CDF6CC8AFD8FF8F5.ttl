    dc:date "2015" ;
    dc:title "A review of Billaea Robineau-Desvoidy of the eastern Palearctic and Oriental regions (Diptera: Tachinidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.288391>, <http://dx.doi.org/10.5281/zenodo.288394>, <http://dx.doi.org/10.5281/zenodo.288395> ;
