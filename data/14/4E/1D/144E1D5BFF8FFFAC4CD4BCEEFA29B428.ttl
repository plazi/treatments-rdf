    dc:creator "Jiang, Jigang; Tang, Boping; Chen, Jian-Xiu" ;
    dc:date "2007" ;
    dc:title "A new species of the genus Hypogastrura from coastal wetlands of East China (Collembola: Hypogastruridae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.179401>, <http://dx.doi.org/10.5281/zenodo.179402> ;
