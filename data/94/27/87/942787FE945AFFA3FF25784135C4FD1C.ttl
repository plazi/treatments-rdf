    dc:date "2015" ;
    dc:title "Two new species of the genus Loxopamea Hreblay & Plante 1995 (Lepidoptera: Noctuidae) from China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.234154>, <http://dx.doi.org/10.5281/zenodo.234155>, <http://dx.doi.org/10.5281/zenodo.234156> ;
