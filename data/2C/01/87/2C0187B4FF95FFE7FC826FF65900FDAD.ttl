    dc:title "Lower Devonian Zosterophyllum-like plants from central Victoria, Australia, and their significance" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.8065437>, <http://dx.doi.org/10.5281/zenodo.8065441> ;
