    dc:title "The life histories of Americerura (Lepidoptera: Notodontidae: Cerurinae) from southern Brazil, with the description of a new species" ;
    bibo:endPage "2082" ;
    bibo:issue "45 - 48" ;
    bibo:journal "Journal of Natural History" ;
