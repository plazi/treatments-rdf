    dc:title "Kalanchoe sogae Gideon F. Sm. & Figueiredo 2022, nothospec. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/73359949B858FFF1FF0674A4D87CC2FB.mc.4BF42202B858FFF6FF58748CD994C235> ;
