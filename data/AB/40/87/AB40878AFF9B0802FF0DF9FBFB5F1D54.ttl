<http://dx.doi.org/10.11646/zootaxa.4742.1.13>
    bibo:endPage "200" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
    bibo:pubDate "2020-02-19" ;
    bibo:startPage "194" ;
