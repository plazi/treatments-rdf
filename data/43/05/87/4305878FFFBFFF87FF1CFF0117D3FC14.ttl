    dc:title "Polydora tunicola Abe, Hoshino & Yamada 2022, sp. nov." ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/4305878FFFBFFF87FF1CFF0117D3FC14.mc.7BC43CC4FFBFFF8FFEC1FE3B11A9FE37> ;
