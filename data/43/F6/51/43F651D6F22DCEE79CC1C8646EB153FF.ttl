    dc:title "Three additional new genera of acidocerine water scavenger beetles from the Guiana and Brazilian Shield regions of South America (Coleoptera, Hydrophilidae, Acidocerinae)" ;
    fabio:hasPart <http://dx.doi.org/10.3897/zookeys.855.33013.figure10>, <http://dx.doi.org/10.3897/zookeys.855.33013.figure11>, <http://dx.doi.org/10.3897/zookeys.855.33013.figure12>, <http://dx.doi.org/10.3897/zookeys.855.33013.figure13>, <http://dx.doi.org/10.3897/zookeys.855.33013.figure14>, <http://dx.doi.org/10.3897/zookeys.855.33013.figure15>, <http://dx.doi.org/10.3897/zookeys.855.33013.figure16> ;
