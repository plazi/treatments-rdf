    cito:cites <https://binary.pensoft.net/fig/10012>, <https://binary.pensoft.net/fig/10013>, <https://binary.pensoft.net/fig/10014> ;
    dc:creator "Filipowicz, Natalia; Nee, Michael H.; Renner, Susanne S." ;
    dc:title "Brunfelsia plowmaniana N. Filipowicz & M. Nee 2012, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Plantae/Brunfelsia_plowmaniana_Filipowicz_2012> ;
    trt:publishedIn <http://dx.doi.org/10.3897/phytokeys.10.2558> ;
    a trt:Treatment .

<http://dx.doi.org/10.3897/phytokeys.10.2558>
    bibo:endPage "94" ;
    bibo:journal "PhytoKeys" ;
    bibo:pubDate "2012-03-22" ;
    bibo:startPage "83" ;
    bibo:volume "10" ;
    dc:creator "Filipowicz, Natalia; Nee, Michael H.; Renner, Susanne S." ;
    dc:date "2012" ;
    dc:title "Description and molecular diagnosis of a new species of Brunfelsia (Solanaceae) from the Bolivian and Argentinean Andes" ;
    fabio:hasPart <https://binary.pensoft.net/fig/10012>, <https://binary.pensoft.net/fig/10013>, <https://binary.pensoft.net/fig/10014> ;
    a fabio:JournalArticle .

<https://binary.pensoft.net/fig/10012>
    dc:description "Figure 1. Isotype specimen of Brunfelsia plowmaniana N. Filipowicz & M. Nee: M. Nee 37571 (NY)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10012" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10013>
    dc:description "Figure 2. Distribution of Brunfelsia plowmaniana N. Filipowicz & M. Nee based on the voucher specimens listed in Taxonomic treatment and in Appendix 1." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10013" ;
    a fabio:Figure .

<https://binary.pensoft.net/fig/10014>
    dc:description "Figure 3. Maximum likelihood phylogram (GTR + Gamma) for a reduced dataset consisting of 41 accessions of Brunfelsia and 8 outgroup genera and based on the analysis of combined plastid and nuclear sequences (3784 aligned nucleotides). Numbers above branches refer to ML bootstrap support ≥ 70 %. Placements of Brunfelsia plowmaniana N. Filipowicz & M. Nee and Brunfelsia uniflora (Pohl) D. Don (both represented by two accessions) in the tree are marked in red. Main clades are marked in different colors. For the full tree and alignment see TreeBase under acc. no. 12245." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/10014" ;
    a fabio:Figure .

