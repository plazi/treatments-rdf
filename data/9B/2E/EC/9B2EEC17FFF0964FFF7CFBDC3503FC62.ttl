    dc:creator "Sánchez-Nivicela, Juan C.; Urgiles, Veronica L.; Navarrete, María José; Yánez-Muñoz, Mario H.; Ron, Santiago" ;
    dc:title "Lynchius megacephalus Sánchez-Nivicela & Urgiles & Navarrete & Yánez-Muñoz & Ron 2019, new species" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/9B2EEC17FFF0964FFF7CFBDC3503FC62.mc.A3EF575CFFF09640FF7CFB77346EFAB3> ;
