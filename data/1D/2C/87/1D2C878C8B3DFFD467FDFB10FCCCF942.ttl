    dc:title "A new species and new records of Sericini chafers from the Lower Gangetic Plains in India (Coleoptera: Scarabaeidae: Sericinae)" ;
    bibo:endPage "371" ;
    bibo:issue "4" ;
    bibo:journal "Zootaxa" ;
