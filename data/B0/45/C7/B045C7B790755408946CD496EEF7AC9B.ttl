    cito:cites <http://taxon-concept.plazi.org/id/Animalia/Cybistrini_Sharp_1880>, <http://dx.doi.org/10.3897/zookeys.1188.110081.figures1-8>, <http://dx.doi.org/10.3897/zookeys.1188.110081.figures67-71>, <http://dx.doi.org/10.3897/zookeys.1188.110081.figure75>, <http://dx.doi.org/10.3897/zookeys.1188.110081.figure76> ;
    dc:creator "Miller, Kelly B.; Michat, Mariano C.; Ferreira Jr, Nelson" ;
    dc:title "Megadytes Sharp 1882" ;
