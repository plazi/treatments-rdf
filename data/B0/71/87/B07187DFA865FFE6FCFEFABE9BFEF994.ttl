    dc:title "Scorpions of Sri Lanka (Scorpiones Buthidae, Chaerilidae, Scorpionidae) with description of four new species of the genera Charmus Karsch, 1879 and Reddyanus Vachon, 1972, stat n" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7124765>, <http://dx.doi.org/10.5281/zenodo.7124608>, <http://dx.doi.org/10.5281/zenodo.7124696>, <http://dx.doi.org/10.5281/zenodo.7124487>, <http://dx.doi.org/10.5281/zenodo.7124493>, <http://dx.doi.org/10.5281/zenodo.7124547>, <http://dx.doi.org/10.5281/zenodo.7124513>, <http://dx.doi.org/10.5281/zenodo.7124543>, <http://dx.doi.org/10.5281/zenodo.7124523>, <http://dx.doi.org/10.5281/zenodo.7124626>, <http://dx.doi.org/10.5281/zenodo.7124655>, <http://dx.doi.org/10.5281/zenodo.7124612>, <http://dx.doi.org/10.5281/zenodo.7124767>, <http://dx.doi.org/10.5281/zenodo.7124663>, <http://dx.doi.org/10.5281/zenodo.7124684>, <http://dx.doi.org/10.5281/zenodo.7124622>, <http://dx.doi.org/10.5281/zenodo.7124769> ;
