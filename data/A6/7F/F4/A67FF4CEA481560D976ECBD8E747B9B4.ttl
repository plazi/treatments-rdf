    dc:title "Lepidium flexicaule Kirk, Trans. et Proc. New Zealand Inst. 14, 380 1882" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Lepidium_flexicaule_Kirk_1882> ;
