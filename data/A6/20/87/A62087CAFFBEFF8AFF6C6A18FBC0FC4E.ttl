    dc:title "Dolichorhabditis tereticorpus Kito & Ohyama, 2008, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Dolichorhabditis_tereticorpus_Kito_2008> ;
