    dc:title "Three new species and three new records of the genus Bamboosiella from China (Thysanoptera: Phlaeothripidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.2607888>, <http://dx.doi.org/10.5281/zenodo.2607878>, <http://dx.doi.org/10.5281/zenodo.2607884>, <http://dx.doi.org/10.5281/zenodo.2607876>, <http://dx.doi.org/10.5281/zenodo.2607882> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.2607888>
    dc:description "FIGURES 37–44. Bamboosiella species. (37) B. brevis (female); (38) B. brevis (male); (39) B. fasciata (female); (40) B. fasciata (male); (41) B. lewisi (female); (42) B. lewisi (male); (43) B. xiphophora (female); (44) B. xiphophora (male)." ;
    fabio:hasRepresentation "https://zenodo.org/record/2607888/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.2607878>
    dc:description "FIGURES 9–12. Bamboosiella lewisi: (9) head; (10) pronotum; (11) fore leg of female; (12) fore leg of male." ;
    fabio:hasRepresentation "https://zenodo.org/record/2607878/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.2607884>
    dc:description "FIGURES 27–30. Bamboosiella xiphophora: (27) head; (28) pronotum; (29) fore leg of female; (30) fore leg of male (arrows indicate sub-apical tubercle bearing a short seta)." ;
    fabio:hasRepresentation "https://zenodo.org/record/2607884/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.2607876>
    dc:description "FIGURES 3–8. Bamboosiella caudibruna sp. n. (3) head; (4) pronotum; (5) fore leg of male; (6) metanotum; (7) pelta; (8) antenna." ;
    fabio:hasRepresentation "https://zenodo.org/record/2607876/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.2607882>
    dc:description "FIGURES 20–26. Bamboosiella sculpta sp. n.: (20) head; (21) pronotum; (22) ventral view of prothorax; (23) metanotum; (24) pelta; (25) abdominal tergites III–V; (26) antenna." ;
    fabio:hasRepresentation "https://zenodo.org/record/2607882/files/figure.png" ;
    a fabio:Figure .

