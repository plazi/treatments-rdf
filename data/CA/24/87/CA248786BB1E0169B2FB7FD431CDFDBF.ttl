    cito:cites <http://dx.doi.org/10.5281/zenodo.178056> ;
    dc:creator "Ronowicz, Marta; Schuchert, Peter" ;
    dc:title "Halecium arcticum Ronowicz & Schuchert, 2007, sp. nov." ;
    trt:citesTaxonName <http://taxon-name.plazi.org/id/Animalia/Halecium>, <http://taxon-name.plazi.org/id/Animalia/Halecium_delicatulum> ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Halecium_arcticum_Ronowicz_2007> ;
