    dc:date "2015" ;
    dc:title "Taxonomy of recent Adeonidae (Bryozoa, Cheilostomata) from Brazil, with the description of four new species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.237295> ;
