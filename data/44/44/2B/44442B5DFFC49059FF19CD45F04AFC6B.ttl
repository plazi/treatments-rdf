    dc:title "Alurnus chocoensis Pardo-Locarno y Constantino 2023, nueva especie" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Alurnus_chocoensis_Constantino_2023> ;
