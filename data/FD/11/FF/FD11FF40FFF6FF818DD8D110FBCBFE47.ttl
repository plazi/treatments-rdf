    dc:date "2013" ;
    dc:title "Globorentonium, a new genus of rentoniine Trogossitidae (Coleoptera: Cleroidea) from Australia and Brazil" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.215550>, <http://dx.doi.org/10.5281/zenodo.215552>, <http://dx.doi.org/10.5281/zenodo.215553>, <http://dx.doi.org/10.5281/zenodo.215555> ;
