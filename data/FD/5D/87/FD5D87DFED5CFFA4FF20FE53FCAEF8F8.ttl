    dc:date "2022" ;
    dc:title "Helminth Diversity In Teleost Fishes From The South Orkney Islands Region, West Antarctica" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.7175667>, <http://dx.doi.org/10.5281/zenodo.7175669>, <http://dx.doi.org/10.5281/zenodo.7175671> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.7175667>
    dc:description "Fig. 1. Proportion (%) of four parasite taxa in three fish species from the South Orkney Islands area, West Antarctica." ;
    fabio:hasRepresentation "https://zenodo.org/record/7175667/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.7175669>
    dc:description "Fig. 2. Proportion (%) of helminth species parasitizing three teleost fishes from the South Orkney Islands area, West Antarctica on larval and adult stages." ;
    fabio:hasRepresentation "https://zenodo.org/record/7175669/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.7175671>
    dc:description "Fig 3. Cluster analysis of the similarity between the helminth communities of the shallow-water (SW) and deepwater (DW) populations of fish species determined by the Bray-Curtis index." ;
    fabio:hasRepresentation "https://zenodo.org/record/7175671/files/figure.png" ;
    a fabio:Figure .

