    dc:creator "Fujii, Seiko", "Fuse, Kengo", "Hirota, Shun K.", "Kokami, Yasushi", "Sato, Hiroyuki", "Suyama, Yoshihisa", "Tagane, Shuichiro", "Yahara, Tetsukazu" ;
    dc:date "2023" ;
    dc:title "Molecular phylogeny and taxonomy of Hosta (Asparagaceae) on Shikoku Island, Japan, including five new species, one new subspecies, and two new status assignments" ;
    bibo:endPage "187" ;
    bibo:journal "PhytoKeys" ;
    bibo:pubDate "2023-11-17" ;
    bibo:startPage "137" ;
    bibo:volume "235" ;
    fabio:hasPart <http://dx.doi.org/10.3897/phytokeys.235.99140.figure1>, <http://dx.doi.org/10.3897/phytokeys.235.99140.figure21>, <http://dx.doi.org/10.3897/phytokeys.235.99140.figure22>, <http://dx.doi.org/10.3897/phytokeys.235.99140.figure23>, <http://dx.doi.org/10.3897/phytokeys.235.99140.figure24>, <http://dx.doi.org/10.3897/phytokeys.235.99140.figure5>, <http://dx.doi.org/10.3897/phytokeys.235.99140.figure6> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure1>
    dc:description "Figure 1. An unrooted Maximum Likelihood tree of 28 Japanese species of Hosta, reconstructed using MIG-seq data. Bootstrap values (50 % or larger) are indicated on internodes in or above the species level. Numbers in parentheses indicate the IDs of 6 clades." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938502" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure21>
    dc:description "Figure 21. Plants of H. tosana Kagami River lineage A photo taken on 7 Jul. 2021 by Se. Fujii, not collected B JPN 1307. Scale bars: 5 cm (A, B)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938522" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure22>
    dc:description "Figure 22. A flowering plant of H. tosana (a form corresponding to var. Hosta tosana tosana, JPN 6616). Scale bars: 5 cm (A); 1 cm (B)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938523" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure23>
    dc:description "Figure 23. Plants of H. tosana A a form corresponding to var. Hosta tosana caput-avis (JPN 6524) B a form corresponding to var. Hosta tosana tosana (JPN 6555). Scale bars: 5 cm (A, B)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938524" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure24>
    dc:description "Figure 24. Plants of H. tosana (a form corresponding to var. Hosta tosana caput-avis) A JPN 6571 B JPN 6572. Scale bars: 10 cm (A); 1 cm (B)." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938525" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure5>
    dc:description "Figure 5. A rooted Maximum Likelihood tree for Hosta Clade 4 reconstructed using MIG-seq data. Bootstrap values are indicated on internodes. Based on the Maximum Likelihood tree of 28 Japanese species (Fig. 1), the tree is rooted by the Kagami River lineage of H. tosana." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938506" ;
    a fabio:Figure .

<http://dx.doi.org/10.3897/phytokeys.235.99140.figure6>
    dc:description "Figure 6. A SplitsTree for Hosta Clade 4 reconstructed using MIG-seq data." ;
    fabio:hasRepresentation "https://binary.pensoft.net/fig/938507" ;
    a fabio:Figure .

