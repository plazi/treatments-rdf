    dc:date "2015" ;
    dc:title "Thirteen new Costa Rican species belonging to the genus Triraphis Ruthe (Braconidae: Rogadinae) with their host records" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.234391>, <http://dx.doi.org/10.5281/zenodo.234396>, <http://dx.doi.org/10.5281/zenodo.234408> ;
    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.234391>
    dc:description "FIGURES 1 – 6. Ocell-ocular distance for: 1, Triraphis cortazari; 2, T. guarusa; 3, T. simphlex; 4, T. balteus; 5, T. defectus; 6, T. paraholos. Scale bar in millimeters." ;
    fabio:hasRepresentation "https://zenodo.org/record/234391/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.234396>
    dc:description "FIGURE 29 – 34. Triraphis defectus, 29, dorsal habitus; 30, lateral habitus; 31, mesosoma, dorsal view; 32, mesosoma, lateral view; 33, head, anterior view; 34, metasoma, dorsal view. Scale bar in millimeters." ;
    fabio:hasRepresentation "https://zenodo.org/record/234396/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.234408>
    dc:description "FIGURE 101 – 108. Wing venation and wing pattern for: 101, Triraphis balteus; 102, T. fusciceps (Cresson); 103, T. chinusi; 104, T. guarusa; 105, T. cortazari; 106, T. ikelops; 107, T. defectus and 108, T. melasops." ;
    fabio:hasRepresentation "https://zenodo.org/record/234408/files/figure.png" ;
    a fabio:Figure .

