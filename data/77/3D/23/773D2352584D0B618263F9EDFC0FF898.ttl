    a fabio:JournalArticle .

<http://dx.doi.org/10.5281/zenodo.172393>
    dc:description "FIGURE 1 – 4. Formicaphagus tyrannina n. sp. 1 — male; 2 — male genitalia; 3 — female; 4 — female ventral terminalia; 5 — dorsal anterior plate; 6 — 7 Dorsal anterior plate: 6 — F. donpetersi; 7 — F. arnoldi. Scales 1 mm (Figs 1, 3), 0.01 mm (Figs 5 – 7), 0.05 mm (Figs 2, 4)." ;
    fabio:hasRepresentation "https://zenodo.org/record/172393/files/figure.png" ;
    a fabio:Figure .

