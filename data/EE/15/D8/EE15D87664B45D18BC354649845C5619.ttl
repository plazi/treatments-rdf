    dc:title "Notes on species of Talaus Simon, 1886 (Araneae, Thomisidae) from China, with descriptions of two new species" ;
    bibo:endPage "212" ;
    bibo:journal "ZooKeys" ;
    bibo:pubDate "2024-01-29" ;
    bibo:startPage "195" ;
    bibo:volume "1190" ;
