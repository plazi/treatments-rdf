    dc:title "Description of Chlorogomphus danhkyi sp. nov. from Vu Quang National Park, central Vietnam with notes on other congeners from the Park (Odonata Chlorogomphidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.4930364>, <http://dx.doi.org/10.5281/zenodo.4930368>, <http://dx.doi.org/10.5281/zenodo.4930366>, <http://dx.doi.org/10.5281/zenodo.4930373> ;
