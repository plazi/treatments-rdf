    dc:title "Isospora coerebae Berto, Flausino, Luz, Ferreira and Lopes 2010" ;
    dwc:basisOfRecord <http://tb.plazi.org/GgServer/dwcaRecords/7E35E156FFA5FFB535F5CB65FDAF28CB.mc.46F45A1DFFA5FFB43459CBF1FD392911> ;
