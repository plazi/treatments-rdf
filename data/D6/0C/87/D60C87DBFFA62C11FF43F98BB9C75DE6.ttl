    dc:title "A new species of Xenophrys (Amphibia: Anura: Megophryidae) from Truong Son Range, Vietnam" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.6622894>, <http://dx.doi.org/10.5281/zenodo.6622896>, <http://dx.doi.org/10.5281/zenodo.6622898>, <http://dx.doi.org/10.5281/zenodo.6622900> ;
