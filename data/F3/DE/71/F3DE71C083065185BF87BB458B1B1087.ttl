    dc:creator "Hemp, Claudia; Massa, Bruno" ;
    dc:title "Cestromoecha Karsch 1893" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Poreuomenini_Karsch_1893> ;
