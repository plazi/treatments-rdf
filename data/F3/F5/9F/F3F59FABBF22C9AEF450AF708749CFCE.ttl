    dc:creator "Sharkey, Michael J.; Parys, Katherine A.; Clutts, Stephanie" ;
    dc:title "Neothlipsis parysae Sharkey 2011, sp. n." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Neothlipsis_parysae_Sharkey_2011> ;
