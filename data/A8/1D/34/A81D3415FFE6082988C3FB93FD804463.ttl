    dc:title "The oribatid mite genus Nothrus Koch, 1836 (Acari: Oribatida: Nothridae) of South Africa, including a key to African species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.210366>, <http://dx.doi.org/10.5281/zenodo.210365>, <http://dx.doi.org/10.5281/zenodo.210367>, <http://dx.doi.org/10.5281/zenodo.210368>, <http://dx.doi.org/10.5281/zenodo.210370>, <http://dx.doi.org/10.5281/zenodo.210369> ;
