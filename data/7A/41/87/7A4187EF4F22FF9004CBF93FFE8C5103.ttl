    cito:cites <http://dx.doi.org/10.5281/zenodo.6461481>, <http://dx.doi.org/10.5281/zenodo.6461487>, <http://dx.doi.org/10.5281/zenodo.6461491>, <http://dx.doi.org/10.5281/zenodo.6461497>, <http://dx.doi.org/10.5281/zenodo.6461489>, <http://dx.doi.org/10.5281/zenodo.6461483>, <http://dx.doi.org/10.5281/zenodo.6461485> ;
    dc:creator "Cumberlidge, Neil; Daniels, Savel R." ;
    dc:title "Potamonautinae Bott 1970" ;
