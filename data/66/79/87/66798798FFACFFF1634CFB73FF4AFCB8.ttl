    dc:creator "Agerbirk, Niels", "Christensen, Stina", "Cipollini, Don", "Hansen, Cecilie Cetti", "Hauser, Thure P.", "Jensen, Karen R.", "Kiefer, Christiane", "Koch, Marcus A.", "Lange, Conny Bruun Asmussen", "Olsen, Carl Erik", "Pattison, David I.", "Ørgaard, Marian" ;
    dc:date "2021" ;
    dc:title "Glucosinolate profiles and phylogeny in Barbarea compared to other tribe Cardamineae (Brassicaceae) and Reseda (Resedaceae), based on a library of ion trap HPLC-MS / MS data of reference desulfoglucosinolates" ;
    bibo:endPage "19" ;
    bibo:journal "Phytochemistry" ;
    bibo:pubDate "2021-05-31" ;
    bibo:series "112658" ;
