    dc:creator "Rodrigues, Miguel Trefaut; Santos, Ednilza Maranhão Dos" ;
    dc:date "2008" ;
    dc:title "A new genus and species of eyelid-less and limb reduced gymnophthalmid lizard from northeastern Brazil (Squamata, Gymnophthalmidae)" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.184043>, <http://dx.doi.org/10.5281/zenodo.184044>, <http://dx.doi.org/10.5281/zenodo.184045>, <http://dx.doi.org/10.5281/zenodo.184046>, <http://dx.doi.org/10.5281/zenodo.184047> ;
