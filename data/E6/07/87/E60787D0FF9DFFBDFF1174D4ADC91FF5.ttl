    dc:date "2009" ;
    dc:title "A new Jurassic carnivorous cockroach (Insecta, Blattaria, Raphidiomimidae) from the Inner Mongolia in China" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.185100>, <http://dx.doi.org/10.5281/zenodo.185101>, <http://dx.doi.org/10.5281/zenodo.185103> ;
