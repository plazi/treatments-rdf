    dc:title "Systematics and integrative taxonomic revision of the tribe Scopulini Duponchel, 1845 in Iran (Lepidoptera: Geometridae: Sterrhinae)" ;
    bibo:endPage "96" ;
    bibo:issue "1" ;
    bibo:journal "Zootaxa" ;
