    cito:cites <http://dx.doi.org/10.3897/mycokeys.69.33563.figure5>, <http://dx.doi.org/10.3897/mycokeys.69.33563.figure1>, <http://dx.doi.org/10.3897/mycokeys.69.33563.figure3> ;
    dc:creator "Saba, Malka; Haelewaters, Danny; Pfister, Donald H.; Khalid, Abdul Nasir" ;
    dc:title "Pseudosperma pinophilum Saba & Khalid 2020, sp. nov." ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Fungi/Pseudosperma_pinophilum_Saba_2020> ;
