    dc:title "Two new stygobiotic species of Horatia Bourguignat, 1887 (Hydrobiidae) from Croatia" ;
    fabio:hasPart <http://dx.doi.org/10.3897/subtbiol.37.61573.figure4>, <http://dx.doi.org/10.3897/subtbiol.37.61573.figure5> ;
