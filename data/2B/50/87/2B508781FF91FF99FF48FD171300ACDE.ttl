    dc:creator "Marchenko, Irina I." ;
    dc:date "2013" ;
    dc:title "A new species of Gamasiphis Berlese (Acari: Ologamasidae) from Russia (Sakhalin and Kuril Islands) with a key to the Asian species" ;
    fabio:hasPart <http://dx.doi.org/10.5281/zenodo.219232>, <http://dx.doi.org/10.5281/zenodo.219233> ;
