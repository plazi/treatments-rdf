    dc:description "FIGURE 1. Dorsal view of the Lectotype of L. dorbignyi (top) and a specimen collected in Sierra de Fiambalá. The arrows indicate the similar bands and spot that the two specimens exhibit." ;
    fabio:hasRepresentation "https://zenodo.org/record/274177/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.274178>
    dc:description "FIGURE 2. Dorsal view of a male specimen of L. dorbignyi from the Sierra de Fiambalá, Catamarca, Argentina. C. S. Abdala." ;
    fabio:hasRepresentation "https://zenodo.org/record/274178/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.274179>
    dc:description "FIGURE 4. Dorsal view of a female specimen of L. dorbignyi from the Sierra de Fiambalá, Catamarca, Argentina. Photo: C. S. Abdala." ;
    fabio:hasRepresentation "https://zenodo.org/record/274179/files/figure.png" ;
    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.274180>
    dc:description "FIGURE 5. Map of the Northwestern Argentina, showing known localities of L. dorbignyi (diamonds) and L. scrocchii (Black circles). The arrows indicate the restricted type locality of L. dorbignyi and the type locality of L. scrocchii. The white dots indicate the populated areas." ;
    fabio:hasRepresentation "https://zenodo.org/record/274180/files/figure.png" ;
    a fabio:Figure .

