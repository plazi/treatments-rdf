    dc:creator "Audisio, Paolo; Mancini, Emiliano; Biase, Alessio De" ;
    dc:title "Meligethes matronalis Audisio & Spornraft 1990" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Meligethes_matronalis_Audisio_1990> ;
