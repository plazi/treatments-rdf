    a fabio:Figure .

<http://dx.doi.org/10.5281/zenodo.281458>
    dc:description "FIGURE 22. Anatoma tangaroa new species. Paratypes. A. NW of Three Kings Islands, 188 m (NMNZ M. 150335). B. 28 km S of Great Island, Three King Islands, 120 m (NMNZ M. 160285). C. Middlesex Bank, NW of Three King Islands, 246 – 291 m (NMNZ M. 148568). Scale bars shell = 1 mm. Scale bars protoconch = 100 µm." ;
    fabio:hasRepresentation "https://zenodo.org/record/281458/files/figure.png" ;
