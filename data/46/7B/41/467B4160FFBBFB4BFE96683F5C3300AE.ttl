    dc:creator "David, Jerome; Roux, Michel; Messing, Charles G.; Ameziane, Nadia" ;
    dc:title "Endoxocrinus (Diplocrinus) alternicirrus subsp. sibogae Doderlein 1907" ;
    trt:augmentsTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Endoxocrinus_alternicirrus_sibogae_Doderlein_1907> ;
