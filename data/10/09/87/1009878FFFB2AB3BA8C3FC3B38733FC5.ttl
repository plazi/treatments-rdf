    dc:title "Moneuptychia wahlbergi Freitas, Barbosa, Siewert & Mielke, new species" ;
    trt:definesTaxonConcept <http://taxon-concept.plazi.org/id/Animalia/Moneuptychia_wahlbergi_Freitas_2015> ;
