<http://dx.doi.org/10.1111/zoj.12222>
        a               fabio:JournalArticle ;
        dc:creator      "Krynak, Katherine" , "Guayasamin, Juan M." , "Krynak, Tim" , "Hutter, Carl R." , "Culebras, Jaime" ;
        dc:date         "2015" ;
        dc:title        "Phenotypic plasticity raises questions for taxonomically important traits: a remarkable new Andean rainfrog (Pristimantis) with the ability to change skin texture" ;
        bibo:endPage    "928" ;
        bibo:issue      "4" ;
        bibo:journal    "Zoological Journal of the Linnean Society" ;
        bibo:pubDate    "2015-03-24" ;
        bibo:startPage  "913" ;
        bibo:volume     "173" ;
