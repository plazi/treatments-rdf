        dc:date         "2011" ;
        dc:title        "A new genus of large Vesicomyidae (Mollusca, Bivalvia, Vesicomyidae, Pliocardiinae) from the Congo margin, with the first record of the subfamily Pliocardiinae in the Bay of Biscay (northeastern Atlantic)" ;
        bibo:endPage    "99" ;
        bibo:issue      "1" ;
        bibo:journal    "Zoosystema" ;
