        dc:date         "2021" ;
        dc:title        "Castniidae of the Museum of Natural History of the University of Wroclaw: new findings from Friedrich Wilhelm Niepelt's collection with comments on Karl Adolf Georg Lauterbach and August Weberbauer" ;
        bibo:endPage    "132" ;
