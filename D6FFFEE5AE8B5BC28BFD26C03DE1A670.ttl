        dc:date         "2020" ;
        dc:title        "Synotis panzhouensis (Asteraceae, Senecioneae), a distinct new species with red-purple pappus from southwestern Guizhou, China" ;
        bibo:endPage    "86" ;
        bibo:journal    "PhytoKeys" ;
