        a               fabio:JournalArticle ;
        dc:creator      "Benjamin, Suresh P." , "Ranasinghe, U. G. S. L." ;
        dc:date         "2018" ;
        dc:title        "Three new species of Aprusia (Araneae: Oonopidae) from Sri Lanka with a phylogenetic analysis of the genus" ;
