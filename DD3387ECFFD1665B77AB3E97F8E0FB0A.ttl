        dc:creator      "Flannery, Tim F." , "Groves, C. P." ;
        dc:date         "1994" ;
        dc:title        "A revision of the genus Uromys Peters, 1867 (Muridae: Mammalia) with descriptions of two new species" ;
        bibo:endPage    "169" ;
        bibo:issue      "2" ;
        bibo:journal    "Records of the Australian Museum" ;
        bibo:pubDate    "1994-07-28" ;
        bibo:startPage  "145" ;
        bibo:volume     "46" ;
        fabio:hasPart   <http://dx.doi.org/10.5281/zenodo.4658478> .

