        a               fabio:JournalArticle ;
        dc:creator      "Louzada, Rafael Batista" , "Wanderley, Maria Das Graças Lapa" ;
        dc:date         "2011" ;
        dc:title        "A new species of Orthophytum (Bromeliaceae) from Chapada Diamantina, Bahia, Brazil" ;
        bibo:endPage    "30" ;
        bibo:journal    "Phytotaxa" ;
        bibo:pubDate    "2011-09-14" ;
