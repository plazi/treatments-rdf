<http://doi.org/10.5281/zenodo.4658447>
        a               fabio:JournalArticle ;
        dc:creator      "Gong, Jun" , "Song, Weibo" ;
        dc:date         "2004" ;
        dc:title        "Morphology and infraciliature of two marine species of Hartmannula (Protozoa, Ciliophora, Cyrtophorida), from scallop-farming waters off Qingdao (Tsingtao), China" ;
        bibo:endPage    "1337" ;
        bibo:issue      "11" ;
        bibo:journal    "Journal of Natural History" ;
        bibo:pubDate    "2004-01-01" ;
        bibo:startPage  "1327" ;
        bibo:volume     "38" ;
        fabio:hasPart   <http://dx.doi.org/10.5281/zenodo.4658540> , <http://dx.doi.org/10.5281/zenodo.4658536> , <http://dx.doi.org/10.5281/zenodo.4658542> , <http://dx.doi.org/10.5281/zenodo.4658538> .

<http://dx.doi.org/10.5281/zenodo.4658538>
        a                        fabio:Figure ;
        dc:description           "FIGS. 10–13. Morphology and infraciliature of Hartmannula angustipilosa from life (10, 11), after protargol (13) and silver nitrate impregnation (12). (10) Ventral view. (11) Dorsal view. (12) Silverline system on ventral side, arrows indicating contractile vacuole pores. (13) Ventral view, showing general appearance of infraciliature. P, podite. Bars: 30 µm." ;
        fabio:hasRepresentation  "https://zenodo.org/record/4658538/files/figure.png" .

