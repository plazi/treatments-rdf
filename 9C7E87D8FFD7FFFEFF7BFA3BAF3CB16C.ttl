        dc:date         "2019" ;
        dc:title        "New Synonymies and Lectotype Designations for the Neotropical Seed Beetle Genus Caryedes Hummel, 1827 (Coleoptera: Chrysomelidae: Bruchinae)" ;
        bibo:endPage    "328" ;
