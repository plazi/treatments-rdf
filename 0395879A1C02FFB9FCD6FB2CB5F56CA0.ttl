        dc:date         "2014" ;
        dc:title        "New species and global revision of Hippasteria (Hippasterinae: Goniasteridae; Asteroidea; Echinodermata)" ;
        bibo:endPage    "456" ;
        bibo:issue      "2" ;
        bibo:journal    "Zoological Journal of the Linnean Society" ;
