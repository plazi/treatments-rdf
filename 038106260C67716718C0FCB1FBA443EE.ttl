<https://doi.org/10.11646/zootaxa.4984.1.6>
        a               fabio:JournalArticle ;
        dc:creator      "Dunlop, Jason A." , "Mitov, Plamen G." , "Perkovsky, Evgeny E." ;
        dc:date         "2021" ;
        dc:title        "Harvestmen (Arachnida: Opiliones) in Eocene Rovno amber (Ukraine)" ;
        bibo:endPage    "72" ;
        bibo:issue      "1" ;
        bibo:journal    "Zootaxa" ;
