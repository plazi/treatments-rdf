<http://treatment.plazi.org/id/0645AF505C7FEE75FF393E77FBB9FF72>
        a                         trt:Treatment ;
        trt:augmentsTaxonConcept  <http://taxon-concept.plazi.org/id/Animalia/Eugenia_malacantha_Legrand_1961> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_brevistila_Legrand_1977> ;
        trt:citesTaxonName        <urn:Eugenia_suberosa> , <urn:Eugenia_cana> , <urn:Stenocalyx_blastanthus> , <urn:Eugenia_umbrosa> , <urn:Eugenia_pohliana> , <urn:Phyllocalyx_regelianus> , <urn:Eugenia_longipedunculata> , <urn:Phyllocalyx_luschnathianus> , <urn:Phyllocalyx_strictus> , <urn:Eugenia_verticillaris> , <urn:Eugenia> , <urn:Eugenia_goyazensis> , <urn:Eugenia_selloi> , <urn:Eugenia_regeliana> , <urn:Eugenia_magnifolia> , <urn:Eugenia_anomala> , <urn:Phyllocalyx_edulis> , <urn:Eugenia_involucrata> , <urn:Eugenia_nitida> , <urn:Eugenia_calycina> , <urn:Eugenia_humilis> , <urn:Calycorectes_australis> , <urn:Eugenia_australis> , <urn:Stenocalyx_longipes> , <urn:Eugenia_luschnathiana> , <urn:Eugenia_tinguyensis> , <urn:Hexachlamys_humilis> , <urn:Eugenia_lourteigiae> , <urn:Eugenia_stricta> , <urn:Eugenia_gracilis> , <urn:Eugenia_blastantha> , <urn:Eugenia_lindbergiana> , <urn:Eugenia_duarteana> , <urn:Calycorectes_duarteanus> , <urn:Calycorectes_lourteigiae> , <urn:Eugenia_nutans> , <urn:Eugenia_hiemalis> , <urn:Eugenia_pisiformis> , <urn:Eugenia_pallescens> , <urn:Eugenia_longipes> ;
        trt:definesTaxonConcept   <http://taxon-concept.plazi.org/id/Plantae/Eugenia_punicifolia_DC._2010> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_neogracilis_Mazine_2010> ;
        trt:deprecates            <http://taxon-concept.plazi.org/id/Animalia/Eugenia_brevistila_Legrand_1977> , <http://taxon-concept.plazi.org/id/Plantae/Myrtus_punicifolia_Kunth_2010> , <http://taxon-concept.plazi.org/id/Plantae/Eugenia_punicifolia_DC._2010> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_neonitida_Sobral_1995> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_neogracilis_Mazine_2010> , <http://taxon-concept.plazi.org/id/Plantae/Eugenia_rufoflavescens_Mattos_2000> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_vallsiana_Stehmann_2009> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_vallsiana_Mattos_1995> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_malacantha_Legrand_1961> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_falkenbergiana_Mattos_2005> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_schadrackiana_Legrand_1961> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_neoaustralis_Sobral_2003> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_strictissima_Govaerts_2008> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_plurisepala_Chodat_2003> , <http://taxon-concept.plazi.org/id/Animalia/Eugenia_duckeana_Mattos_1969> ;
        trt:publishedIn           <http://dx.doi.org/10.11646/phytotaxa.8.1.6> ;
