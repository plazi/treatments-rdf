        a               fabio:JournalArticle ;
        dc:creator      "Chen, Jiun-Hong" , "Chang, Chih-Han" ;
        dc:date         "2005" ;
        dc:title        "Three new species of octothecate pheretimoid earthworms from Taiwan, with discussion on the biogeography of related species" ;
