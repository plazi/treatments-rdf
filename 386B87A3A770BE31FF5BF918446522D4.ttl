        dc:date         "2020" ;
        dc:title        "Further notes on the flower chafer genus Platysodes Westwood, 1873 (Coleoptera Scarabaeidae: Cetoniinae) with description of a new species from Himalaya" ;
        bibo:endPage    "200" ;
        bibo:issue      "2" ;
