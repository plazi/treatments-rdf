        trt:citesTaxonName        <http://tb.plazi.org/GgServer/lodRdf/Phyllocalyx_luschnathianus> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_tinguyensis> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_gracilis> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_blastantha> , <http://tb.plazi.org/GgServer/lodRdf/Stenocalyx_longipes> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_nitida> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_pohliana> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_verticillaris> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_longipes> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_luschnathiana> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_nutans> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_cana> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_umbrosa> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_suberosa> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_pisiformis> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_lourteigiae> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_magnifolia> , <http://tb.plazi.org/GgServer/lodRdf/Stenocalyx_blastanthus> , <http://tb.plazi.org/GgServer/lodRdf/Phyllocalyx_edulis> , <http://tb.plazi.org/GgServer/lodRdf/Calycorectes_lourteigiae> , <http://tb.plazi.org/GgServer/lodRdf/Eugenia_selloi> ;
