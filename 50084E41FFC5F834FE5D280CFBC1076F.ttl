<http://dx.doi.org/10.1080/00222933.2018.1449912>
        a               fabio:JournalArticle ;
        dc:creator      "Roelke, Corey E." , "Reyes-Velasco, Jacobo" , "McGuire, Jimmy A." , "Holmes, Iris A." , "Cox, Christian L." , "Davis Rabosky, Alison R." , "Campbell, Jonathan A." , "Smith, Eric N." , "Flores-Villela, Oscar" ;
        dc:date         "2018" ;
        dc:title        "Synopsis and taxonomic revision of three genera in the snake tribe Sonorini" ;
        bibo:endPage    "988" ;
        bibo:issue      "13 - 16" ;
        bibo:journal    "Journal of Natural History" ;
        bibo:pubDate    "2018-04-11" ;
