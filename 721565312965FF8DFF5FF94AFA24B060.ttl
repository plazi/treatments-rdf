<http://dx.doi.org/10.5281/zenodo.4503051>
        a                        fabio:Figure ;
        dc:description           "Fig. 7. Dardanus balhibuon, new species, holotype. Female SL 14.3 mm, stn R38, NMCR 40109. A, Left cheliped, outer view; B, Left cheliped, inner view; C, Right cheliped, outer view; D, Right cheliped, inner view. Scale bars = 1 mm." ;
        fabio:hasRepresentation  "https://zenodo.org/record/4503051/files/figure.png" .

